---
import ThemeToggle from '@/components/ThemeToggle.astro';
---

<header class="sticky top-0 z-50 bg-base/80 backdrop-blur-md border-b border-border print:hidden">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    
    <a href="/" class="flex items-center gap-2 group focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-md">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-accent group-hover:scale-110 transition-transform"><path d="m13 2-2 2.5h3L11 22l2-2.5h-3L13 2z"/></svg>
      <span class="font-display font-bold text-lg text-text-primary tracking-tight hidden sm:block">
        Electricity Load <span class="text-accent">Calculator</span>
      </span>
      <span class="font-display font-bold text-lg text-text-primary tracking-tight sm:hidden">
        Electricity <span class="text-accent">Load</span>
      </span>
    </a>

    <div class="flex items-center gap-2 sm:gap-6">
      <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-text-primary">
        <a href="/about-us" class="hover:text-accent transition-colors">About</a>
        <a href="/contact-us" class="hover:text-accent transition-colors">Contact</a>
        <a href="/privacy-policy" class="hover:text-accent transition-colors">Privacy</a>
        <a href="/terms-conditions" class="hover:text-accent transition-colors">Terms</a>
      </nav>
      <div class="w-px h-5 bg-border hidden md:block"></div>
      <ThemeToggle />
      
      <!-- Mobile Menu Toggle -->
      <button 
        id="mobile-menu-toggle"
        type="button" 
        class="md:hidden p-2 text-text-primary hover:text-accent focus:outline-none focus:ring-2 focus:ring-accent rounded-md transition-colors"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        <svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

  </div>

  <!-- Mobile Menu Content -->
  <div 
    id="mobile-menu" 
    class="hidden md:hidden border-t border-border bg-base/95 backdrop-blur-md overflow-hidden transition-all duration-300 ease-in-out"
  >
    <nav class="flex flex-col p-4 gap-1">
      <a href="/about-us" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors">About Us</a>
      <a href="/contact-us" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors">Contact Us</a>
      <a href="/privacy-policy" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors">Privacy Policy</a>
      <a href="/terms-conditions" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors">Terms & Conditions</a>
    </nav>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!toggleBtn || !mobileMenu || !menuIcon || !closeIcon) return;

    let isOpen = false;

    function toggleMenu() {
      isOpen = !isOpen;
      
      // Update UI
      mobileMenu.classList.toggle('hidden', !isOpen);
      menuIcon.classList.toggle('hidden', isOpen);
      closeIcon.classList.toggle('hidden', !isOpen);
      
      // Update ARIA
      toggleBtn.setAttribute('aria-expanded', isOpen.toString());
    }

    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (isOpen && !mobileMenu.contains(e.target as Node) && !toggleBtn.contains(e.target as Node)) {
        toggleMenu();
      }
    });

    // Handle escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        toggleMenu();
      }
    });
  }

  // Initial setup
  setupMobileMenu();

  // Re-run setup on View Transitions (if enabled in Astro)
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
