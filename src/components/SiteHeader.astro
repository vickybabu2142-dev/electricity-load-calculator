---
import ThemeToggle from '@/components/ThemeToggle.astro';
const isAssessment = Astro.url.pathname.startsWith('/assessment') || Astro.url.pathname.startsWith('/recommendations');
const isKnowledgeHub = Astro.url.pathname.startsWith('/knowledge-hub');
---

<header class="sticky top-0 z-50 bg-base/80 backdrop-blur-md border-b border-border print:hidden">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    
    <a href="/" class="flex items-center gap-2.5 group focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-md">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="w-7 h-7 text-accent flex-shrink-0 group-hover:scale-110 transition-transform"
        aria-hidden="true"
      >
        <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
      </svg>
      <span class="font-display font-bold text-lg text-text-primary tracking-tight hidden sm:block">
        Electricity Load <span class="text-accent">Calculator</span>
      </span>
      <span class="font-display font-bold text-lg text-text-primary tracking-tight sm:hidden">
        Electricity <span class="text-accent">Load</span>
      </span>
    </a>

    <div class="flex items-center gap-3 sm:gap-6">
      <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-text-primary">
        <a
          href="/assessment"
          class={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg border font-semibold transition-all ${isAssessment ? 'bg-accent text-accent-text border-accent shadow-lg shadow-accent/25' : 'border-border text-text-muted hover:border-accent/50 hover:text-accent'}`}
          data-astro-prefetch="hover"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4.5 h-4.5 flex-shrink-0 relative -translate-y-[1px]" aria-hidden="true">
            <path fill-rule="evenodd" d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm1 5.75a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5h-4.5a.75.75 0 0 1-.75-.75Zm.75 2.25a.75.75 0 0 0 0 1.5h2a.75.75 0 0 0 0-1.5h-2Z" clip-rule="evenodd"/>
          </svg>
          Assessment
        </a>
        <a
          href="/knowledge-hub"
          class={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg border font-semibold transition-all ${isKnowledgeHub ? 'bg-accent text-accent-text border-accent shadow-lg shadow-accent/25' : 'border-border text-text-muted hover:border-accent/50 hover:text-accent'}`}
          data-astro-prefetch="hover"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-4.5 h-4.5 flex-shrink-0 relative -translate-y-[2.5px]" aria-hidden="true">
            <path d="M6 11.5c-.3-.8-.9-1.5-1.5-2.2a3.8 3.8 0 0 1-.5-2.3c0-2.2 1.8-4 4-4s4 1.8 4 4c0 1-.4 2-.5 2.3-.6.7-1.2 1.4-1.5 2.2" />
            <path d="M5.5 13.5h5M6.5 15.2h3" />
            <path d="M8 1v1.2" />
            <path d="M3.5 3.5l.8.8" />
            <path d="M12.5 3.5l-.8.8" />
            <path d="M1.5 7h1.2" />
            <path d="M14.5 7h-1.2" />
          </svg>
          Knowledge Hub
        </a>
        <a href="/about-us" class="hover:text-accent transition-colors" data-astro-prefetch="hover">About</a>
        <a href="/contact-us" class="hover:text-accent transition-colors" data-astro-prefetch="hover">Contact</a>
      </nav>
      <div class="w-px h-5 bg-border hidden md:block"></div>
      
      <!-- Mobile Assessment Quick Link -->
      <a
        href="/assessment"
        class={`md:hidden p-2 rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-accent touch-manipulation ${isAssessment ? 'text-accent bg-accent/10' : 'text-text-primary hover:text-accent hover:bg-accent/5'}`}
        aria-label="View Assessment Report"
        data-astro-prefetch="tap"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-5 h-5" aria-hidden="true">
          <path fill-rule="evenodd" d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm1 5.75a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5h-4.5a.75.75 0 0 1-.75-.75Zm.75 2.25a.75.75 0 0 0 0 1.5h2a.75.75 0 0 0 0-1.5h-2Z" clip-rule="evenodd"/>
        </svg>
      </a>

      <!-- Mobile Knowledge Hub Quick Link -->
      <a
        href="/knowledge-hub"
        class={`md:hidden p-2 rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-accent touch-manipulation ${isKnowledgeHub ? 'text-accent bg-accent/10' : 'text-text-primary hover:text-accent hover:bg-accent/5'}`}
        aria-label="View Knowledge Hub Guides"
        data-astro-prefetch="tap"
      >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
            <path d="M6 11.5c-.3-.8-.9-1.5-1.5-2.2a3.8 3.8 0 0 1-.5-2.3c0-2.2 1.8-4 4-4s4 1.8 4 4c0 1-.4 2-.5 2.3-.6.7-1.2 1.4-1.5 2.2" />
            <path d="M5.5 13.5h5M6.5 15.2h3" />
            <path d="M8 1v1.2" />
            <path d="M3.5 3.5l.8.8" />
            <path d="M12.5 3.5l-.8.8" />
            <path d="M1.5 7h1.2" />
            <path d="M14.5 7h-1.2" />
          </svg>
      </a>

      <ThemeToggle />
      
      <!-- Mobile Menu Toggle -->
      <button 
        id="mobile-menu-toggle"
        type="button" 
        class="md:hidden p-2 text-text-primary hover:text-accent focus:outline-none focus:ring-2 focus:ring-accent rounded-md transition-colors touch-manipulation"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        <svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

  </div>

  <!-- Mobile Menu Content -->
  <div 
    id="mobile-menu" 
    class="hidden md:hidden border-t border-border bg-base/95 backdrop-blur-md overflow-hidden transition-all duration-300 ease-in-out"
  >
    <nav class="flex flex-col p-4 gap-1">
      <a href="/assessment" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors" data-astro-prefetch>Assessment</a>
      <a href="/knowledge-hub" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors" data-astro-prefetch>Knowledge Hub</a>
      <a href="/about-us" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors" data-astro-prefetch>About Us</a>
      <a href="/contact-us" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors" data-astro-prefetch>Contact Us</a>
      <a href="/privacy-policy" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors" data-astro-prefetch>Privacy Policy</a>
      <a href="/terms-conditions" class="px-4 py-3 text-base font-medium text-text-primary hover:bg-accent/10 hover:text-accent rounded-lg transition-colors" data-astro-prefetch>Terms & Conditions</a>
    </nav>
  </div>
</header>

<script>
  // Holds the AbortController for the current menu setup so we can cancel
  // all listeners cleanly before re-initialising on the next navigation.
  let menuController: AbortController | null = null;

  function setupMobileMenu() {
    menuController?.abort();
    menuController = new AbortController();
    const { signal } = menuController;

    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!toggleBtn || !mobileMenu || !menuIcon || !closeIcon) return;

    let isOpen = false;

    function toggleMenu() {
      isOpen = !isOpen;
      mobileMenu.classList.toggle('hidden', !isOpen);
      menuIcon.classList.toggle('hidden', isOpen);
      closeIcon.classList.toggle('hidden', !isOpen);
      toggleBtn.setAttribute('aria-expanded', isOpen.toString());
    }

    toggleBtn.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      e.stopPropagation();
      toggleMenu();
    }, { passive: false, signal });

    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => { if (isOpen) toggleMenu(); }, { signal });
    });

    document.addEventListener('pointerdown', (e) => {
      if (isOpen && !mobileMenu.contains(e.target as Node) && !toggleBtn.contains(e.target as Node)) {
        toggleMenu();
      }
    }, { signal });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) toggleMenu();
    }, { signal });
  }

  document.addEventListener('astro:page-load', setupMobileMenu);
</script>
