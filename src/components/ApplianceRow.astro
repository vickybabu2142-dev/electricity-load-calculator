---
/**
 * ApplianceRow.astro — now a thin SSR wrapper around the shared
 * buildRowHTML() template from @/utils/rowTemplate.
 *
 * Previously this component was a 146-line duplicate of the
 * client-side buildRowHTML() function in index.astro with subtle
 * differences (truncated aria-labels, missing input id/label pairs).
 *
 * Both SSR and dynamic client-side rows now use the same source.
 */
import type { Appliance } from '@/types';
import { buildRowHTML } from '@/utils/rowTemplate';

interface Props {
  appliance: Appliance;
  index: number; // kept for API compatibility with ApplianceCategory.astro
}

const { appliance } = Astro.props;
---

<Fragment set:html={buildRowHTML(appliance)} />
