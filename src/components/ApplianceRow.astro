---
import type { Appliance } from '@/types';
import { calculateRowKWh } from '@/utils/calculations';

interface Props {
  appliance: Appliance;
  index: number;
}

const { appliance: a, index } = Astro.props;
const kwh = calculateRowKWh(a).toFixed(2);
---

<div
  class="appliance-row group flex flex-wrap lg:flex-nowrap items-center gap-y-3 gap-x-4 px-4 py-5 hover:bg-card-hover transition-colors duration-150 animate-slide-up"
  data-id={a.id}
  style={`animation-delay: ${index * 0.03}s;`}
>
  <!-- Row 1: Name -->
  <div class="flex items-center gap-3 flex-1 min-w-[200px]">
    <!-- Name -->
    <div class="flex-1">
      <span
        class="text-sm font-normal transition-colors duration-150"
        style={a.qty > 0 ? 'color: var(--text-primary);' : 'color: var(--text-muted);'}
      >
        {a.name}
      </span>
      {a.custom && (
        <span class="ml-2 text-[10px] font-mono px-1.5 py-0.5 rounded bg-border text-accent">
          CUSTOM
        </span>
      )}
    </div>
  </div>

  <!-- Row 2: Metrics (Watts, Qty, Hours, kWh) + Actions -->
  <div class="flex items-center justify-between gap-1 w-full lg:w-auto lg:contents lg:gap-3">
    <!-- Watts -->
    <div class="flex items-center gap-1">
      <label class="sr-only" for={`watts-${a.id}`}>Watts</label>
      <input
        id={`watts-${a.id}`}
        type="number"
        value={a.watts}
        min="1"
        max="99999"
        class="w-14 sm:w-20 bg-base border border-border rounded-lg px-1.5 py-1 text-center font-mono text-xs sm:text-sm text-text-primary focus:border-accent focus:outline-none transition-colors"
        data-action="update-watts"
        data-id={a.id}
        aria-label={`Watts for ${a.name}`}
      />
      <span class="text-[9px] sm:text-[11px] text-text-muted font-mono uppercase">W</span>
    </div>

    <!-- Qty stepper -->
    <div class="flex items-center" role="group" aria-label={`Quantity for ${a.name}`}>
      <button
        type="button"
        class="stepper-btn w-11 h-11 sm:w-8 sm:h-8 rounded-md bg-border text-text-primary hover:text-accent-text active:text-accent-text font-bold text-sm hover:bg-accent active:bg-accent transition-colors focus:outline-none"
        data-action="decrement-qty"
        data-id={a.id}
        aria-label={`Decrease quantity of ${a.name}`}
      >−</button>
      <span
        class="w-6 sm:w-8 text-center font-mono text-xs sm:text-sm font-semibold tabular-nums"
        data-qty-display={a.id}
      >{a.qty}</span>
      <button
        type="button"
        class="stepper-btn w-11 h-11 sm:w-8 sm:h-8 rounded-md bg-border text-text-primary hover:text-accent-text active:text-accent-text font-bold text-sm hover:bg-accent active:bg-accent transition-colors focus:outline-none"
        data-action="increment-qty"
        data-id={a.id}
        aria-label={`Increase quantity of ${a.name}`}
      >+</button>
    </div>

    <!-- Hours -->
    <div class="flex items-center gap-1">
      <label class="sr-only" for={`hours-${a.id}`}>Hours per day</label>
      <input
        id={`hours-${a.id}`}
        type="number"
        value={a.hours}
        min="0"
        max="24"
        step="0.25"
        class="w-12 sm:w-16 bg-base border border-border rounded-lg px-1.5 py-1 text-center font-mono text-xs sm:text-sm text-text-primary focus:border-accent focus:outline-none transition-colors"
        data-action="update-hours"
        data-id={a.id}
        aria-label={`Hours per day for ${a.name}`}
      />
      <span class="text-[9px] sm:text-[11px] text-text-muted font-mono uppercase">h/d</span>
    </div>

    <!-- kWh/day result -->
    <div class="flex-shrink-0 text-right min-w-[65px] sm:min-w-[80px]">
      <span
        class="font-mono text-xs sm:text-sm font-semibold tabular-nums"
        style="color: var(--accent);"
        data-kwh-display={a.id}
      >{kwh}</span>
      <span class="text-[9px] sm:text-[10px] text-text-muted ml-0.5">kWh(unit)</span>
    </div>

    <!-- Actions -->
    <div class="flex-shrink-0 w-11 h-11 sm:w-8 sm:h-8 flex items-center justify-center">
      {a.custom && (
        <button
          type="button"
          class="w-10 h-10 sm:w-8 sm:h-8 rounded-md text-text-muted hover:text-danger active:text-danger hover:bg-border transition-colors focus:outline-none"
          data-action="delete-appliance"
          data-id={a.id}
          aria-label={`Remove ${a.name}`}
          title="Remove appliance"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mx-auto">
            <path d="M3 6h18"></path>
            <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
            <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
          </svg>
        </button>
      )}
    </div>
  </div>
</div>
