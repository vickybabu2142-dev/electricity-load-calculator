---
/**
 * ConfirmModal.astro — a styled, accessible confirmation dialog.
 * Replaces the native window.confirm() which is unstyled, blocks
 * the main thread, and looks inconsistent across browsers/OS.
 *
 * Usage (JavaScript):
 *   import { showConfirm } from '@/scripts/calculator/confirm';
 *   const ok = await showConfirm('Reset all appliances?');
 *   if (ok) { ... }
 */
---

<div
  id="confirm-modal"
  class="fixed inset-0 z-[60] hidden items-center justify-center p-4 no-print"
  role="alertdialog"
  aria-modal="true"
  aria-labelledby="confirm-title"
  aria-describedby="confirm-message"
>
  <!-- Backdrop -->
  <div
    id="confirm-backdrop"
    class="absolute inset-0 bg-black/70 backdrop-blur-sm animate-fade-in"
  ></div>

  <!-- Dialog box -->
  <div
    class="relative w-full max-w-sm bg-card border border-border rounded-2xl shadow-2xl overflow-hidden animate-scale-in"
    role="document"
  >
    <!-- Icon + Title -->
    <div class="flex items-start gap-4 px-6 pt-6 pb-4">
      <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center shadow-lg shadow-accent/5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-accent" aria-hidden="true">
          <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <h3 id="confirm-title" class="font-display font-bold text-lg text-text-primary leading-tight">
          Confirm Action
        </h3>
        <p id="confirm-message" class="mt-1 text-sm text-text-muted leading-relaxed">
          Are you sure?
        </p>
      </div>
    </div>

    <!-- Action buttons -->
    <div class="flex gap-3 px-6 pb-6">
      <button
        id="confirm-cancel-btn"
        type="button"
        class="btn-secondary flex-1 text-sm"
        autofocus
      >
        Cancel
      </button>
      <button
        id="confirm-ok-btn"
        type="button"
        class="btn-primary flex-1 text-sm shadow-lg shadow-accent/10"
      >
        Reset
      </button>
    </div>
  </div>
</div>

<style>
  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  .animate-fade-in  { animation: fade-in  150ms ease-out forwards; }
  .animate-scale-in { animation: scale-in 200ms ease-out forwards; }
</style>
