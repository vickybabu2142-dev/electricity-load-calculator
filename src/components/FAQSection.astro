---
import { FAQS } from '@/data/faqs';
---

<section class="max-w-[1400px] mx-auto px-4 sm:px-6 pb-24 print:hidden">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-display font-bold text-text-primary mb-12 uppercase tracking-wider border-l-4 border-accent pl-4">
      Frequently Asked <span class="text-accent">Questions</span>
    </h2>
    
    <div class="grid gap-4">
      {FAQS.map((faq) => (
        <details class="bg-card border border-border rounded-xl group transition-all duration-300">
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none focus:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-xl">
            <h3 class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors pr-8">
              {faq.question}
            </h3>
            <span class="flex-shrink-0 text-text-muted group-hover:text-accent group-open:rotate-180 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </summary>
          <div class="px-5 pb-5 pt-0 border-t border-border/50 mt-1 animate-fade-in">
            <p class="text-sm text-text-muted leading-relaxed mt-4">
              {faq.answer}
            </p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
