---
import type { ApplianceCategory } from '@/types';
import { CATEGORIES } from '@/data/appliances';

interface Props {
  category: ApplianceCategory;
}

const { category } = Astro.props;
---

<div class="add-appliance-wrapper px-4 py-3 border-t border-border border-dashed">
  <button
    type="button"
    class="add-toggle-btn flex items-center gap-2 text-sm text-text-faint hover:text-accent active:text-accent transition-colors focus:outline-none group"
    data-action="toggle-add-form"
    data-category={category}
    aria-expanded="false"
    aria-label={`Add custom appliance to ${category}`}
  >
    <span class="w-6 h-6 rounded-lg border border-border bg-base text-text-primary group-hover:border-accent group-hover:text-accent group-hover:bg-accent/5 flex items-center justify-center text-lg leading-none transition-all duration-200 shadow-sm">+</span>
    <span>Add custom appliance</span>
  </button>

  <form
    class="add-appliance-form hidden mt-3 flex flex-wrap gap-3 items-end"
    data-category={category}
    novalidate
  >
    <div class="flex flex-col gap-1">
      <label class="text-[10px] font-mono uppercase tracking-widest text-text-muted" for={`new-name-${category}`}>Name</label>
      <input
        id={`new-name-${category}`}
        type="text"
        placeholder="e.g. Hair Dryer"
        class="rounded-lg px-3 py-1.5 text-sm w-44 focus:outline-none"
        data-field="name"
        required
      />
    </div>

    <div class="flex flex-col gap-1">
      <label class="text-[10px] font-mono uppercase tracking-widest text-text-muted" for={`new-watts-${category}`}>Watts</label>
      <input
        id={`new-watts-${category}`}
        type="number"
        placeholder="1000"
        min="1"
        max="99999"
        class="rounded-lg px-3 py-1.5 text-sm text-center font-mono w-24 focus:outline-none"
        data-field="watts"
        required
      />
    </div>

    <div class="flex flex-col gap-1">
      <label class="text-[10px] font-mono uppercase tracking-widest text-text-muted" for={`new-hours-${category}`}>Hrs/Day</label>
      <input
        id={`new-hours-${category}`}
        type="number"
        placeholder="2"
        min="0"
        max="24"
        step="0.25"
        class="rounded-lg px-3 py-1.5 text-sm text-center font-mono w-20 focus:outline-none"
        data-field="hours"
        required
      />
    </div>

    <div class="flex flex-col gap-1">
      <label class="text-[10px] font-mono uppercase tracking-widest text-text-muted" for={`new-category-${category}`}>Category</label>
      <div class="relative group">
        <select
          id={`new-category-${category}`}
          class="custom-select w-full appearance-none pl-3 pr-8 py-1.5 text-sm cursor-pointer transition-all duration-200 hover:border-accent focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent"
          data-field="category"
        >
          {CATEGORIES.map(c => (
            <option value={c} selected={c === category} class="bg-card text-text-primary">{c}</option>
          ))}
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-text-muted group-hover:text-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </div>
      </div>
    </div>

    <div class="flex gap-2">
      <button
        type="submit"
        class="btn-primary flex-1 sm:flex-none"
      >
        Add
      </button>
      <button
        type="button"
        class="add-cancel-btn btn-secondary flex-1 sm:flex-none"
        data-action="cancel-add-form"
        data-category={category}
      >
        Cancel
      </button>
    </div>

    <!-- Validation error -->
    <p class="form-error hidden w-full text-xs text-danger font-mono"></p>
  </form>
</div>
