---
/**
 * KnowledgeHubCTA — Prominent calculator call-to-action used mid-article and at article end.
 */
interface Props {
  /** Variant: 'inline' (compact) or 'block' (full-width banner). Defaults to 'block'. */
  variant?: 'inline' | 'block';
  heading?: string;
  subtext?: string;
  /** Optional id for TOC anchor targeting */
  id?: string;
}
const {
  variant = 'block',
  heading = 'Need an Exact Calculation?',
  subtext = 'Skip the manual math. Our free Electricity Load Calculator gives you instant results — total load in kW, daily kWh, health score, and smart recommendations.',
  id,
} = Astro.props;
---

{variant === 'block' && (
  <div
    id={id}
    class="my-10 rounded-xl border border-border bg-card p-6 sm:p-8 relative overflow-hidden"
    style="box-shadow: 0 4px 32px -8px color-mix(in srgb, var(--accent), transparent 80%);"
  >
    <!-- Decorative glow -->
    <div
      class="absolute -top-10 -right-10 w-40 h-40 rounded-full pointer-events-none"
      style="background: radial-gradient(circle, color-mix(in srgb, var(--accent), transparent 75%) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <div class="relative flex flex-col sm:flex-row items-start sm:items-center gap-5">
      <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl border border-border bg-base">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-6 h-6 text-accent"
          aria-hidden="true"
        >
          <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z" />
        </svg>
      </div>
      <div class="flex-1">
        <h3 class="font-display font-bold text-xl text-text-primary mb-1">{heading}</h3>
        <p class="text-sm text-text-muted leading-relaxed max-w-xl">{subtext}</p>
      </div>
      <a
        href="/"
        class="btn-primary flex-shrink-0 text-sm px-5 py-2.5"
        data-astro-prefetch="hover"
      >
        Try Free Calculator
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
)}

{variant === 'inline' && (
  <p class="my-6 text-sm text-text-muted leading-relaxed">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent inline-block mr-1.5 align-middle -translate-y-[1px]" aria-hidden="true">
      <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .6 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
      <path d="M9 18h6" />
      <path d="M10 22h4" />
    </svg>
    <strong class="text-text-secondary">Pro tip:</strong> Instead of calculating manually, use our free{' '}
    <a href="/" class="text-accent hover:underline font-medium" data-astro-prefetch="hover">
      Electricity Load Calculator
    </a>{' '}
    to get instant results with MCB, cable, and inverter recommendations included.
  </p>
)}
