---
import type { Appliance, ApplianceCategory } from '@/types';
import { CATEGORY_ICONS } from '@/data/appliances';
import ApplianceRow from './ApplianceRow.astro';
import AddApplianceForm from './AddApplianceForm.astro';

interface Props {
  name: ApplianceCategory;
  appliances: Appliance[];
  index: number;
}

const { name, appliances, index } = Astro.props;

const totalWatts = appliances
  .filter(a => a.qty > 0)
  .reduce((s, a) => s + a.watts * a.qty, 0);

const dailyKWh = appliances
  .filter(a => a.qty > 0)
  .reduce((s, a) => s + (a.watts * a.qty * a.hours) / 1000, 0);

const activeCount = appliances.filter(a => a.qty > 0).length;

const icon = CATEGORY_ICONS[name];
---

<section
  class="category-section rounded-xl border border-border bg-card"
  data-category={name}
>
  <!-- Category header -->
  <button
    type="button"
    class="category-toggle w-full flex items-center gap-3 px-5 py-4 hover:bg-card-hover transition-colors text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-accent"
    data-action="toggle-category"
    aria-expanded="false"
    aria-controls={`category-body-${name.replace(/\s/g, '-')}`}
    data-category={name}
  >
    <!-- Icon -->
    <span class="text-accent flex-shrink-0" set:html={icon} />

    <!-- Name -->
    <span class="font-display font-bold text-lg text-text-primary flex-1 tracking-wide">
      {name}
    </span>

    <!-- Live badges -->
    <div class="hidden sm:flex items-center gap-2 mr-2">
      <span
        class="hidden sm:inline-flex items-center gap-1.5 font-mono text-xs px-2.5 py-1 rounded-full bg-base border border-border tabular-nums text-text-primary"
        data-category-watts={name}
      >
        <!-- Lightning bolt SVG -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-3 h-3 text-accent flex-shrink-0"
          aria-hidden="true"
        >
          <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
        </svg>
        <span>{totalWatts.toLocaleString()} W</span>
      </span>

      <span
        class="hidden sm:inline-flex items-center gap-1.5 font-mono text-xs px-2.5 py-1 rounded-full bg-base border border-border tabular-nums text-text-primary"
        data-category-kwh={name}
      >
        <!-- Bar chart SVG -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="#7a7f96" class="w-3 h-3 flex-shrink-0">
          <rect x="1" y="8" width="3" height="7" rx="0.5"/>
          <rect x="6" y="5" width="3" height="10" rx="0.5"/>
          <rect x="11" y="2" width="3" height="13" rx="0.5"/>
        </svg>
        <span>{dailyKWh.toFixed(2)} kWh(unit)/d</span>
      </span>
    </div>

    <!-- Appliance count -->
    <span class="text-xs text-text-muted mr-3 flex-shrink-0">
      <span
        class:list={[
          "transition-all duration-300",
          activeCount > 0 ? "bg-accent text-accent-text px-2 py-0.5 rounded-full font-bold" : ""
        ]}
        data-category-count-badge={name}
      >
        <span data-category-count={name}>{activeCount}/{appliances.length}</span>
      </span>
      <span class="ml-1">appliances</span>
    </span>

    <!-- Chevron -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="chevron w-5 h-5 text-text-muted flex-shrink-0"
      style="transform: rotate(-90deg)"
    >
      <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
    </svg>
  </button>

  <!-- Category body -->
  <div
    id={`category-body-${name.replace(/\s/g, '-')}`}
    class="category-body-wrap transition-all duration-300 ease-in-out"
  >
    <div class="category-body-inner">
      <!-- Column headers (desktop only) -->
      <div class="hidden lg:grid grid-cols-[1fr_90px_100px_80px_80px_28px] gap-3 px-4 py-2 border-b border-border text-[11px] font-mono uppercase tracking-widest text-text-secondary font-medium">
        <div class="text-left">Appliance</div>
        <div class="text-center">Watts</div>
        <div class="text-center">Quantity</div>
        <div class="text-center">Hrs/Day</div>
        <div class="text-right">Usage</div>
        <div></div>
      </div>

      <!-- Appliance rows -->
      <div data-rows-container={name}>
        {appliances.map((a, i) => (
          <ApplianceRow appliance={a} index={i} />
        ))}
      </div>

      <!-- Add appliance form -->
      <AddApplianceForm category={name} />
    </div>
  </div>
</section>

<style>
  .chevron {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  /* Prevent the global button scale animation on the category toggle for a more stable feel */
  .category-toggle:active {
    transform: none !important;
  }
</style>
