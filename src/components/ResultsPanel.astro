---
// No props — all values updated via JS
---

<aside
  id="results-panel"
  class="h-fit rounded-xl border border-border bg-card overflow-hidden animate-slide-up no-print transition-all duration-500 ease-in-out hover:-translate-y-1 hover:shadow-2xl hover:border-accent/30"
  style="animation-delay: 0.1s; box-shadow: var(--panel-shadow);"
  aria-label="Calculation results"
>
  <!-- Panel header -->
  <div class="px-5 py-4 border-b border-border flex items-center justify-between">
    <div class="flex items-center gap-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="w-5 h-5 text-accent flex-shrink-0"
        aria-hidden="true"
      >
        <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
      </svg>
      <h2 class="font-display font-bold text-lg tracking-wide text-text-primary">Your Load Summary</h2>
    </div>
    <!-- Load level badge -->
    <span
      id="load-level-badge"
      class="text-xs font-mono px-2.5 py-1 rounded-full border font-semibold"
      style="border-color: var(--success); color: var(--success);"
    >
      Light Load
    </span>
  </div>

  <div class="px-5 py-5 space-y-5">

    <!-- Total Load -->
    <div>
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Total Load</p>

      <!-- Primary: kW (more useful unit) — large -->
      <div class="flex items-end gap-1.5 mb-0.5">
        <span id="total-kw" class="font-display font-bold text-5xl tabular-nums leading-none" style="color: var(--accent);">0.00</span>
        <span class="font-mono text-lg text-text-muted mb-1">kW</span>
      </div>

      <!-- Secondary: Watts — smaller, muted -->
      <div class="flex items-center gap-1">
        <span id="total-watts" class="font-mono text-sm tabular-nums text-text-muted">0</span>
        <span class="font-mono text-xs text-text-muted">watts</span>
      </div>

      <!-- Progress bar -->
      <div class="mt-2 relative h-2.5 rounded-full overflow-hidden"
        style="background-color: var(--toggle-off);"
        role="progressbar" aria-label="Load percentage"
        aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="load-progress">
        <div
          id="load-bar"
          class="h-full rounded-full transition-all duration-500 ease-out"
          style="width: max(4px, 0%); background: var(--progress-gradient); border-radius: 999px;"
        ></div>
      </div>
      <!-- Threshold labels -->
      <div class="flex justify-between mt-1.5">
        <span class="font-mono text-[10px] text-text-muted">0 W</span>
        <span id="load-percent" class="font-mono text-[10px] tabular-nums" style="color: var(--accent);">0%</span>
        <span id="max-kw-label" class="font-mono text-[10px] text-text-muted">5 kW max</span>
      </div>
    </div>

    <!-- Smart Insights -->
    <div id="smart-insights-section" style="display:none;">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3">Smart Insights</p>
      <div class="grid grid-cols-2 gap-2.5">

        <!-- MCB -->
        <a id="insight-mcb-link" href="/insights/mcb" class="insight-card rounded-lg border border-border bg-base p-3.5 flex flex-col gap-2 no-underline" aria-label="View MCB details">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="insight-icon-ring flex h-6 w-6 items-center justify-center rounded-full flex-shrink-0" style="background:color-mix(in srgb, var(--accent), transparent 86%)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" style="color:var(--accent)" aria-hidden="true">
                  <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
                </svg>
              </span>
              <span class="text-[9px] font-mono uppercase tracking-widest text-text-muted leading-tight">MCB</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 opacity-40 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span id="insight-mcb-value" class="font-display font-bold text-lg leading-tight" style="color:var(--accent)">—</span>
          <p class="text-[10px] text-text-muted leading-snug">Safety margin included.</p>
          <span class="text-[10px] font-mono mt-auto flex items-center gap-1" style="color:var(--accent)">View Details →</span>
        </a>

        <!-- Cable -->
        <a id="insight-cable-link" href="/insights/cable" class="insight-card rounded-lg border border-border bg-base p-3.5 flex flex-col gap-2 no-underline" aria-label="View cable details">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="insight-icon-ring flex h-6 w-6 items-center justify-center rounded-full flex-shrink-0" style="background:color-mix(in srgb, var(--accent), transparent 86%)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-3.5 h-3.5" style="color:var(--accent)" aria-hidden="true">
                  <path d="M4 12h16M7 5v14M17 5v14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                </svg>
              </span>
              <span class="text-[9px] font-mono uppercase tracking-widest text-text-muted leading-tight">Cable</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 opacity-40 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span id="insight-cable-value" class="font-display font-bold text-lg leading-tight" style="color:var(--accent)">—</span>
          <p class="text-[10px] text-text-muted leading-snug">Current carrying capacity.</p>
          <span class="text-[10px] font-mono mt-auto flex items-center gap-1" style="color:var(--accent)">View Details →</span>
        </a>

        <!-- Inverter -->
        <a id="insight-inverter-link" href="/insights/inverter" class="insight-card rounded-lg border border-border bg-base p-3.5 flex flex-col gap-2 no-underline" aria-label="View inverter details">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="insight-icon-ring flex h-6 w-6 items-center justify-center rounded-full flex-shrink-0" style="background:color-mix(in srgb, var(--accent), transparent 86%)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" style="color:var(--accent)" aria-hidden="true">
                  <path d="M4 7h16a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Zm14 2H6v6h12V9Zm2-3h1v2h-1V6Zm-17 0H2v2h1V6Z"/>
                </svg>
              </span>
              <span class="text-[9px] font-mono uppercase tracking-widest text-text-muted leading-tight">Inverter</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 opacity-40 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span id="insight-inverter-value" class="font-display font-bold text-lg leading-tight" style="color:var(--accent)">—</span>
          <p class="text-[10px] text-text-muted leading-snug">Based on connected load.</p>
          <span class="text-[10px] font-mono mt-auto flex items-center gap-1" style="color:var(--accent)">View Details →</span>
        </a>

        <!-- Solar -->
        <a id="insight-solar-link" href="/insights/solar" class="insight-card rounded-lg border border-border bg-base p-3.5 flex flex-col gap-2 no-underline" aria-label="View solar details">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="insight-icon-ring flex h-6 w-6 items-center justify-center rounded-full flex-shrink-0" style="background:color-mix(in srgb, var(--accent), transparent 86%)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" style="color:var(--accent)" aria-hidden="true">
                  <path d="M12 2a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1Zm0 15a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm8-6a1 1 0 0 1 0 2h-1a1 1 0 1 1 0-2h1ZM5 11a1 1 0 0 1 0 2H4a1 1 0 1 1 0-2h1Zm14.07-6.07a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0ZM6.34 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0Zm12.02 1.41a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 1 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41ZM5.64 5.64a1 1 0 0 1 1.41 0l.71.71A1 1 0 1 1 6.34 7.76l-.71-.71a1 1 0 0 1 0-1.41ZM12 20a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1Z"/>
                </svg>
              </span>
              <span class="text-[9px] font-mono uppercase tracking-widest text-text-muted leading-tight">Solar</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 opacity-40 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span id="insight-solar-value" class="font-display font-bold text-lg leading-tight" style="color:var(--accent)">—</span>
          <p class="text-[10px] text-text-muted leading-snug">Based on monthly consumption.</p>
          <span class="text-[10px] font-mono mt-auto flex items-center gap-1" style="color:var(--accent)">View Details →</span>
        </a>

      </div>
    </div>

    <!-- Empty state — shown when no appliances are active -->
    <div
      id="empty-state-prompt"
      class="rounded-xl px-5 py-5 text-center"
      style="
        background: color-mix(in srgb, var(--accent), transparent 91%);
        border: 1px solid color-mix(in srgb, var(--accent), transparent 55%);
        box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent), transparent 82%), 0 6px 24px -6px color-mix(in srgb, var(--accent), transparent 65%);
      "
    >
      <!-- Icon badge -->
      <div class="flex justify-center mb-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-full"
          style="background: color-mix(in srgb, var(--accent), transparent 78%);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" style="color: var(--accent);" aria-hidden="true">
            <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
          </svg>
        </span>
      </div>

      <p class="text-sm font-semibold text-text-primary mb-1">Nothing selected yet</p>
      <p class="text-xs text-text-muted leading-relaxed">
        Pick a <span class="font-semibold" style="color: var(--accent);">Quick Start</span> above for an instant setup, or increase the quantity on any appliance manually.
      </p>
    </div>

    <!-- Divider -->
    <hr class="border-border" />

    <!-- Global Settings -->
    <div class="grid grid-cols-2 gap-3">
      <div class="space-y-1.5">
        <label for="currency-select" class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Currency</label>
        <div class="relative group">
          <select
            id="currency-select"
            data-action="change-currency"
            class="custom-select w-full appearance-none pl-3 pr-8 py-1.5 text-xs cursor-pointer transition-all duration-200 hover:border-accent focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent"
          >
            <option value="INR">INR (₹)</option>
            <option value="USD">USD ($)</option>
            <option value="EUR">EUR (€)</option>
            <option value="GBP">GBP (£)</option>
            <option value="CAD">CAD ($)</option>
            <option value="AUD">AUD ($)</option>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-text-muted group-hover:text-accent transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </div>
        </div>
      </div>
      <div class="space-y-1.5">
        <label for="max-kw-input" class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Max Capacity</label>
        <div class="flex items-center gap-1.5">
          <input
            id="max-kw-input"
            data-action="update-max-kw"
            type="number"
            value="5"
            min="1"
            max="100"
            class="flex-1 bg-base border border-border rounded-lg px-2 py-1.5 text-xs text-text-primary text-center focus:border-accent focus:outline-none font-mono"
          />
          <span class="text-[10px] font-mono text-text-muted uppercase">kW</span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-border" />

    <!-- Energy stats -->
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <span class="text-sm text-text-muted">Daily Consumption</span>
        <div>
          <span id="daily-kwh" class="font-mono font-semibold tabular-nums" style="color: var(--accent);">0.00</span>
          <span class="font-mono text-xs text-text-muted ml-1">kWh(unit)/day</span>
        </div>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-text-muted">Monthly Estimate</span>
        <div>
          <span id="monthly-kwh" class="font-mono font-semibold tabular-nums" style="color: var(--accent);">0</span>
          <span class="font-mono text-xs text-text-muted ml-1">kWh(unit)/mo</span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-border" />

    <!-- Bill estimate -->
    <div class="rounded-lg bg-base border border-border px-4 py-3">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm text-text-muted">Est. Monthly Bill</span>
        <span id="monthly-bill" class="font-display font-bold text-2xl tabular-nums" style="color: var(--accent);">0</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-text-muted">
        <span>Tariff:</span>
        <span class="font-mono currency-symbol">₹</span>
        <input
          id="tariff-input"
          data-action="update-tariff"
          type="number"
          value="8"
          min="0.01"
          max="500"
          step="0.5"
          class="w-20 bg-card border border-border rounded px-2 py-1 font-mono text-sm font-bold text-center focus:border-accent focus:outline-none"
          style="color: var(--accent);"
          aria-label="Electricity tariff per kWh(unit)"
        />
        <span class="font-mono">/ kWh(unit)</span>
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-border" />

    <!-- Top consumer -->
    <div>
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-2">Top Consumer</p>
      <div class="flex items-center justify-between">
        <span id="top-consumer-name" class="text-sm font-medium text-text-primary">—</span>
        <div>
          <span id="top-consumer-watts" class="font-mono font-semibold tabular-nums text-text-primary">0</span>
          <span class="font-mono text-xs text-text-muted ml-1">W</span>
        </div>
      </div>
    </div>

    <!-- Active Appliances Stat -->
    <hr class="border-border" />

    <div class="flex items-center justify-between">
      <span class="text-sm text-text-muted">Active Appliances</span>
      <div class="flex items-center gap-1.5">
        <span id="active-count" class="font-mono font-semibold tabular-nums text-text-primary">0</span>
        <span class="font-mono text-xs text-text-muted">/</span>
        <span id="total-count" class="font-mono text-xs tabular-nums text-text-muted">0</span>
        <span class="font-mono text-xs text-text-muted">appliances</span>
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-border" />

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row lg:flex-row gap-3">
      <button
        id="download-report-btn"
        data-action="download-report"
        type="button"
        class="flex-1 flex items-center justify-center gap-2 px-3 py-3 rounded-lg bg-accent text-accent-text text-lg font-display font-medium hover:bg-accent-dim transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-accent shadow-lg shadow-accent/20 active:scale-95"
        aria-label="View load report"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
          <path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
          <path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.186A10.004 10.004 0 0 1 10 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0 1 10 17c-4.257 0-7.893-2.66-9.336-7.41ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd" />
        </svg>
        Report
      </button>
    </div>

  </div>
</aside>
