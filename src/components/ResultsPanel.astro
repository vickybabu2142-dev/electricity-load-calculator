---
// No props — all values updated via JS
---

<aside
  id="results-panel"
  class="h-fit rounded-xl border border-border bg-card overflow-hidden animate-slide-up no-print"
  style="animation-delay: 0.1s; box-shadow: var(--panel-shadow);"
  aria-label="Calculation results"
>
  <!-- Panel header -->
  <div class="px-5 py-4 border-b border-border flex items-center justify-between">
    <div class="flex items-center gap-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="w-5 h-5 text-accent flex-shrink-0"
        aria-hidden="true"
      >
        <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
      </svg>
      <div>
        <h2 class="font-display font-bold text-lg tracking-wide text-text-primary leading-tight">Your Load Summary</h2>
        <p class="text-[10px] font-mono text-text-muted uppercase tracking-wider">
          <span id="active-count" class="text-accent font-bold">0</span> active / <span id="total-count">0</span> appliances
        </p>
      </div>
    </div>
    <!-- Load level badge -->
    <span
      id="load-level-badge"
      class="text-xs font-mono px-2.5 py-1 rounded-full border font-semibold"
      style="border-color: var(--success); color: var(--success);"
    >
      Light Load
    </span>
  </div>

  <div class="px-5 py-5 space-y-5">

    <!-- Total Load -->
    <div>
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Total Load</p>

      <!-- Primary: kW (more useful unit) — large -->
      <div class="flex items-end gap-1.5 mb-0.5">
        <span id="total-kw" class="font-display font-bold text-5xl tabular-nums leading-none text-accent">0.00</span>
        <span class="font-mono text-lg text-text-muted mb-1">kW</span>
      </div>

      <!-- Secondary: Watts — smaller, muted -->
      <div class="flex items-center gap-1">
        <span id="total-watts" class="font-mono text-sm tabular-nums text-text-muted">0</span>
        <span class="font-mono text-xs text-text-muted">watts</span>
      </div>

      <!-- Progress bar -->
      <div class="mt-2 relative h-2.5 rounded-full overflow-hidden"
        style="background-color: var(--toggle-off);"
        role="progressbar" aria-label="Load percentage"
        aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="load-progress">
        <div
          id="load-bar"
          class="h-full rounded-full transition-[width] duration-200 ease-out"
          style="width: max(4px, 0%); background: var(--progress-gradient); border-radius: 999px;"
        ></div>
      </div>
      <!-- Threshold labels -->
      <div class="flex justify-between mt-1.5">
        <span class="font-mono text-[10px] text-text-muted">0 W</span>
        <span id="load-percent" class="font-mono text-[10px] tabular-nums text-accent">0%</span>
        <span id="max-kw-label" class="font-mono text-[10px] text-text-muted">5 kW max</span>
      </div>
    </div>

    <!-- Global Settings -->
    <div class="space-y-1.5">
      <label for="max-kw-input" class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Max Capacity</label>
      <div class="flex items-center gap-1.5">
        <input
          id="max-kw-input"
          data-action="update-max-kw"
          type="number"
          value="5"
          min="1"
          max="100"
          class="flex-1 bg-base border border-border rounded-lg px-2 py-1.5 text-xs text-text-primary text-center focus:border-accent focus:outline-none font-mono"
        />
        <span class="text-[10px] font-mono text-text-muted uppercase">kW</span>
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-border" />

    <!-- Energy stats -->
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <span class="text-sm text-text-muted">Daily Consumption</span>
        <div>
          <span id="daily-kwh" class="font-mono font-semibold tabular-nums text-accent">0.00</span>
          <span class="font-mono text-xs text-text-muted ml-1">kWh(unit)/day</span>
        </div>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-text-muted">Monthly Estimate</span>
        <div>
          <span id="monthly-kwh" class="font-mono font-semibold tabular-nums text-accent">0</span>
          <span class="font-mono text-xs text-text-muted ml-1">kWh(unit)/mo</span>
        </div>
      </div>
    </div>

    <!-- Compact Health Score — shown when appliances active -->
    <div id="health-score-compact" style="display:none;">
      <div
        id="health-score-card"
        class="flex items-center justify-between rounded-xl border border-border p-3.5"
        style="background: var(--bg-card); transition: border-color 0.2s ease, background 0.2s ease;"
      >
        <div class="flex items-center gap-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0 text-accent" id="health-score-icon" aria-hidden="true">
            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z"/>
          </svg>
          <div>
            <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted leading-none mb-1">Health Score</p>
            <span
              id="health-score-label"
              class="inline-block text-[10px] font-mono font-semibold px-2 py-0.5 rounded-full border"
              style="color:#3ecf6e; background:color-mix(in srgb, #3ecf6e, transparent 85%); border-color:color-mix(in srgb, #3ecf6e, transparent 55%);"
            >Excellent</span>
          </div>
        </div>
        <div class="text-right flex-shrink-0">
          <span id="health-score-value" class="font-display font-bold text-3xl tabular-nums leading-none" style="color:#3ecf6e; transition: color 0.2s ease;">0</span>
          <span class="font-mono text-xs text-text-muted">/100</span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-border" />

    <!-- Empty state — shown when no appliances are active -->
    <div
      id="empty-state-prompt"
      class="rounded-xl px-5 py-5 text-center"
      style="
        background: color-mix(in srgb, var(--accent), transparent 94%);
        border: 1px solid color-mix(in srgb, var(--accent), transparent 75%);
        box-shadow: 0 4px 16px -4px color-mix(in srgb, var(--accent), transparent 85%);
      "
    >
      <!-- Icon badge -->
      <div class="flex justify-center mb-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-full empty-state-icon-pulse"
          style="background: color-mix(in srgb, var(--accent), transparent 88%);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-accent" aria-hidden="true">
            <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
          </svg>
        </span>
      </div>

      <p class="text-sm font-semibold text-text-primary mb-1">Nothing selected yet</p>
      <p class="text-xs text-text-muted leading-relaxed">
        Pick a <span class="text-accent font-medium">Quick Start</span> above for an instant setup, or tap <span class="text-accent font-medium">+ </span> to load any appliance manually.
      </p>
    </div>

    <!-- Generate Assessment CTA -->
    <a
      id="generate-assessment-btn"
      href="/assessment"
      class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg bg-accent text-accent-text font-display font-medium text-base hover:bg-accent-dim transition-all duration-300 shadow-lg shadow-accent/20 active:scale-95"
      aria-label="View your full electrical assessment report"
      data-astro-prefetch="hover"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 flex-shrink-0" aria-hidden="true">
        <path fill-rule="evenodd" d="M4.5 2A1.5 1.5 0 0 0 3 3.5v13A1.5 1.5 0 0 0 4.5 18h11a1.5 1.5 0 0 0 1.5-1.5V7.621a1.5 1.5 0 0 0-.44-1.06l-4.12-4.122A1.5 1.5 0 0 0 11.378 2H4.5ZM10 8a.75.75 0 0 1 .75.75v1.5h1.5a.75.75 0 0 1 0 1.5h-1.5v1.5a.75.75 0 0 1-1.5 0v-1.5h-1.5a.75.75 0 0 1 0-1.5h1.5v-1.5A.75.75 0 0 1 10 8Z" clip-rule="evenodd"/>
      </svg>
      Generate Full Assessment
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-70 flex-shrink-0" aria-hidden="true">
        <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
      </svg>
    </a>

  </div>
</aside>
