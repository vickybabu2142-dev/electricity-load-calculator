---
// No props — all values updated via JS
---

<aside
  id="results-panel"
  class="h-fit rounded-xl border border-border bg-card overflow-hidden animate-slide-up no-print"
  style="animation-delay: 0.1s; box-shadow: var(--panel-shadow);"
  aria-label="Calculation results"
>
  <!-- Panel header -->
  <div class="px-5 py-4 border-b border-border flex items-center justify-between">
    <div class="flex items-center gap-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="w-5 h-5 text-accent flex-shrink-0"
        aria-hidden="true"
      >
        <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
      </svg>
      <h2 class="font-display font-bold text-lg tracking-wide text-text-primary">Your Load Summary</h2>
    </div>
    <!-- Load level badge -->
    <span
      id="load-level-badge"
      class="text-xs font-mono px-2.5 py-1 rounded-full border font-semibold"
      style="border-color: var(--success); color: var(--success);"
    >
      Light Load
    </span>
  </div>

  <div class="px-5 py-5 space-y-5">

    <!-- Total Load -->
    <div>
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Total Load</p>

      <!-- Primary: kW (more useful unit) — large -->
      <div class="flex items-end gap-1.5 mb-0.5">
        <span id="total-kw" class="font-display font-bold text-5xl tabular-nums leading-none" style="color: var(--accent);">0.00</span>
        <span class="font-mono text-lg text-text-muted mb-1">kW</span>
      </div>

      <!-- Secondary: Watts — smaller, muted -->
      <div class="flex items-center gap-1">
        <span id="total-watts" class="font-mono text-sm tabular-nums text-text-muted">0</span>
        <span class="font-mono text-xs text-text-muted">watts</span>
      </div>

      <!-- Progress bar -->
      <div class="mt-2 relative h-2.5 rounded-full overflow-hidden"
        style="background-color: var(--toggle-off);"
        role="progressbar" aria-label="Load percentage"
        aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="load-progress">
        <div
          id="load-bar"
          class="h-full rounded-full transition-[width] duration-200 ease-out"
          style="width: max(4px, 0%); background: var(--progress-gradient); border-radius: 999px;"
        ></div>
      </div>
      <!-- Threshold labels -->
      <div class="flex justify-between mt-1.5">
        <span class="font-mono text-[10px] text-text-muted">0 W</span>
        <span id="load-percent" class="font-mono text-[10px] tabular-nums" style="color: var(--accent);">0%</span>
        <span id="max-kw-label" class="font-mono text-[10px] text-text-muted">5 kW max</span>
      </div>
    </div>

    <!-- Global Settings -->
    <div class="space-y-1.5">
      <label for="max-kw-input" class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Max Capacity</label>
      <div class="flex items-center gap-1.5">
        <input
          id="max-kw-input"
          data-action="update-max-kw"
          type="number"
          value="5"
          min="1"
          max="100"
          class="flex-1 bg-base border border-border rounded-lg px-2 py-1.5 text-xs text-text-primary text-center focus:border-accent focus:outline-none font-mono"
        />
        <span class="text-[10px] font-mono text-text-muted uppercase">kW</span>
      </div>
    </div>
    
    <!-- Divider -->
    <hr class="border-border" />

    <!-- Energy stats -->
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <span class="text-sm text-text-muted">Daily Consumption</span>
        <div>
          <span id="daily-kwh" class="font-mono font-semibold tabular-nums" style="color: var(--accent);">0.00</span>
          <span class="font-mono text-xs text-text-muted ml-1">kWh(unit)/day</span>
        </div>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-text-muted">Monthly Estimate</span>
        <div>
          <span id="monthly-kwh" class="font-mono font-semibold tabular-nums" style="color: var(--accent);">0</span>
          <span class="font-mono text-xs text-text-muted ml-1">kWh(unit)/mo</span>
        </div>
      </div>
    </div>
    
    <!-- Divider -->
    <hr class="border-border" />

    <!-- Smart Insights -->
    <div id="smart-insights-section" style="display:none;">
      <div class="flex items-center gap-2.5 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 flex-shrink-0" style="color:var(--accent); filter:drop-shadow(0 0 5px var(--accent))" aria-hidden="true">
          <path d="M9 16a5 5 0 1 1 6 0a3.5 3.5 0 0 0-1 3a2 2 0 0 1-4 0a3.5 3.5 0 0 0-1-3z"/>
          <line x1="9.7" y1="17" x2="14.3" y2="17"/>
        </svg>
        <p class="text-sm font-mono uppercase tracking-widest text-text-muted">Smart Insights</p>
      </div>
      <div class="grid grid-cols-2 gap-2.5">

        <!-- MCB -->
        <a id="insight-mcb-link" href="/insights/mcb" class="insight-card rounded-lg border border-border bg-base p-3.5 flex flex-col gap-2 no-underline" aria-label="View MCB details">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="insight-icon-ring flex h-6 w-6 items-center justify-center rounded-full flex-shrink-0" style="background:color-mix(in srgb, var(--accent), transparent 86%)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" style="color:var(--accent)" aria-hidden="true">
                  <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
                </svg>
              </span>
              <span class="text-xs font-mono uppercase tracking-widest text-text-muted leading-tight">MCB</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 opacity-40 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span id="insight-mcb-value" class="font-display font-bold text-lg leading-tight" style="color:var(--accent)">—</span>
          <p class="text-xs text-text-muted leading-snug">Safety margin included.</p>
          <span class="text-xs font-mono mt-auto flex items-center gap-1" style="color:var(--accent)">View Details →</span>
        </a>

        <!-- Cable -->
        <a id="insight-cable-link" href="/insights/cable" class="insight-card rounded-lg border border-border bg-base p-3.5 flex flex-col gap-2 no-underline" aria-label="View cable details">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="insight-icon-ring flex h-6 w-6 items-center justify-center rounded-full flex-shrink-0" style="background:color-mix(in srgb, var(--accent), transparent 86%)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-3.5 h-3.5" style="color:var(--accent)" aria-hidden="true">
                  <path d="M4 12h16M7 5v14M17 5v14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                </svg>
              </span>
              <span class="text-xs font-mono uppercase tracking-widest text-text-muted leading-tight">Cable</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 opacity-40 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span id="insight-cable-value" class="font-display font-bold text-lg leading-tight" style="color:var(--accent)">—</span>
          <p class="text-xs text-text-muted leading-snug">Current carrying capacity.</p>
          <span class="text-xs font-mono mt-auto flex items-center gap-1" style="color:var(--accent)">View Details →</span>
        </a>

        <!-- Inverter -->
        <a id="insight-inverter-link" href="/insights/inverter" class="insight-card rounded-lg border border-border bg-base p-3.5 flex flex-col gap-2 no-underline" aria-label="View inverter details">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="insight-icon-ring flex h-6 w-6 items-center justify-center rounded-full flex-shrink-0" style="background:color-mix(in srgb, var(--accent), transparent 86%)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" style="color:var(--accent)" aria-hidden="true">
                  <path d="M4 7h16a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Zm14 2H6v6h12V9Zm2-3h1v2h-1V6Zm-17 0H2v2h1V6Z"/>
                </svg>
              </span>
              <span class="text-xs font-mono uppercase tracking-widest text-text-muted leading-tight">Inverter</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 opacity-40 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span id="insight-inverter-value" class="font-display font-bold text-lg leading-tight" style="color:var(--accent)">—</span>
          <p class="text-xs text-text-muted leading-snug">Based on connected load.</p>
          <span class="text-xs font-mono mt-auto flex items-center gap-1" style="color:var(--accent)">View Details →</span>
        </a>

        <!-- Solar -->
        <a id="insight-solar-link" href="/insights/solar" class="insight-card rounded-lg border border-border bg-base p-3.5 flex flex-col gap-2 no-underline" aria-label="View solar details">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="insight-icon-ring flex h-6 w-6 items-center justify-center rounded-full flex-shrink-0" style="background:color-mix(in srgb, var(--accent), transparent 86%)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" style="color:var(--accent)" aria-hidden="true">
                  <path d="M12 2a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1Zm0 15a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm8-6a1 1 0 0 1 0 2h-1a1 1 0 1 1 0-2h1ZM5 11a1 1 0 0 1 0 2H4a1 1 0 1 1 0-2h1Zm14.07-6.07a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0ZM6.34 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0Zm12.02 1.41a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 1 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41ZM5.64 5.64a1 1 0 0 1 1.41 0l.71.71A1 1 0 1 1 6.34 7.76l-.71-.71a1 1 0 0 1 0-1.41ZM12 20a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1Z"/>
                </svg>
              </span>
              <span class="text-xs font-mono uppercase tracking-widest text-text-muted leading-tight">Solar</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 opacity-40 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span id="insight-solar-value" class="font-display font-bold text-lg leading-tight" style="color:var(--accent)">—</span>
          <p class="text-xs text-text-muted leading-snug">Based on monthly consumption.</p>
          <span class="text-xs font-mono mt-auto flex items-center gap-1" style="color:var(--accent)">View Details →</span>
        </a>

      </div>
    </div>

    <!-- Electrical Health Score -->
    <div id="health-score-section" style="display:none;">
      <div
        id="health-score-card"
        class="rounded-xl border p-4 space-y-4"
        style="border-color: var(--border); background: var(--bg-card); transition: border-color 0.2s ease, background 0.2s ease;"
      >

        <!-- Header -->
        <div class="flex items-center gap-2">
          <svg id="health-score-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0" style="color:var(--accent); transition: color 0.2s ease;" aria-hidden="true">
            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z"/>
          </svg>
          <p class="text-sm font-mono uppercase tracking-widest text-text-muted">Electrical Health Score</p>
        </div>

        <!-- Ring gauge + label -->
        <div class="flex items-center gap-5">

          <!-- Circular ring gauge (r=36, C=226.19) -->
          <div class="relative flex-shrink-0" style="width:90px; height:90px;">
            <svg viewBox="0 0 90 90" class="w-full h-full" style="transform:rotate(-90deg);" aria-hidden="true">
              <circle cx="45" cy="45" r="36" fill="none" stroke="var(--toggle-off)" stroke-width="7"/>
              <circle
                id="health-score-ring"
                cx="45" cy="45" r="36"
                fill="none"
                stroke="#3ecf6e"
                stroke-width="7"
                stroke-linecap="round"
                style="stroke-dasharray:226.19; stroke-dashoffset:226.19; transition: stroke-dashoffset 0.3s ease, stroke 0.2s ease;"
              />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
              <span id="health-score-value" class="font-display font-bold text-2xl tabular-nums leading-none" style="color:#3ecf6e; transition: color 0.2s ease;">0</span>
              <span class="text-[9px] font-mono text-text-muted leading-none mt-0.5">/ 100</span>
            </div>
          </div>

          <!-- Label pill + description -->
          <div class="flex-1 min-w-0 space-y-2">
            <span
              id="health-score-label"
              class="inline-block text-xs font-mono font-semibold px-3 py-1.5 rounded-full border"
              style="color:#3ecf6e; background:color-mix(in srgb, #3ecf6e, transparent 85%); border-color:color-mix(in srgb, #3ecf6e, transparent 55%);"
            >Excellent</span>
            <p id="health-score-desc" class="text-xs text-text-muted leading-relaxed">Your electrical setup is well-balanced and efficient.</p>
          </div>

        </div>

        <!-- Sub-score rows -->
        <div class="space-y-2.5">

          <div class="space-y-1">
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-text-muted">Load Utilization</span>
              <span id="health-sub-utilization-pts" class="text-[11px] font-mono tabular-nums text-text-muted">0/30</span>
            </div>
            <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--toggle-off);">
              <div id="health-sub-utilization-bar" class="h-full rounded-full transition-[width] duration-200 ease-out" style="width:0%; background:var(--accent);"></div>
            </div>
          </div>

          <div class="space-y-1">
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-text-muted">Energy Efficiency</span>
              <span id="health-sub-efficiency-pts" class="text-[11px] font-mono tabular-nums text-text-muted">0/30</span>
            </div>
            <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--toggle-off);">
              <div id="health-sub-efficiency-bar" class="h-full rounded-full transition-[width] duration-200 ease-out" style="width:0%; background:var(--accent);"></div>
            </div>
          </div>

          <div class="space-y-1">
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-text-muted">Safety Readiness</span>
              <span id="health-sub-safety-pts" class="text-[11px] font-mono tabular-nums text-text-muted">0/20</span>
            </div>
            <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--toggle-off);">
              <div id="health-sub-safety-bar" class="h-full rounded-full transition-[width] duration-200 ease-out" style="width:0%; background:var(--accent);"></div>
            </div>
          </div>

          <div class="space-y-1">
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-text-muted">Renewable Readiness</span>
              <span id="health-sub-renewable-pts" class="text-[11px] font-mono tabular-nums text-text-muted">0/20</span>
            </div>
            <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--toggle-off);">
              <div id="health-sub-renewable-bar" class="h-full rounded-full transition-[width] duration-200 ease-out" style="width:0%; background:var(--accent);"></div>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Consumption Breakdown -->
    <div id="consumption-breakdown-section" style="display:none;">
      <div class="rounded-xl border border-border bg-card p-4 space-y-4">

        <!-- Header -->
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
            <path fill-rule="evenodd" d="M2.25 13.5a8.25 8.25 0 0 1 8.25-8.25.75.75 0 0 1 .75.75v6.75H18a.75.75 0 0 1 .75.75 8.25 8.25 0 0 1-16.5 0Z" clip-rule="evenodd"/>
            <path fill-rule="evenodd" d="M12.75 3a.75.75 0 0 1 .75-.75 8.25 8.25 0 0 1 8.25 8.25.75.75 0 0 1-.75.75h-7.5a.75.75 0 0 1-.75-.75V3Z" clip-rule="evenodd"/>
          </svg>
          <p class="text-sm font-mono uppercase tracking-widest text-text-muted">Consumption Breakdown</p>
        </div>

        <!-- Donut chart + legend -->
        <div class="flex items-center gap-4">

          <!-- SVG donut -->
          <div class="flex-shrink-0 relative" style="width:130px; height:130px;">
            <svg
              id="donut-chart-svg"
              viewBox="0 0 100 100"
              class="w-full h-full"
              style="transform: rotate(-90deg);"
              aria-hidden="true"
            >
              <!-- Track ring -->
              <circle cx="50" cy="50" r="35" fill="none" stroke="var(--toggle-off)" stroke-width="9"/>
              <!-- Slices injected by JS -->
            </svg>
            <!-- Center label -->
            <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none text-center px-2">
              <!-- Default: total kWh -->
              <div id="donut-center-default">
                <span id="donut-center-kwh" class="font-display font-bold text-base tabular-nums leading-tight" style="color:var(--accent)">0.0</span>
                <span class="block text-[10px] font-mono text-text-muted leading-tight mt-0.5">kWh/day</span>
              </div>
              <!-- Hover: category detail -->
              <div id="donut-center-hover" style="display:none;">
                <span id="donut-hover-pct" class="font-display font-bold text-lg tabular-nums leading-tight" style="color:var(--accent)">0%</span>
                <span id="donut-hover-kwh" class="block text-[9px] font-mono text-text-muted leading-tight mt-0.5">0 kWh</span>
              </div>
            </div>
          </div>

          <!-- Legend -->
          <div id="breakdown-legend" class="flex-1 min-w-0 space-y-0.5">
            <!-- Injected by JS -->
          </div>

        </div>

        <!-- Insight line -->
        <div id="breakdown-insight-text" class="flex items-center gap-2 rounded-lg px-3 py-2.5" style="background: color-mix(in srgb, var(--accent), transparent 92%); border: 1px solid color-mix(in srgb, var(--accent), transparent 78%);">
          <svg id="breakdown-insight-dot" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0" style="width:12px; height:12px; color: var(--accent);" aria-hidden="true">
            <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
          </svg>
          <span id="breakdown-insight-label" class="text-xs font-medium"></span>
        </div>

      </div>
    </div>

    <!-- High Consumption Alerts -->
    <div id="high-consumption-section" style="display:none;">
      <div class="rounded-xl border p-4 space-y-3" style="border-color: color-mix(in srgb, var(--danger), transparent 60%); background: color-mix(in srgb, var(--danger), transparent 91%);">

        <!-- Header -->
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0" style="color:var(--danger)" aria-hidden="true">
            <path fill-rule="evenodd" d="M9.401 3.003c1.155-2 4.043-2 5.197 0l7.355 12.748c1.154 2-.29 4.5-2.599 4.5H4.645c-2.309 0-3.752-2.5-2.598-4.5L9.4 3.003ZM12 8.25a.75.75 0 0 1 .75.75v3.75a.75.75 0 0 1-1.5 0V9a.75.75 0 0 1 .75-.75Zm0 8.25a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z" clip-rule="evenodd"/>
          </svg>
          <p class="text-sm font-mono uppercase tracking-widest" style="color:var(--danger)">High Consumption Devices</p>
        </div>

        <!-- Alert rows injected by JS -->
        <ul id="high-consumption-list" class="space-y-2.5">
        </ul>

      </div>
    </div>

    <!-- Energy Saving Opportunities -->
    <div id="energy-saving-section" style="display:none;">
      <div class="rounded-xl border border-border bg-card p-4 space-y-3">

        <!-- Header -->
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
            <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-2.26A7 7 0 0 1 12 2Zm-1 16h2v1a1 1 0 1 1-2 0v-1Zm-3-1h8v-1H8v1Z"/>
          </svg>
          <p class="text-sm font-mono uppercase tracking-widest text-text-muted">Energy Saving Opportunities</p>
        </div>

        <!-- Top consumer label -->
        <div class="flex items-center justify-between">
          <span class="text-xs text-text-muted">Top Consumer</span>
          <span id="saving-top-consumer" class="text-xs font-semibold text-text-primary">—</span>
        </div>

        <!-- Potential savings chip -->
        <div class="flex items-center justify-between rounded-lg px-3 py-2.5" style="background: color-mix(in srgb, #3ecf6e, transparent 88%); border: 1px solid color-mix(in srgb, #3ecf6e, transparent 65%);">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 flex-shrink-0" style="color:#3ecf6e" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Zm.53 5.47a.75.75 0 0 0-1.06 0l-3 3a.75.75 0 1 0 1.06 1.06l1.72-1.72v5.69a.75.75 0 0 0 1.5 0v-5.69l1.72 1.72a.75.75 0 1 0 1.06-1.06l-3-3Z" clip-rule="evenodd"/>
            </svg>
            <span class="text-xs font-medium" style="color:#3ecf6e">Potential Monthly Energy Savings</span>
          </div>
          <span id="saving-potential" class="text-sm font-display font-bold tabular-nums" style="color:#3ecf6e">—</span>
        </div>

        <!-- Tips list -->
        <ul id="saving-tips-list" class="space-y-2">
          <!-- Injected by JS -->
        </ul>

      </div>
    </div>

    <!-- Empty state — shown when no appliances are active -->
    <div
      id="empty-state-prompt"
      class="rounded-xl px-5 py-5 text-center"
      style="
        background: color-mix(in srgb, var(--accent), transparent 91%);
        border: 1px solid color-mix(in srgb, var(--accent), transparent 55%);
        box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent), transparent 82%), 0 6px 24px -6px color-mix(in srgb, var(--accent), transparent 65%);
      "
    >
      <!-- Icon badge -->
      <div class="flex justify-center mb-3">
        <span
          class="flex h-10 w-10 items-center justify-center rounded-full"
          style="background: color-mix(in srgb, var(--accent), transparent 78%);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" style="color: var(--accent);" aria-hidden="true">
            <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
          </svg>
        </span>
      </div>

      <p class="text-sm font-semibold text-text-primary mb-1">Nothing selected yet</p>
      <p class="text-xs text-text-muted leading-relaxed">
        Pick a <span class="font-semibold" style="color: var(--accent);">Quick Start</span> above for an instant setup, or increase the quantity on any appliance manually.
      </p>
    </div>
    
    <!-- Energy Cost Estimator -->
    <div id="energy-cost-estimator-section" style="display:none;">
      <div class="rounded-xl border border-border bg-card p-4 space-y-4">

        <!-- Header -->
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0" style="color:var(--accent)" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 6a.75.75 0 0 0-1.5 0v.816a3.836 3.836 0 0 0-1.72.756c-.712.566-1.112 1.35-1.112 2.178 0 .829.4 1.612 1.113 2.178.502.4 1.102.647 1.719.756v2.978a2.536 2.536 0 0 1-.921-.421l-.879-.66a.75.75 0 0 0-.9 1.2l.879.66c.533.4 1.169.645 1.821.75V18a.75.75 0 0 0 1.5 0v-.81a4.124 4.124 0 0 0 1.821-.749c.745-.559 1.179-1.344 1.179-2.191 0-.847-.434-1.632-1.179-2.191a4.122 4.122 0 0 0-1.821-.75V8.354c.29.082.559.213.786.393l.415.33a.75.75 0 0 0 .933-1.175l-.415-.33a3.836 3.836 0 0 0-1.719-.755V6Z" clip-rule="evenodd"/>
          </svg>
          <p class="text-sm font-mono uppercase tracking-widest text-text-muted">Energy Cost Estimator</p>
        </div>

        <!-- Monthly kWh — pulled from calculator, shown prominently -->
        <div
          class="flex items-center justify-between rounded-lg px-3 py-3"
          style="background: color-mix(in srgb, var(--accent), transparent 92%); border: 1px solid color-mix(in srgb, var(--accent), transparent 75%);"
        >
          <div>
            <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-0.5">Your Monthly Usage</p>
            <p class="text-[10px] text-text-muted">from your appliance setup above</p>
          </div>
          <div class="text-right flex-shrink-0 ml-3">
            <span id="estimator-monthly-kwh" class="font-display font-bold text-2xl tabular-nums" style="color: var(--accent);">0</span>
            <span class="font-mono text-xs text-text-muted ml-1">kWh/mo</span>
          </div>
        </div>

        <!-- Two-column inputs -->
        <div class="grid grid-cols-2 gap-3">
          <div class="space-y-1.5 min-w-0">
            <label for="estimator-currency-select" class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Currency</label>
            <div class="relative group">
              <select
                id="estimator-currency-select"
                data-action="update-estimator"
                class="custom-select w-full appearance-none pl-3 pr-8 py-1.5 text-xs cursor-pointer transition-all duration-200 hover:border-accent focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent"
                aria-label="Currency symbol for cost estimate"
              >
                <option value="₹">₹ INR</option>
                <option value="$" selected>$ USD</option>
                <option value="€">€ EUR</option>
                <option value="£">£ GBP</option>
                <option value="AED ">AED</option>
                <option value="A$">A$ AUD</option>
                <option value="C$">C$ CAD</option>
                <option value="">Other</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-text-muted group-hover:text-accent transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
          </div>
          <div class="space-y-1.5 min-w-0">
            <label for="estimator-rate-input" class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Rate per kWh</label>
            <div class="flex items-center gap-1.5 min-w-0">
              <input
                id="estimator-rate-input"
                data-action="update-estimator"
                type="number"
                min="0.001"
                step="0.01"
                placeholder="e.g. 0.15"
                class="min-w-0 flex-1 bg-base border border-border rounded-lg px-2 py-1.5 text-xs font-mono text-center focus:border-accent focus:outline-none"
                aria-label="Electricity rate per kWh"
              />
              <span class="text-[10px] font-mono text-text-muted uppercase flex-shrink-0">/kWh</span>
            </div>
          </div>
        </div>

        <!-- Result (hidden until rate is entered) -->
        <div
          id="estimator-result-section"
          class="rounded-lg p-4 text-center"
          style="display:none; background: color-mix(in srgb, var(--accent), transparent 92%); border: 1px solid color-mix(in srgb, var(--accent), transparent 75%);"
        >
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-2">Estimated Monthly Energy Cost</p>
          <p id="estimator-monthly-cost" class="font-display font-bold text-3xl tabular-nums" style="color: var(--accent);">—</p>
        </div>

        <!-- Disclaimer -->
        <p class="text-[10px] text-text-muted leading-relaxed opacity-75">
          Actual bills vary due to taxes, fixed charges, slab pricing, and regional tariffs.
        </p>

      </div>
    </div>

    <!-- Divider -->
    <hr class="border-border" />

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row lg:flex-row gap-3">
      <button
        id="download-report-btn"
        data-action="download-report"
        type="button"
        class="flex-1 flex items-center justify-center gap-2 px-3 py-3 rounded-lg bg-accent text-accent-text text-lg font-display font-medium hover:bg-accent-dim transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-accent shadow-lg shadow-accent/20 active:scale-95"
        aria-label="View load report"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
          <path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
          <path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.186A10.004 10.004 0 0 1 10 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0 1 10 17c-4.257 0-7.893-2.66-9.336-7.41ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd" />
        </svg>
        Report
      </button>
    </div>

  </div>
</aside>

