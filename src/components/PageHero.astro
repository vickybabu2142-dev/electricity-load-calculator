---
// No props needed
---

<header class="relative pt-8 pb-6 px-6 text-center overflow-hidden no-print">
  <p class="font-mono text-[10px] tracking-[0.25em] text-text-muted uppercase mb-2 animate-fade-in">
    ⚡ Electrical Load Calculator
  </p>

  <h1
    class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl text-text-primary leading-none tracking-tight mb-3 animate-slide-up"
    style="animation-delay: 0.05s"
  >
    Home Load
    <span class="inline-block sm:block text-accent-dim">Calculator</span>
  </h1>

  <p
    class="max-w-xl mx-auto text-text-muted text-sm leading-relaxed animate-slide-up"
    style="animation-delay: 0.12s"
  >
    Add your appliances and instantly see your home's total electrical load,
    daily energy consumption, and estimated monthly electricity bill.
  </p>

  <!-- Stats strip -->
  <div
    class="mt-4 inline-flex flex-wrap justify-center gap-6 text-xs animate-slide-up"
    style="animation-delay: 0.2s"
  >
    {[
      { label: '26 Appliances', icon: '🔌' },
      { label: '5 Categories',  icon: '📂' },
      { label: 'Real-time Calc',icon: '⚡' },
    ].map(s => (
      <span class="flex items-center gap-1.5 text-text-muted">
        <span>{s.icon}</span>
        <span>{s.label}</span>
      </span>
    ))}
  </div>
</header>
