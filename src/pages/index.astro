---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import ApplianceCategory from '@/components/ApplianceCategory.astro';
import ResultsPanel from '@/components/ResultsPanel.astro';
import ReportModal from '@/components/ReportModal.astro';
import FAQSection from '@/components/FAQSection.astro';
import { DEFAULT_APPLIANCES, CATEGORIES, SECTIONS } from '@/data/appliances';
import type { ApplianceCategory as CategoryType } from '@/types';

// Group appliances by sections and categories for SSR rendering
const sectionedData = SECTIONS.map(section => ({
  title: section.title,
  groups: section.categories.map(cat => ({
    name: cat as CategoryType,
    appliances: DEFAULT_APPLIANCES.filter(a => a.category === cat && !a.hidden),
  }))
}));
---

<BaseLayout>
  <PageHero />

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pb-24 print:hidden animate-slide-up">

    <!-- QUICK START PRESETS -->
    <div class="mb-6 print:hidden">
      <div class="flex items-center gap-3 mb-3">
        <p class="text-sm font-semibold uppercase tracking-widest text-text-primary flex-shrink-0">Quick Start</p>
        <div class="flex-1 h-px bg-border"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 sm:gap-3">

        <!-- Typical 2BHK -->
        <button type="button" data-action="load-preset" data-preset-id="typical-2bhk"
          class="preset-card text-left px-4 py-3 rounded-xl border border-border bg-card hover:border-accent/40 hover:bg-card-hover transition-[border-color,background-color,box-shadow,transform] duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent group active:scale-[0.98]">
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2.5">
              <span class="text-accent flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </span>
              <span class="text-base font-semibold text-text-primary group-hover:text-accent transition-colors">Typical 2BHK</span>
            </div>
            <span class="flex-shrink-0 text-xs font-mono px-2 py-1 rounded-full border border-border text-text-primary tabular-nums font-semibold">~5 kW</span>
          </div>
          <p class="hidden sm:block text-xs text-text-muted mt-2 leading-relaxed">Standard home — AC, fridge, TV &amp; kitchen</p>
        </button>

        <!-- Budget Home -->
        <button type="button" data-action="load-preset" data-preset-id="budget-home"
          class="preset-card text-left px-4 py-3 rounded-xl border border-border bg-card hover:border-accent/40 hover:bg-card-hover transition-[border-color,background-color,box-shadow,transform] duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent group active:scale-[0.98]">
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2.5">
              <span class="text-accent flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M12 22V12"/><path d="m5 12 7-10 7 10"/><path d="M19 15v5a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-5"/></svg>
              </span>
              <span class="text-base font-semibold text-text-primary group-hover:text-accent transition-colors">Budget Home</span>
            </div>
            <span class="flex-shrink-0 text-xs font-mono px-2 py-1 rounded-full border border-border text-text-primary tabular-nums font-semibold">~1.3 kW</span>
          </div>
          <p class="hidden sm:block text-xs text-text-muted mt-2 leading-relaxed">Essentials only — fans, fridge, TV &amp; laptop</p>
        </button>

        <!-- Summer Heavy -->
        <button type="button" data-action="load-preset" data-preset-id="summer-heavy"
          class="preset-card text-left px-4 py-3 rounded-xl border border-border bg-card hover:border-accent/40 hover:bg-card-hover transition-[border-color,background-color,box-shadow,transform] duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent group active:scale-[0.98]">
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2.5">
              <span class="text-accent flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
              </span>
              <span class="text-base font-semibold text-text-primary group-hover:text-accent transition-colors">Summer Heavy</span>
            </div>
            <span class="flex-shrink-0 text-xs font-mono px-2 py-1 rounded-full border border-border text-text-primary tabular-nums font-semibold">~10 kW</span>
          </div>
          <p class="hidden sm:block text-xs text-text-muted mt-2 leading-relaxed">Peak season — dual AC, full kitchen &amp; more</p>
        </button>

      </div>

    </div>

    <div class="flex flex-col lg:flex-row gap-6 items-start">

      <!-- Left: appliance categories -->
      <div class="flex-1 w-full min-w-0">
        <div class="space-y-10">
          {sectionedData.map((section) => (
          <div class="space-y-4">
            <div class="flex items-center justify-between border-l-4 border-accent pl-3">
              <h2 class="text-xl font-display font-bold text-text-primary uppercase tracking-wider flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-accent"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                {section.title}
              </h2>
              <button
                type="button"
                data-action="reset-all"
                class="hidden lg:flex items-center gap-2 px-3 py-1 rounded-lg border border-danger/20 text-danger bg-danger/5 text-lg font-display font-medium hover:bg-danger/10 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-danger active:scale-95"
                aria-label="Reset all appliances"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0V5.36l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219Z" clip-rule="evenodd"/>
                </svg>
                Reset All
              </button>
            </div>
            <div class="space-y-4">
              {section.groups.map((group, i) => (
                <ApplianceCategory
                  name={group.name}
                  appliances={group.appliances}
                  index={i}
                />
              ))}
            </div>
          </div>
        ))}
        </div>
      </div>

      <!-- Right: results panel -->
      <div class="w-full lg:w-80 xl:w-96 flex-shrink-0 z-10">
        <ResultsPanel />
      </div>

    </div>
  </main>

  <!-- MOBILE STICKY SUMMARY -->
  <div id="mobile-sticky-bar" class="fixed bottom-0 left-0 right-0 bg-card/95 backdrop-blur-md border-t border-border p-3 z-40 lg:hidden print:hidden no-print shadow-[0_-15px_30px_-15px_rgba(0,0,0,0.5)] flex justify-between items-center gap-4 pb-[max(0.75rem,env(safe-area-inset-bottom))] animate-slide-up-sticky">
    
    <!-- Reset button -->
    <button
      id="sticky-reset-btn"
      data-action="reset-all"
      type="button"
      class="flex items-center justify-center gap-2 px-3 h-10 rounded-lg border border-danger/20 text-danger bg-danger/5 hover:bg-danger/10 transition-all duration-300 focus:outline-none focus:ring-1 focus:ring-danger flex-shrink-0"
      aria-label="Reset all appliances"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 opacity-80">
        <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0V5.36l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219Z" clip-rule="evenodd"/>
      </svg>
      <span class="text-sm font-medium">Reset</span>
    </button>

    <!-- Center Summary -->
    <div class="flex flex-col items-center text-center flex-1 min-w-0">

      <!-- Numbers: shown when at least one appliance is active -->
      <div id="sticky-summary">
        <div class="flex items-baseline justify-center gap-1">
          <span id="sticky-total-kw" class="font-display font-bold text-2xl tabular-nums leading-none truncate" style="color: var(--accent);">0.00</span>
          <span class="font-mono text-xs text-text-muted">kW</span>
        </div>
        <div class="text-[10px] text-text-primary font-medium truncate w-full opacity-90">
          Monthly: <span id="sticky-monthly-kwh" class="font-semibold tabular-nums" style="color: var(--accent);">0</span> kWh
        </div>
      </div>

      <!-- Hint: shown when nothing is active yet -->
      <div id="sticky-empty-hint" class="flex flex-col items-center gap-0.5" style="display: none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
          class="w-3 h-3 animate-bounce mb-0.5" style="color: var(--accent);" aria-hidden="true">
          <path d="M12 19V5M5 12l7-7 7 7"/>
        </svg>
        <p class="text-xs font-medium text-text-primary">
          Pick a <span class="font-semibold" style="color: var(--accent);">Quick Start</span> or tap <span class="font-semibold" style="color: var(--accent);">+</span>
        </p>
        <p class="text-[10px] text-text-muted">to see your load &amp; bill</p>
      </div>

    </div>

    <!-- Details View -->
    <a
      href="#results-panel"
      id="sticky-details-link"
      class="flex items-center justify-center gap-2 px-4 h-10 rounded-lg bg-accent text-accent-text hover:bg-accent-dim transition-all duration-300 focus:outline-none focus:ring-1 focus:ring-accent shadow-lg shadow-accent/20 active:scale-95 flex-shrink-0"
      aria-label="View Detailed Report"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
        <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
        <circle cx="12" cy="12" r="3" />
      </svg>
      <span class="text-sm font-medium">Details</span>
    </a>
  </div>
  </div>

  <!-- PRINT ONLY LAYOUT -->
  <div id="print-layout" class="hidden print:block w-full max-w-4xl mx-auto text-text-primary bg-white print:bg-white" style="padding: 0; box-sizing: border-box; background-color: white !important;">

    <!-- ── PAGE 1: Executive Summary ──────────────────────── -->
    <div class="print-page">
      <!-- Report header -->
      <div class="border-b-2 border-border pb-5 mb-8 flex justify-between items-end">
        <div>
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Electrical Assessment Report</p>
          <h1 class="text-2xl font-display font-bold text-text-primary">
            Electricity Load <span class="text-accent">Report</span>
          </h1>
          <p class="text-sm text-text-muted mt-1.5" id="print-date"></p>
        </div>
        <div class="text-right select-none">
          <p class="print-brand-url text-sm font-bold font-mono text-accent tracking-wide"></p>
          <p class="text-[10px] text-text-muted mt-1">&copy; {new Date().getFullYear()} · All Rights Reserved</p>
          <p class="text-[9px] text-text-muted mt-0.5 uppercase tracking-widest">Proprietary Report</p>
        </div>
      </div>

      <!-- Executive Summary: 3-column stats -->
      <div class="grid grid-cols-3 gap-4 mb-8">
        <div class="bg-card p-5 rounded-xl border border-border break-inside-avoid">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3">Total Electrical Load</p>
          <p class="text-4xl font-bold font-display" style="color: var(--accent);"><span id="print-total-kw">0.00</span> kW</p>
          <p class="text-xs text-text-muted mt-2"><span id="print-total-watts">0</span> W</p>
        </div>
        <div class="bg-card p-5 rounded-xl border border-border break-inside-avoid">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3">Daily Consumption</p>
          <p class="text-4xl font-bold font-display text-text-primary"><span id="print-daily-kwh">0.00</span></p>
          <p class="text-xs text-text-muted mt-2">kWh (units) per day</p>
        </div>
        <div class="bg-card p-5 rounded-xl border border-border break-inside-avoid">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3">Monthly Consumption</p>
          <p class="text-4xl font-bold font-display text-text-primary"><span id="print-monthly-kwh">0</span></p>
          <p class="text-xs text-text-muted mt-2">kWh (units) per month</p>
        </div>
      </div>

      <!-- Electrical Health Score -->
      <div class="break-inside-avoid">
        <h2 class="text-[10px] font-bold uppercase tracking-wider text-text-muted mb-3">Electrical Health Score</h2>
        <div class="bg-card p-6 rounded-xl border border-border">
          <div class="flex items-center gap-8 mb-5">
            <div class="flex items-end gap-2">
              <span id="print-health-score" class="text-6xl font-bold font-display" style="color: var(--accent);">—</span>
              <span class="text-xl text-text-muted mb-2">/ 100</span>
            </div>
            <div>
              <span id="print-health-label" class="text-2xl font-semibold text-text-primary">—</span>
              <p class="text-xs text-text-muted mt-1">Composite electrical system assessment</p>
            </div>
          </div>
          <div id="print-health-details" class="space-y-2">
            <!-- Populated by JS -->
          </div>
        </div>
      </div>

      <!-- Optional Energy Cost Estimate (only shown if user entered a rate) -->
      <div id="print-cost-estimator" class="mt-6 bg-card p-5 rounded-xl border border-border break-inside-avoid" style="display:none;">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-4">Energy Cost Estimator</p>

        <!-- Three key numbers -->
        <div class="grid grid-cols-3 gap-4 mb-4">
          <div>
            <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Monthly Usage</p>
            <p class="text-2xl font-bold font-display" style="color: var(--accent);"><span id="print-cost-monthly-kwh">0</span></p>
            <p class="text-xs text-text-muted mt-0.5">kWh / month</p>
          </div>
          <div>
            <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Rate per kWh</p>
            <p id="print-cost-rate" class="text-2xl font-bold font-display text-text-primary">—</p>
          </div>
          <div>
            <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Est. Monthly Cost</p>
            <p id="print-estimated-cost" class="text-2xl font-bold font-display" style="color: var(--accent);">—</p>
          </div>
        </div>

        <!-- Daily and yearly breakdown -->
        <div class="flex gap-8 pt-3 mb-4 border-t border-border">
          <div>
            <p class="text-[10px] font-mono text-text-muted uppercase tracking-widest">Daily Cost</p>
            <p id="print-cost-daily" class="text-sm font-semibold font-mono text-text-primary mt-0.5">—</p>
          </div>
          <div>
            <p class="text-[10px] font-mono text-text-muted uppercase tracking-widest">Yearly Estimate</p>
            <p id="print-cost-yearly" class="text-sm font-semibold font-mono text-text-primary mt-0.5">—</p>
          </div>
        </div>

        <p class="text-xs text-text-muted">Based on user-provided electricity rate. Actual bills may vary due to taxes, fixed charges, slab pricing, and regional tariffs.</p>
      </div>

    </div>

    <!-- ── Section 2: Smart Insights ─────────────────────────── -->
    <div class="print-page" style="page-break-before: always; break-before: page;">
      <!-- Section brand strip -->
      <div class="flex justify-between items-center pb-3 mb-6 border-b border-border select-none">
        <span class="text-[9px] font-mono uppercase tracking-widest text-text-muted">Electrical Assessment Report &nbsp;·&nbsp; Proprietary</span>
        <span class="print-brand-url text-[9px] font-mono font-semibold text-accent"></span>
      </div>
      <!-- Section header -->
      <div class="border-b border-border pb-2 mb-5">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Smart Insights</p>
        <h2 class="text-base font-display font-bold text-text-primary">Electrical System Recommendations</h2>
      </div>

      <!-- Insights 2×2 grid -->
      <div class="grid grid-cols-2 gap-5 mb-7 break-inside-avoid">
        <div class="bg-card p-5 rounded-xl border border-border">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">⚡ Recommended MCB</p>
          <p class="text-xl font-bold text-accent mt-2 mb-1" id="print-mcb-value">—</p>
          <p class="text-xs text-text-muted leading-relaxed">Miniature Circuit Breaker rating for safe protection of your total load</p>
        </div>
        <div class="bg-card p-5 rounded-xl border border-border">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">🔌 Recommended Cable</p>
          <p class="text-xl font-bold text-accent mt-2 mb-1" id="print-cable-value">—</p>
          <p class="text-xs text-text-muted leading-relaxed">Wire gauge suitable for safe and efficient power delivery</p>
        </div>
        <div class="bg-card p-5 rounded-xl border border-border">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">🔋 Recommended Inverter</p>
          <p class="text-xl font-bold text-accent mt-2 mb-1" id="print-inverter-value">—</p>
          <p class="text-xs text-text-muted leading-relaxed">Minimum inverter capacity needed for reliable backup power</p>
        </div>
        <div class="bg-card p-5 rounded-xl border border-border">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">☀️ Recommended Solar</p>
          <p class="text-xl font-bold text-accent mt-2 mb-1" id="print-solar-value">—</p>
          <p class="text-xs text-text-muted leading-relaxed">Solar panel capacity to meaningfully offset your consumption</p>
        </div>
      </div>

      <!-- Disclaimer -->
      <div class="bg-card border border-border rounded-xl p-5 break-inside-avoid">
        <p class="text-[10px] font-bold uppercase tracking-widest text-text-muted mb-2">Important Notice</p>
        <p class="text-xs text-text-muted leading-relaxed">These recommendations are estimates based on your declared appliance loads. Always consult a licensed electrician before making wiring changes or purchasing equipment. Local regulations and building codes take precedence over these figures.</p>
      </div>

    </div>

    <!-- ── Section 3: Consumption Breakdown ──────────────────── -->
    <div class="print-page" style="page-break-before: always; break-before: page;">
      <!-- Section brand strip -->
      <div class="flex justify-between items-center pb-3 mb-6 border-b border-border select-none">
        <span class="text-[9px] font-mono uppercase tracking-widest text-text-muted">Electrical Assessment Report &nbsp;·&nbsp; Proprietary</span>
        <span class="print-brand-url text-[9px] font-mono font-semibold text-accent"></span>
      </div>
      <!-- Section header -->
      <div class="border-b border-border pb-2 mb-5">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Energy Analysis</p>
        <h2 class="text-base font-display font-bold text-text-primary">Consumption Breakdown by Category</h2>
      </div>

      <!-- Breakdown table with column headers -->
      <div class="break-inside-avoid mb-8">
        <div class="flex text-[10px] font-bold uppercase tracking-widest py-2 mb-0.5 border-b-2 border-border">
          <span class="flex-1 text-text-primary">Category</span>
          <span class="w-32 text-right text-text-primary">kWh / day</span>
          <span class="w-20 text-right text-text-primary">Share</span>
        </div>
        <div id="print-breakdown-table" class="space-y-0">
          <!-- Populated by JS -->
        </div>
      </div>

      <!-- Active Appliances -->
      <h2 class="text-[10px] font-bold uppercase tracking-wider text-text-muted mb-4 border-b border-border pb-2">Active Appliances Breakdown</h2>
      <div id="print-appliances-list" class="space-y-5">
        <!-- Populated by JS -->
      </div>

      <!-- Daily total row -->
      <div id="print-appliances-total" class="mt-4 pt-3 border-t-2 border-border break-inside-avoid">
        <!-- Populated by JS -->
      </div>

    </div>

    <!-- ── Section 4: Energy Saving + High Consumption ──────── -->
    <div class="print-page" style="page-break-before: always; break-before: page;">
      <!-- Section brand strip -->
      <div class="flex justify-between items-center pb-3 mb-6 border-b border-border select-none">
        <span class="text-[9px] font-mono uppercase tracking-widest text-text-muted">Electrical Assessment Report &nbsp;·&nbsp; Proprietary</span>
        <span class="print-brand-url text-[9px] font-mono font-semibold text-accent"></span>
      </div>
      <!-- Section header -->
      <div class="border-b border-border pb-2 mb-5">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-1">Action Plan</p>
        <h2 class="text-base font-display font-bold text-text-primary">Energy Saving Opportunities</h2>
      </div>

      <!-- Energy Saving Tips -->
      <div class="break-inside-avoid mb-8">
        <div id="print-saving-tips" class="space-y-1.5">
          <!-- Populated by JS -->
        </div>
      </div>

      <!-- High Consumption Devices -->
