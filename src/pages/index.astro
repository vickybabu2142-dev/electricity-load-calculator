<script>
// ─────────────────────────────────────────────────────────
// ELECTRICITY LOAD CALCULATOR — CLIENT-SIDE LOGIC
// ─────────────────────────────────────────────────────────

import { DEFAULT_APPLIANCES, CATEGORIES, SECTIONS } from '@/data/appliances';
import type { Appliance, ApplianceCategory } from '@/types';
import { calculateRowKWh, calculateTotals } from '@/utils/calculations';
import { calculateInsights } from '@/utils/insights';
import { calculateHealthScore, calculateCategoryBreakdown, generateSavingsTips, getHighConsumptionAlerts } from '@/utils/health';

// ── State & Settings ──────────────────────────────────────
const STORAGE_KEY = 'electricity_load_calculator_state';

const REGION_SETTINGS: Record<string, { locale: string, symbol: string, defaultTariff: number, step: number, defaultMaxKW: number }> = {
  INR: { locale: 'en-IN', symbol: '₹', defaultTariff: 8,    step: 0.5,  defaultMaxKW: 5  },
  USD: { locale: 'en-US', symbol: '$', defaultTariff: 0.15, step: 0.01, defaultMaxKW: 20 },
  EUR: { locale: 'de-DE', symbol: '€', defaultTariff: 0.35, step: 0.01, defaultMaxKW: 15 },
  GBP: { locale: 'en-GB', symbol: '£', defaultTariff: 0.28, step: 0.01, defaultMaxKW: 15 },
  CAD: { locale: 'en-CA', symbol: '$', defaultTariff: 0.14, step: 0.01, defaultMaxKW: 20 },
  AUD: { locale: 'en-AU', symbol: '$', defaultTariff: 0.30, step: 0.01, defaultMaxKW: 20 },
};

let appliances: Appliance[] = structuredClone(DEFAULT_APPLIANCES).filter(a => !a.hidden);
let tariff = 0;
let currentCurrency = 'INR';
let maxCapacityKW = 5;
let customIdCounter = 1000;
let activePresetId: string | null = null;

const PRESETS: Record<string, Record<string, number>> = {
  'typical-2bhk': {
    'LED Bulb': 4, 'Tube Light': 2,
    'Ceiling Fan': 3, 'Air Conditioner (1.5T)': 1,
    'Refrigerator': 1, 'Microwave Oven': 1, 'Mixer / Grinder': 1, 'Water Purifier (RO)': 1,
    'LED TV (32")': 1, 'Set-top Box': 1, 'Wi-Fi Router': 1,
    'Washing Machine': 1, 'Laptop / Charger': 1, 'Water Pump (0.5 HP)': 1,
  },
  'budget-home': {
    'LED Bulb': 3, 'Tube Light': 1,
    'Ceiling Fan': 2, 'Table Fan': 1,
    'Refrigerator': 1, 'Mixer / Grinder': 1,
    'LED TV (32")': 1, 'Wi-Fi Router': 1, 'Laptop / Charger': 1,
  },
  'summer-heavy': {
    'LED Bulb': 6, 'Spotlight / Downlight': 2,
    'Ceiling Fan': 3, 'Air Conditioner (1.5T)': 2, 'Air Cooler': 1, 'Exhaust Fan': 2,
    'Refrigerator': 1, 'Microwave Oven': 1, 'Water Purifier (RO)': 1, 'Induction Cooktop': 1,
    'LED TV (55")': 1, 'Wi-Fi Router': 1,
    'Washing Machine': 1, 'Laptop / Charger': 2, 'Geyser / Water Heater': 1, 'Water Pump (0.5 HP)': 1,
  },
};

// ── Helpers ───────────────────────────────────────────────
function saveState() {
  const state = {
    appliances,
    tariff,
    currentCurrency,
    maxCapacityKW,
    customIdCounter
  };
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  } catch {
    // QuotaExceededError or SecurityError in private browsing — ignore silently
  }
}

function loadState(): boolean {
  const saved = localStorage.getItem(STORAGE_KEY);
  if (!saved) return false;
  try {
    const state = JSON.parse(saved);
    if (!Array.isArray(state.appliances) || state.appliances.length === 0) return false;
    appliances = state.appliances;
    if (typeof state.tariff === 'number' && state.tariff > 0) tariff = state.tariff;
    if (typeof state.currentCurrency === 'string' && REGION_SETTINGS[state.currentCurrency]) currentCurrency = state.currentCurrency;
    if (typeof state.maxCapacityKW === 'number' && state.maxCapacityKW > 0) maxCapacityKW = state.maxCapacityKW;
    if (typeof state.customIdCounter === 'number') customIdCounter = state.customIdCounter;
    return true;
  } catch (e) {
    appliances = structuredClone(DEFAULT_APPLIANCES).filter(a => !a.hidden);
    localStorage.removeItem(STORAGE_KEY);
    return false;
  }
}

function getAppliance(id: string): Appliance | undefined {
  return appliances.find(a => a.id === id);
}

function formatCurrency(amount: number): string {
  const { locale, symbol } = REGION_SETTINGS[currentCurrency];
  const decimals = currentCurrency === 'INR' ? 0 : 2;
  
  return new Intl.NumberFormat(locale, {
    style: 'currency',
    currency: currentCurrency,
    maximumFractionDigits: decimals,
    minimumFractionDigits: decimals,
  }).format(amount);
}

function formatNumber(val: number, decimals = 0): string {
  return new Intl.NumberFormat(navigator.language || 'en', {
    minimumFractionDigits: decimals,
    maximumFractionDigits: decimals,
  }).format(val);
}

function animateCounter(id: string, target: number, decimals: number) {
  const el = document.getElementById(id);
  if (!el) return;
  const startText = el.textContent?.replace(/[^0-9.]/g, '') || '0';
  const start = parseFloat(startText) || 0;
  const duration = 350;
  const startTime = performance.now();

  function step(now: number) {
    const progress = Math.min((now - startTime) / duration, 1);
    const ease = 1 - Math.pow(1 - progress, 3);
    const value = start + (target - start) * ease;
    el.textContent = formatNumber(value, decimals);
    if (progress < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

function setText(id: string, value: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = value;
}


function updateRowKWh(a: Appliance) {
  const kwhEl = document.querySelector(`[data-kwh-display="${a.id}"]`);
  if (kwhEl) kwhEl.textContent = formatNumber(calculateRowKWh(a), 2);
}

function updateRowQtyDisplay(a: Appliance) {
  const el = document.querySelector(`[data-qty-display="${a.id}"]`);
  if (el) el.textContent = String(a.qty);
}

function updateRowNameStyle(a: Appliance) {
  const row = document.querySelector<HTMLElement>(`[data-id="${a.id}"]`);
  if (!row) return;
  const nameEl = row.querySelector<HTMLElement>('.flex-1 span');
  if (nameEl) nameEl.style.color = a.qty > 0 ? 'var(--text-primary)' : 'var(--text-muted)';
}

// ── Calculation ───────────────────────────────────────────
function calculate() {
  const result = calculateTotals(appliances, tariff, maxCapacityKW);

  animateCounter('total-kw', result.totalKW, 2);
  animateCounter('sticky-total-kw', result.totalKW, 2);
  animateCounter('total-watts', result.totalWatts, 0);
  animateCounter('daily-kwh', result.dailyKWh, 2);
  animateCounter('monthly-kwh', result.monthlyKWh, 0);
  setText('sticky-monthly-kwh', String(Math.round(result.monthlyKWh)));

  setText('top-consumer-name', result.topConsumerName);
  setText('top-consumer-watts', formatNumber(result.topConsumerWatts));
  setText('load-percent', `${Math.round(result.loadPercent)}%`);
  setText('max-kw-label', `${maxCapacityKW} kW max`);

  const bar = document.getElementById('load-bar');
  if (bar) {
    bar.style.width = `max(4px, ${Math.min(result.loadPercent, 100)}%)`;
  }
  const progress = document.getElementById('load-progress');
  if (progress) progress.setAttribute('aria-valuenow', String(Math.round(result.loadPercent)));

  const badge = document.getElementById('load-level-badge');
  if (badge) {
    badge.style.boxShadow = 'none';
    if (result.loadPercent < 30) {
      badge.textContent = 'Light Load';
      badge.style.borderColor = 'var(--success)';
      badge.style.color = 'var(--success)';
    } else if (result.loadPercent < 70) {
      badge.textContent = 'Moderate Load';
      badge.style.borderColor = 'var(--warning)';
      badge.style.color = 'var(--warning)';
    } else {
      badge.textContent = 'Heavy Load';
      badge.style.borderColor = 'transparent';
      badge.style.color = 'var(--danger)';
      badge.style.boxShadow = 'var(--danger-glow)';
    }
  }

  const activeCount = appliances.filter(a => a.qty > 0).length;
  const totalCount  = appliances.filter(a => !a.hidden).length;
  setText('active-count', String(activeCount));
  setText('total-count',  String(totalCount));
  setText('hero-total-count', String(totalCount));

  const emptyPrompt = document.getElementById('empty-state-prompt');
  if (emptyPrompt) emptyPrompt.style.display = activeCount === 0 ? '' : 'none';

  const stickySummary = document.getElementById('sticky-summary');
  const stickyHint = document.getElementById('sticky-empty-hint');
  if (stickySummary) stickySummary.style.display = activeCount === 0 ? 'none' : '';
  if (stickyHint) stickyHint.style.display = activeCount === 0 ? 'flex' : 'none';


  CATEGORIES.forEach(cat => {
    const catAppliances = appliances.filter(a => a.category === cat);
    const activeCatAppliances = catAppliances.filter(a => a.qty > 0);
    const catWatts = activeCatAppliances.reduce((s, a) => s + a.watts * a.qty, 0);
    const catKWh   = activeCatAppliances.reduce((s, a) => s + calculateRowKWh(a), 0);
    
    const activeCount = activeCatAppliances.length;
    const totalCount  = catAppliances.length;

    // Use slugified ID to find the category body, then get the section parent
    const bodyId = `category-body-${cat.replace(/\s/g, '-')}`;
    const body = document.getElementById(bodyId);
    const section = body?.closest('.category-section');

    const wattEl = section?.querySelector('[data-category-watts]');
    const kwhEl  = section?.querySelector('[data-category-kwh]');
    const cntEl  = section?.querySelector('[data-category-count]');

    const wattTextEl = wattEl?.querySelector('span:last-child');
    const kwhTextEl  = kwhEl?.querySelector('span:last-child');
    if (wattTextEl) wattTextEl.textContent = `${catWatts.toLocaleString()} W`;
    if (kwhTextEl)  kwhTextEl.textContent  = `${catKWh.toFixed(2)} kWh(unit)/d`;
    if (cntEl)  cntEl.textContent  = `${activeCount}/${totalCount}`;
  });

  setText('print-total-kw', (result.totalWatts / 1000).toFixed(2));
  setText('print-total-watts', formatNumber(result.totalWatts));
  setText('print-daily-kwh', formatNumber(result.dailyKWh, 2));
  setText('print-monthly-kwh', String(Math.round(result.monthlyKWh)));
  setText('print-date', `Generated on: ${new Date().toLocaleDateString(navigator.language || 'en', { dateStyle: 'long' })}`);

  const siteUrl = window.location.origin;
  document.querySelectorAll<HTMLElement>('.print-brand-url').forEach(el => {
    el.innerHTML = ''; // Clear to prevent duplication
    const a = document.createElement('a');
    a.href = siteUrl;
    a.textContent = siteUrl;
    a.style.cssText = 'color:inherit;text-decoration:underline;text-underline-offset:2px;';
    el.appendChild(a);
  });

  const printList = document.getElementById('print-appliances-list');
  if (printList) {
    let html = '';
    const included = appliances.filter(a => a.qty > 0);
    SECTIONS.forEach(section => {
      const sectionItems = included.filter(a => section.categories.includes(a.category));
      if (sectionItems.length > 0) {
        html += `<div class="mb-6"><h2 class="text-sm font-bold text-accent uppercase tracking-widest mb-4 border-l-4 border-accent pl-3">${section.title}</h2><div class="space-y-4">`;
        section.categories.forEach(cat => {
          const catItems = sectionItems.filter(a => a.category === cat);
          if (catItems.length > 0) {
            html += `
              <div>
                <h3 class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-2 border-b border-border pb-1">${cat}</h3>
                <div class="space-y-1.5">
                  ${catItems.map(a => `
                    <div class="flex justify-between items-center text-sm">
                      <div class="flex-1">
                        <span class="font-medium text-text-primary">${escapeHtml(a.name)}</span>
                        <span class="text-text-muted ml-2 text-xs">${a.qty} × ${a.watts}W</span>
                      </div>
                      <div class="text-right font-mono font-medium text-text-primary">
                        ${calculateRowKWh(a).toFixed(2)} <span class="text-[10px] text-text-muted">kWh/d</span>
                      </div>
                    </div>
                  `).join('')}
                </div>
              </div>
            `;
          }
        });
        html += `</div></div>`;
      }
    });
    printList.innerHTML = html || '<p class="text-text-muted italic">No active appliances selected.</p>';

    const printTotal = document.getElementById('print-appliances-total');
    if (printTotal) {
      printTotal.innerHTML = `
        <div class="flex justify-between items-baseline">
          <span class="text-[10px] font-bold uppercase tracking-widest text-text-muted">Total Daily Consumption</span>
          <span class="font-mono font-bold text-lg" style="color:var(--accent);">${result.dailyKWh.toFixed(2)}<span class="text-xs text-text-muted font-normal ml-1">kWh / day</span></span>
        </div>
      `;
    }
  }

  // ── Smart Insights (print only) ──
  const insights = calculateInsights(result.totalKW, result.monthlyKWh);

  if (activeCount > 0) {
    setText('print-mcb-value', insights.recommendedMCB);
    setText('print-cable-value', insights.recommendedCable);
    setText('print-inverter-value', insights.recommendedInverter);
    setText('print-solar-value', insights.recommendedSolar);
  }

  // ── Electrical Health Score ────────────────────────────
  const topConsumerDailyKWh = appliances
    .filter(a => a.qty > 0)
    .reduce((best, a) => Math.max(best, calculateRowKWh(a)), 0);

  const health = calculateHealthScore({
    loadPercent: result.loadPercent,
    dailyKWh: result.dailyKWh,
    topConsumerDailyKWh,
    monthlyKWh: result.monthlyKWh,
    hasMCB: activeCount > 0,
    hasCable: activeCount > 0,
  });

  const healthCompact = document.getElementById('health-score-compact');
  if (healthCompact) healthCompact.style.display = activeCount === 0 ? 'none' : '';

  if (activeCount > 0) {
    const scoreEl = document.getElementById('health-score-value');
    if (scoreEl) scoreEl.style.color = health.color;
    animateCounter('health-score-value', health.score, 0);

    const scoreCard = document.getElementById('health-score-card');
    if (scoreCard) {
      scoreCard.style.borderColor = `color-mix(in srgb, ${health.color}, transparent 62%)`;
      scoreCard.style.background   = `color-mix(in srgb, ${health.color}, transparent 93%)`;
    }

    const iconEl = document.getElementById('health-score-icon');
    if (iconEl) (iconEl as HTMLElement).style.color = health.color;

    const labelEl = document.getElementById('health-score-label');
    if (labelEl) {
      labelEl.textContent = health.label;
      labelEl.style.color = health.color;
      labelEl.style.background   = `color-mix(in srgb, ${health.color}, transparent 85%)`;
      labelEl.style.borderColor  = `color-mix(in srgb, ${health.color}, transparent 55%)`;
    }

    // Print
    setText('print-health-score', String(health.score));
    setText('print-health-label', health.label);
    const printDetails = document.getElementById('print-health-details');
    if (printDetails) {
      printDetails.innerHTML = `
        <div class="flex justify-between text-sm border-b border-border pb-1"><span class="text-text-muted">Load Utilization</span><span class="font-mono font-semibold" style="color:var(--accent)">${health.subScores.utilization}/30</span></div>
        <div class="flex justify-between text-sm border-b border-border pb-1"><span class="text-text-muted">Energy Efficiency</span><span class="font-mono font-semibold" style="color:var(--accent)">${health.subScores.efficiency}/30</span></div>
        <div class="flex justify-between text-sm border-b border-border pb-1"><span class="text-text-muted">Safety Readiness</span><span class="font-mono font-semibold" style="color:var(--accent)">${health.subScores.safety}/20</span></div>
        <div class="flex justify-between text-sm"><span class="text-text-muted">Renewable Readiness</span><span class="font-mono font-semibold" style="color:var(--accent)">${health.subScores.renewable}/20</span></div>
      `;
    }
  }

  // ── Consumption Breakdown (print only — sidebar chart removed) ──
  const breakdown = calculateCategoryBreakdown(appliances);

  if (activeCount > 0 && result.dailyKWh > 0) {
    const printBreakdown = document.getElementById('print-breakdown-table');
    if (printBreakdown) {
      printBreakdown.innerHTML = breakdown.items.map(item => `
        <div class="flex text-sm py-1.5 border-b border-border">
          <span class="flex-1 text-text-muted">${item.category}</span>
          <span class="w-32 text-right font-mono">${item.kWhDay.toFixed(2)} kWh/d</span>
          <span class="w-20 text-right font-mono font-semibold" style="color:var(--accent)">${Math.round(item.percent)}%</span>
        </div>
      `).join('');
    }
  }

  // ── Energy Saving Opportunities (print only — sidebar section removed) ──
  const savings = generateSavingsTips(appliances, result.monthlyKWh);

  if (activeCount > 0) {
    const printSaving = document.getElementById('print-saving-tips');
    if (printSaving) {
      printSaving.innerHTML = `
        <div class="flex justify-between mb-2">
          <span class="text-sm text-text-muted">Top Consumer</span>
          <span class="text-sm font-semibold text-text-primary">${savings.topConsumerName}</span>
        </div>
        <div class="flex justify-between mb-3 pb-3 border-b border-border">
          <span class="text-sm text-text-muted">Potential Monthly Savings</span>
          <span class="text-sm font-bold" style="color:var(--accent)">${formatCurrency(savings.potentialSavings)}</span>
        </div>
        ${savings.tips.map(tip => `<div class="flex items-start gap-2 mb-1.5"><span class="text-accent font-bold">✓</span><span class="text-sm text-text-muted">${tip}</span></div>`).join('')}
      `;
    }
  }

  // ── High Consumption Alerts (print only — sidebar section removed) ──
  const alerts = getHighConsumptionAlerts(appliances, result.dailyKWh);

  if (alerts.length > 0) {
    const printAlerts = document.getElementById('print-high-consumption');
    if (printAlerts) {
      printAlerts.innerHTML = alerts.map(alert => `
        <div class="flex justify-between text-sm py-1.5 border-b border-border">
          <div>
            <span class="font-medium text-text-primary">⚠ ${alert.name}</span>
            <span class="text-text-muted ml-2 text-xs">${alert.reason}</span>
          </div>
          <span class="font-mono font-semibold flex-shrink-0 ml-4" style="color:var(--accent)">${alert.kWhDay.toFixed(1)} kWh/d</span>
        </div>
      `).join('');
    }
  }
}


// ── Debounce ──────────────────────────────────────────────
function debounce<T extends (...args: any[]) => void>(fn: T, ms: number): T {
  let timer: any;
  return ((...args: any[]) => {
    clearTimeout(timer);
    timer = setTimeout(() => fn(...args), ms);
  }) as T;
}

const debouncedCalculate = debounce(calculate, 80);

// ── DOM Event Delegation ──────────────────────────────────
document.addEventListener('change', (e) => {
  const target = e.target as HTMLElement;
  const action = target.dataset.action;
  const id     = target.dataset.id;

  if (!action) return;

  // Appliance updates
  if (id) {
    const a = getAppliance(id);
    if (!a) return;

    if (action === 'update-watts') {
      const val = parseFloat((target as HTMLInputElement).value);
      if (!isNaN(val) && val >= 1) {
        a.watts = val;
        updateRowKWh(a);
        saveState();
        debouncedCalculate();
      }
      return;
    }

    if (action === 'update-hours') {
      const val = parseFloat((target as HTMLInputElement).value);
      const errorEl = document.querySelector(`[data-error-id="${id}"]`);
      
      if (!isNaN(val)) {
        if (val > 24) {
          target.classList.add('border-danger');
          target.classList.remove('border-border');
          errorEl?.classList.remove('hidden');
        } else {
          target.classList.remove('border-danger');
          target.classList.add('border-border');
          errorEl?.classList.add('hidden');
        }
        
        // Still update the state but cap at 24 for calculation safety
        a.hours = Math.min(24, val);
        updateRowKWh(a);
        saveState();
        debouncedCalculate();
      }
      return;
    }
  }

});

document.addEventListener('click', (e) => {
  const target = e.target as HTMLElement;

  if (target.dataset.action === 'close-modal' || target.closest('[data-action="close-modal"]')) {
    closeModal();
    return;
  }

  const btn = target.closest<HTMLElement>('[data-action]');
  if (!btn) return;

  const action = btn.dataset.action;
  const id     = btn.dataset.id;

  if (!action) return;

  if (action === 'load-preset') {
    const presetId = btn.dataset.presetId;
    if (presetId) loadPreset(presetId);
    return;
  }

  if (action === 'toggle-category') {
    const category = btn.dataset.category!;
    const bodyId   = `category-body-${category.replace(/\s/g, '-')}`;
    const body     = document.getElementById(bodyId);
    const chevron  = btn.querySelector<SVGElement>('.chevron');
    if (!body) return;
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    body.classList.toggle('is-open', !isOpen);
    if (chevron) chevron.style.transform = isOpen ? 'rotate(-90deg)' : '';
    return;
  }

  if (action === 'toggle-add-form') {
    const wrapper  = btn.closest('.add-appliance-wrapper');
    const form     = wrapper?.querySelector<HTMLFormElement>('.add-appliance-form');
    if (!form) return;
    const isHidden = form.classList.contains('hidden');
    form.classList.toggle('hidden', !isHidden);
    btn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
    return;
  }

  if (action === 'cancel-add-form') {
    const wrapper = btn.closest('.add-appliance-wrapper');
    const form = wrapper?.querySelector<HTMLFormElement>('.add-appliance-form');
    const toggleBtn = wrapper?.querySelector<HTMLButtonElement>('.add-toggle-btn');
    form?.classList.add('hidden');
    form?.reset();
    toggleBtn?.setAttribute('aria-expanded', 'false');
    return;
  }

  if ((action === 'increment-qty' || action === 'decrement-qty') && id) {
    const a = getAppliance(id);
    if (!a) return;
    if (action === 'increment-qty') a.qty = Math.min(a.qty + 1, 500);
    if (action === 'decrement-qty') a.qty = Math.max(a.qty - 1, 0);
    updateRowQtyDisplay(a);
    updateRowKWh(a);
    updateRowNameStyle(a);
    saveState();
    calculate();
    return;
  }

  if (action === 'delete-appliance' && id) {
    appliances = appliances.filter(a => a.id !== id);
    const row = document.querySelector(`[data-id="${id}"]`);
    row?.remove();
    saveState();
    calculate();
    return;
  }

  if (action === 'reset-all') {
    if (!confirm('Reset all appliances to their default values?')) return;
    
    // Clear persisted state
    localStorage.removeItem(STORAGE_KEY);
    
    // Restore default state variables
    appliances = structuredClone(DEFAULT_APPLIANCES).filter(a => !a.hidden);
    customIdCounter = 1000;
    
    // Re-render UI
    CATEGORIES.forEach(cat => {
      const bodyId = `category-body-${cat.replace(/\s/g, '-')}`;
      const body = document.getElementById(bodyId);
      const container = body?.querySelector('[data-rows-container]');
      if (!container) return;
      container.innerHTML = '';
      const catAppliances = appliances.filter(a => a.category === cat);
      catAppliances.forEach(a => {
        container.insertAdjacentHTML('beforeend', buildRowHTML(a));
      });
      
      // Collapse the category on reset
      if (body) {
        body.classList.remove('is-open');
        const section = body.closest('.category-section');
        const toggleBtn = section?.querySelector<HTMLButtonElement>('[data-action="toggle-category"]');
        const chevron = toggleBtn?.querySelector<SVGElement>('.chevron');
        if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.style.transform = 'rotate(-90deg)';
      }
    });
    
    appliances.forEach(a => updateRowNameStyle(a));
    activePresetId = null;
    updatePresetButtons();
    maxCapacityKW = REGION_SETTINGS.INR.defaultMaxKW;
    const maxKWInput = document.getElementById('max-kw-input') as HTMLInputElement;
    if (maxKWInput) maxKWInput.value = String(maxCapacityKW);
    
    expandLighting();
    calculate();

    return;
  }

  if (action === 'download-report') {
    const included = appliances.filter(a => a.qty > 0);
    const totalWatts  = included.reduce((s, a) => s + a.watts * a.qty, 0);
    const dailyKWh    = included.reduce((s, a) => s + calculateRowKWh(a), 0);
    const monthlyKWh  = dailyKWh * 30;
    const date = new Date().toLocaleDateString(navigator.language || 'en', { dateStyle: 'long' });

    let report = `ELECTRICITY LOAD CALCULATOR REPORT\n`;
    report += `Generated: ${date}\n`;
    report += `${'─'.repeat(48)}\n\n`;
    report += `SUMMARY\n`;
    report += `  Total Load          : ${formatNumber(totalWatts)} W (${(totalWatts / 1000).toFixed(2)} kW)\n`;
    report += `  Daily Consumption   : ${formatNumber(dailyKWh, 2)} kWh(unit)/day\n`;
    report += `  Monthly Estimate    : ${formatNumber(monthlyKWh)} kWh(unit)/month\n`;
    report += `  Max Load Capacity   : ${maxCapacityKW} kW\n\n`;
    report += `${'─'.repeat(48)}\n\n`;
    const reportInsights = calculateInsights(totalWatts / 1000, monthlyKWh);
    report += `SMART INSIGHTS\n`;
    report += `  Recommended MCB         : ${reportInsights.recommendedMCB}\n`;
    report += `  Recommended Cable       : ${reportInsights.recommendedCable}\n`;
    report += `  Recommended Inverter    : ${reportInsights.recommendedInverter}\n`;
    report += `  Recommended Solar       : ${reportInsights.recommendedSolar}\n\n`;
    report += `${'─'.repeat(48)}\n\n`;
    report += `APPLIANCE BREAKDOWN\n\n`;
    SECTIONS.forEach(section => {
      const sectionItems = included.filter(a => section.categories.includes(a.category));
      if (!sectionItems.length) return;
      report += `[ ${section.title.toUpperCase()} ]\n`;
      section.categories.forEach(cat => {
        const catItems = sectionItems.filter(a => a.category === cat);
        if (!catItems.length) return;
        report += `  ${cat.toUpperCase()}\n`;
        catItems.forEach(a => {
          report += `    ${a.name.padEnd(28)} ${String(a.qty).padStart(2)}× ${String(a.watts).padStart(5)}W  ${calculateRowKWh(a).toFixed(2)} kWh(unit)/d\n`;
        });
        report += '\n';
      });
      report += '\n';
    });

    report += `${'─'.repeat(48)}\n`;
    report += `Source: ${window.location.origin}\n`;
    report += `© ${new Date().getFullYear()} Electricity Load Calculator\n`;

    const modal   = document.getElementById('report-modal');
    const content = document.getElementById('report-content');
    if (modal && content) {
      content.textContent = report;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
    return;
  }

  if (action === 'print-report') {
    const originalTitle = document.title;
    const dateStr = new Date().toISOString().split('T')[0];
    document.title = `electricity-load-calculator-assessment-report-${dateStr}`;
    window.print();
    document.title = originalTitle;
    return;
  }

  if (action === 'download-txt') {
    const content = document.getElementById('report-content')?.textContent || '';
    if (!content) return;
    const blob = new Blob([content], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `electricity-load-report-${new Date().toISOString().split('T')[0]}.txt`;
    a.click();
    URL.revokeObjectURL(url);
    return;
  }
});

document.addEventListener('input', (e) => {
  const target = e.target as HTMLElement;
  const action = target.dataset.action;

  if (!action) return;

  if (action === 'update-max-kw') {
    const val = parseFloat((target as HTMLInputElement).value);
    if (!isNaN(val) && val > 0) {
      maxCapacityKW = val;
      saveState();
      calculate();
    }
  }

});

document.addEventListener('submit', (e) => {
  const form = e.target as HTMLFormElement;
  if (!form.classList.contains('add-appliance-form')) return;
  e.preventDefault();
  e.stopImmediatePropagation(); // Prevent Astro's ClientRouter from intercepting this as a navigation
  const nameInput  = form.querySelector<HTMLInputElement>('[data-field="name"]');
  const wattsInput = form.querySelector<HTMLInputElement>('[data-field="watts"]');
  const hoursInput = form.querySelector<HTMLInputElement>('[data-field="hours"]');
  const catSelect  = form.querySelector<HTMLSelectElement>('[data-field="category"]');
  const errorEl    = form.querySelector<HTMLParagraphElement>('.form-error');
  const name  = nameInput?.value.trim();
  const watts = parseFloat(wattsInput?.value || '0');
  const hours = parseFloat(hoursInput?.value || '0');
  const cat   = (catSelect?.value || 'Other') as ApplianceCategory;
  if (!name) {
    if (errorEl) { errorEl.textContent = 'Please enter an appliance name.'; errorEl.classList.remove('hidden'); }
    nameInput?.focus();
    return;
  }
  if (!watts || watts < 1) {
    if (errorEl) { errorEl.textContent = 'Watts must be at least 1.'; errorEl.classList.remove('hidden'); }
    wattsInput?.focus();
    return;
  }
  if (isNaN(hours) || hours < 0 || hours > 24) {
    if (errorEl) { errorEl.textContent = 'Hours must be between 0 and 24.'; errorEl.classList.remove('hidden'); }
    hoursInput?.focus();
    return;
  }
  errorEl?.classList.add('hidden');
  const newAppliance: Appliance = {
    id: `custom-${++customIdCounter}`,
    category: cat,
    name,
    defaultWatts: watts,
    defaultQty: 1,
    defaultHours: hours,
    watts,
    qty: 1,
    hours,
    custom: true,
  };
  appliances.push(newAppliance);
  
  // Use slugified ID to find the correct container
  const bodyId = `category-body-${cat.replace(/\s/g, '-')}`;
  const body = document.getElementById(bodyId);
  const container = body?.querySelector('[data-rows-container]');
  
  if (container) {
    const rowHtml = buildRowHTML(newAppliance);
    container.insertAdjacentHTML('beforeend', rowHtml);
    
    // Auto-expand category if hidden
    if (body && !body.classList.contains('is-open')) {
      body.classList.add('is-open');
      const section = body.closest('.category-section');
      const toggleBtn = section?.querySelector<HTMLButtonElement>('[data-action="toggle-category"]');
      const chevron = toggleBtn?.querySelector<SVGElement>('.chevron');
      toggleBtn?.setAttribute('aria-expanded', 'true');
      if (chevron) chevron.style.transform = '';
    }
  }
  
  form.reset();
  form.classList.add('hidden');
  const toggleBtn = form.closest('.add-appliance-wrapper')?.querySelector<HTMLButtonElement>('.add-toggle-btn');
  toggleBtn?.setAttribute('aria-expanded', 'false');
  saveState();
  calculate();
}, true);

function updatePresetButtons() {
  document.querySelectorAll<HTMLElement>('.preset-card').forEach(btn => {
    const isActive = btn.dataset.presetId === activePresetId;
    btn.style.borderColor = '';
    btn.style.boxShadow  = isActive ? '0 0 0 1px color-mix(in srgb, var(--accent), transparent 65%)' : '';
    btn.style.background  = isActive ? 'color-mix(in srgb, var(--accent), transparent 93%)' : '';
  });
}

function loadPreset(presetId: string) {
  const quantities = PRESETS[presetId];
  if (!quantities) return;

  // Reset all quantities then apply preset
  appliances.forEach(a => { a.qty = 0; });
  appliances.forEach(a => { if (quantities[a.name] !== undefined) a.qty = quantities[a.name]; });

  activePresetId = presetId;

  // Re-render every category and expand/collapse based on active appliances
  CATEGORIES.forEach(cat => {
    const bodyId = `category-body-${cat.replace(/\s/g, '-')}`;
    const body = document.getElementById(bodyId);
    const container = body?.querySelector('[data-rows-container]');
    if (!container) return;

    container.innerHTML = '';
    const catAppliances = appliances.filter(a => a.category === cat);
    catAppliances.forEach(a => container.insertAdjacentHTML('beforeend', buildRowHTML(a)));

    if (body) {
      const hasActive = catAppliances.some(a => a.qty > 0);
      body.classList.toggle('is-open', hasActive);
      const section = body.closest('.category-section');
      const toggleBtn = section?.querySelector<HTMLButtonElement>('[data-action="toggle-category"]');
      const chevron   = toggleBtn?.querySelector<SVGElement>('.chevron');
      if (toggleBtn) toggleBtn.setAttribute('aria-expanded', hasActive ? 'true' : 'false');
      if (chevron)   chevron.style.transform = hasActive ? '' : 'rotate(-90deg)';
    }
  });

  appliances.forEach(a => updateRowNameStyle(a));
  updatePresetButtons();
  saveState();
  calculate();
}

function escapeHtml(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

function buildRowHTML(a: Appliance): string {
  const kwh = formatNumber(calculateRowKWh(a), 2);
  const nameColor = a.qty > 0 ? 'var(--text-primary)' : 'var(--text-muted)';
  const safeName = escapeHtml(a.name);
  return `
    <div class="appliance-row group flex flex-wrap lg:flex-nowrap items-center gap-y-3 gap-x-4 px-4 py-5 hover:bg-card-hover transition-colors duration-150"
      data-id="${a.id}">

      <!-- Name & Reading Row -->
      <div class="flex items-center justify-between gap-3 flex-1 min-w-[200px] lg:min-w-0 lg:contents">
        <!-- Name -->
        <div class="flex-1 lg:order-1">
          <span class="text-sm font-normal transition-colors duration-150" style="color: ${nameColor};">${safeName}</span>
          ${a.custom ? `<span class="ml-2 text-[10px] font-mono px-1.5 py-0.5 rounded bg-border text-accent">CUSTOM</span>` : ''}
        </div>

        <!-- kWh display (Shown on mobile line 1, on desktop after hours) -->
        <div class="flex-shrink-0 text-right min-w-[65px] sm:min-w-[80px] lg:order-5">
          <span class="font-mono text-xs sm:text-sm font-semibold tabular-nums" style="color: var(--accent);" data-kwh-display="${a.id}">${kwh}</span>
          <span class="text-[9px] sm:text-[10px] text-text-muted ml-0.5">kWh(unit)</span>
        </div>
      </div>

      <!-- Controls Row -->
      <div class="flex items-center justify-between w-full lg:w-auto lg:contents gap-2 lg:gap-3 order-3 mt-1 lg:mt-0">
        <!-- Watts -->
        <div class="flex items-center gap-1 flex-1 lg:flex-none justify-center lg:justify-start lg:order-2">
          <input type="number" value="${a.watts}" min="1" max="99999"
            class="w-full sm:w-20 rounded-lg px-1.5 h-11 sm:h-8 text-center font-mono text-xs sm:text-sm focus:outline-none transition-colors"
            data-action="update-watts" data-id="${a.id}" aria-label="Watts for ${safeName}" />
          <span class="text-[9px] sm:text-[11px] text-text-muted font-mono uppercase w-3 text-center">W</span>
        </div>

        <!-- Qty stepper -->
        <div class="flex items-center flex-1 lg:flex-none justify-center lg:order-3">
          <button type="button" class="stepper-btn flex-1 lg:flex-none max-w-[40px]" data-action="decrement-qty" data-id="${a.id}" aria-label="Decrease quantity">−</button>
          <span class="w-6 sm:w-8 text-center font-mono text-xs sm:text-sm font-semibold tabular-nums" data-qty-display="${a.id}">${a.qty}</span>
          <button type="button" class="stepper-btn flex-1 lg:flex-none max-w-[40px]" data-action="increment-qty" data-id="${a.id}" aria-label="Increase quantity">+</button>
        </div>

        <!-- Hours -->
        <div class="flex flex-col items-center gap-1 flex-1 lg:flex-none justify-center lg:order-4">
          <div class="flex items-center gap-1 w-full justify-center">
            <input type="number" value="${a.hours}" min="0" max="24" step="0.25"
              class="w-full sm:w-16 rounded-lg px-1.5 h-11 sm:h-8 text-center font-mono text-xs sm:text-sm focus:outline-none transition-colors"
              data-action="update-hours" data-id="${a.id}" aria-label="Hours per day for ${safeName}" />
            <span class="text-[9px] sm:text-[11px] text-text-muted font-mono uppercase w-5 text-center">h/d</span>
          </div>
          <span class="hours-error hidden text-[8px] sm:text-[9px] text-danger font-mono font-bold uppercase absolute mt-6" data-error-id="${a.id}">Max 24h</span>
        </div>

        <!-- Actions -->
        <div class="flex-shrink-0 w-8 h-11 sm:w-8 sm:h-8 flex items-center justify-center lg:order-6 ml-auto">
          ${a.custom ? `
            <button type="button"
              class="w-10 h-10 sm:w-8 sm:h-8 rounded-md text-text-muted hover:text-danger active:text-danger hover:bg-border transition-colors focus:outline-none"
              data-action="delete-appliance" data-id="${a.id}" aria-label="Remove ${safeName}" title="Remove appliance">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mx-auto">
                <path d="M3 6h18"></path>
                <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
              </svg>
            </button>
          ` : ''}
        </div>
      </div>
    </div>`;
}

function closeModal() {
  const modal = document.getElementById('report-modal');
  modal?.classList.add('hidden');
  modal?.classList.remove('flex');
}

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeModal();
});

function expandLighting() {
  const body = document.getElementById('category-body-Lighting');
  if (!body || body.classList.contains('is-open')) return;
  body.classList.add('is-open');
  const section = body.closest('.category-section');
  const toggleBtn = section?.querySelector<HTMLButtonElement>('[data-action="toggle-category"]');
  const chevron   = toggleBtn?.querySelector<SVGElement>('.chevron');
  if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'true');
  if (chevron)   chevron.style.transform = '';
}

function onStickyDetailsClick(e: Event) {
  e.preventDefault();
  document.getElementById('results-panel')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function initCalculator() {
  if (!document.getElementById('results-panel')) return;

  const stickyLink = document.getElementById('sticky-details-link');
  if (stickyLink) {
    stickyLink.removeEventListener('click', onStickyDetailsClick);
    stickyLink.addEventListener('click', onStickyDetailsClick);
  }

  const hasSavedState = loadState();

  if (hasSavedState) {
    // Re-hydrate settings inputs
    const maxKWInput = document.getElementById('max-kw-input') as HTMLInputElement;
    if (maxKWInput) maxKWInput.value = String(maxCapacityKW);

    // Re-hydrate appliance rows
    CATEGORIES.forEach(cat => {
      const bodyId = `category-body-${cat.replace(/\s/g, '-')}`;
      const body = document.getElementById(bodyId);
      const container = body?.querySelector('[data-rows-container]');
      if (!container) return;

      container.innerHTML = '';
      const catAppliances = appliances.filter(a => a.category === cat);
      catAppliances.forEach(a => {
        container.insertAdjacentHTML('beforeend', buildRowHTML(a));
      });

      // Auto-expand category if it contains active appliances
      if (catAppliances.some(a => a.qty > 0) && body) {
        body.classList.add('is-open');
        const section = body.closest('.category-section');
        const toggleBtn = section?.querySelector<HTMLButtonElement>('[data-action="toggle-category"]');
        const chevron = toggleBtn?.querySelector<SVGElement>('.chevron');
        if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'true');
        if (chevron) chevron.style.transform = '';
      }
    });

    appliances.forEach(a => updateRowNameStyle(a));
  }

  expandLighting();
  calculate();
}

document.addEventListener('astro:page-load', initCalculator);
</script>
