---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import ApplianceCategory from '@/components/ApplianceCategory.astro';
import ResultsPanel from '@/components/ResultsPanel.astro';
import ReportModal from '@/components/ReportModal.astro';
import FAQSection from '@/components/FAQSection.astro';
import { FAQS } from '@/data/faqs';
import { DEFAULT_APPLIANCES, CATEGORIES, SECTIONS } from '@/data/appliances';
import type { ApplianceCategory as CategoryType } from '@/types';

// Group appliances by sections and categories for SSR rendering
const sectionedData = SECTIONS.map(section => ({
  title: section.title,
  groups: section.categories.map(cat => ({
    name: cat as CategoryType,
    appliances: DEFAULT_APPLIANCES.filter(a => a.category === cat && !a.hidden),
  }))
}));

const schemaGraph = [
  {
    "@type": "FAQPage",
    "mainEntity": FAQS.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

<BaseLayout
  title="Electricity Load Calculator | Home Electrical Load Assessment"
  description="Professional electrical load calculator for home. Estimate kW load, kWh consumption, get MCB, cable, inverter & solar recommendations instantly."
  keywords="electricity load calculator, electrical load assessment, kw load calculator for home, house wiring load, energy cost estimator, bijli load calculator India"
  schemaGraph={schemaGraph}
>
  <PageHero />

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pb-24 print:hidden animate-slide-up">

    <!-- QUICK START PRESETS -->
    <div class="mt-10 mb-8 print:hidden">
      <div class="flex items-center gap-3 mb-4">
        <p class="text-xs sm:text-sm font-normal uppercase tracking-widest text-text-muted flex-shrink-0">Quick Start</p>
        <div class="flex-1 h-px bg-border/60"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 sm:gap-3">

        <!-- Budget Home -->
        <button type="button" data-action="load-preset" data-preset-id="budget-home"
          class="preset-card relative text-left px-4 py-3 sm:px-5 sm:py-4 rounded-xl border border-border bg-card hover:border-accent/40 hover:bg-card-hover transition-[border-color,background-color,box-shadow,transform] duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent group active:scale-[0.98]">
          
          <!-- Onboarding Hint -->
          <div class="onboarding-hint absolute -top-3 left-4 bg-accent text-accent-text text-[10px] font-bold px-2.5 py-0.5 rounded-full shadow-lg shadow-accent/40 animate-bounce pointer-events-none z-10 hidden">
            ✨ Start Here
          </div>

          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2">
              <span class="text-accent flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M12 22V12"/><path d="m5 12 7-10 7 10"/><path d="M19 15v5a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-5"/></svg>
              </span>
              <span class="text-base font-normal text-text-primary group-hover:text-accent transition-colors">Budget Home</span>
            </div>
            <span class="flex-shrink-0 text-[11px] font-mono px-2 py-1 rounded-full border border-border text-text-primary tabular-nums font-normal">~1.3 kW</span>
          </div>
          <p class="hidden sm:block text-xs text-text-muted mt-1.5 leading-relaxed">Essentials only — fans, fridge, TV &amp; laptop</p>
        </button>

        <!-- Typical 2BHK -->
        <button type="button" data-action="load-preset" data-preset-id="typical-2bhk"
          class="preset-card text-left px-4 py-3 sm:px-5 sm:py-4 rounded-xl border border-border bg-card hover:border-accent/40 hover:bg-card-hover transition-[border-color,background-color,box-shadow,transform] duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent group active:scale-[0.98]">
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2">
              <span class="text-accent flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </span>
              <span class="text-base font-normal text-text-primary group-hover:text-accent transition-colors">Typical 2BHK</span>
            </div>
            <span class="flex-shrink-0 text-[11px] font-mono px-2 py-1 rounded-full border border-border text-text-primary tabular-nums font-normal">~5 kW</span>
          </div>
          <p class="hidden sm:block text-xs text-text-muted mt-1.5 leading-relaxed">Standard home — AC, fridge, TV &amp; kitchen</p>
        </button>

        <!-- Summer Heavy -->
        <button type="button" data-action="load-preset" data-preset-id="summer-heavy"
          class="preset-card text-left px-4 py-3 sm:px-5 sm:py-4 rounded-xl border border-border bg-card hover:border-accent/40 hover:bg-card-hover transition-[border-color,background-color,box-shadow,transform] duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent group active:scale-[0.98]">
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2">
              <span class="text-accent flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
              </span>
              <span class="text-base font-normal text-text-primary group-hover:text-accent transition-colors">Summer Heavy</span>
            </div>
            <span class="flex-shrink-0 text-[11px] font-mono px-2 py-1 rounded-full border border-border text-text-primary tabular-nums font-normal">~10 kW</span>
          </div>
          <p class="hidden sm:block text-xs text-text-muted mt-1.5 leading-relaxed">Peak season — dual AC, full kitchen &amp; more</p>
        </button>

      </div>

    </div>

    <div class="flex flex-col lg:flex-row gap-6 items-start">

      <!-- Left: appliance categories -->
      <div class="flex-1 w-full min-w-0">
        <div class="space-y-10">
          {sectionedData.map((section) => (
          <div class="space-y-4">
            <div class="flex items-center justify-between border-l-4 border-accent pl-3">
              <h2 class="text-xl font-display font-bold text-text-primary uppercase tracking-wider flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-accent"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                {section.title}
              </h2>
              <button
                type="button"
                data-action="reset-all"
                class="hidden lg:flex items-center gap-2 px-3 py-1 rounded-lg border border-danger/20 text-danger bg-danger/5 text-lg font-display font-medium hover:bg-danger/10 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-danger active:scale-95"
                aria-label="Reset all appliances"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0V5.36l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219Z" clip-rule="evenodd"/>
                </svg>
                Reset All
              </button>
            </div>
            <div class="space-y-4">
              {section.groups.map((group, i) => (
                <ApplianceCategory
                  name={group.name}
                  appliances={group.appliances}
                  index={i}
                />
              ))}
            </div>
          </div>
        ))}
        </div>
      </div>

      <!-- Right: results panel -->
      <div class="w-full lg:w-80 xl:w-96 flex-shrink-0 z-10">
        <ResultsPanel />
      </div>

    </div>
  </main>

  <!-- MOBILE STICKY SUMMARY -->
  <div id="mobile-sticky-bar" class="fixed bottom-0 left-0 right-0 bg-card/95 backdrop-blur-md border-t border-border p-3 z-40 lg:hidden print:hidden no-print shadow-[0_-15px_30px_-15px_rgba(0,0,0,0.5)] flex justify-between items-center gap-4 pb-[max(0.75rem,env(safe-area-inset-bottom))] animate-slide-up-sticky">
    
    <!-- Reset button -->
    <button
      id="sticky-reset-btn"
      data-action="reset-all"
      type="button"
      class="flex items-center justify-center gap-2 px-3 h-10 rounded-lg border border-danger/20 text-danger bg-danger/5 hover:bg-danger/10 transition-all duration-300 focus:outline-none focus:ring-1 focus:ring-danger flex-shrink-0"
      aria-label="Reset all appliances"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 opacity-80">
        <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0V5.36l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219Z" clip-rule="evenodd"/>
      </svg>
      <span class="text-sm font-medium">Reset</span>
    </button>

    <!-- Center Summary -->
    <div class="flex flex-col items-center text-center flex-1 min-w-0">

      <!-- Numbers: shown when at least one appliance is active -->
      <div id="sticky-summary">
        <div class="flex items-baseline justify-center gap-1">
          <span id="sticky-total-kw" class="font-display font-bold text-2xl tabular-nums leading-none truncate" style="color: var(--accent);">0.00</span>
          <span class="font-mono text-xs text-text-muted">kW</span>
        </div>
        <div class="text-[10px] text-text-primary font-medium truncate w-full opacity-90">
          Monthly: <span id="sticky-monthly-kwh" class="font-semibold tabular-nums" style="color: var(--accent);">0</span> kWh
        </div>
      </div>

      <!-- Hint: shown when nothing is active yet -->
      <div id="sticky-empty-hint" class="flex flex-col items-center gap-0.5" style="display: none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
          class="w-3 h-3 animate-bounce mb-0.5" style="color: var(--accent);" aria-hidden="true">
          <path d="M12 19V5M5 12l7-7 7 7"/>
        </svg>
        <p class="text-xs font-medium text-text-primary">
          Pick a <span class="font-medium" style="color: var(--accent);">Quick Start</span> or tap <span class="font-medium" style="color: var(--accent);">+</span>
        </p>
        <p class="text-[10px] text-text-muted">to see your load &amp; bill</p>
      </div>

    </div>

    <!-- Details View -->
    <a
      href="#results-panel"
      id="sticky-details-link"
      class="flex items-center justify-center gap-2 px-4 h-10 rounded-lg bg-accent text-accent-text hover:bg-accent-dim transition-all duration-300 focus:outline-none focus:ring-1 focus:ring-accent shadow-lg shadow-accent/20 active:scale-95 flex-shrink-0"
      aria-label="View Detailed Report"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
        <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
        <circle cx="12" cy="12" r="3" />
      </svg>
      <span class="text-sm font-medium">View</span>
    </a>
  </div>
  </div>

  <!-- PRINT ONLY LAYOUT -->
  <div id="print-layout" class="hidden print:block w-full max-w-4xl mx-auto text-text-primary bg-white print:bg-white" style="padding: 0; box-sizing: border-box; background-color: white !important;">

    <!-- SECTION 1: Cover Page -->
    <div class="print-page flex flex-col justify-center min-h-[1050px]" style="page-break-after: always;">
      <div class="text-center">
        <h1 class="text-5xl font-display font-bold text-accent mb-6">Electrical Assessment Report</h1>
        <p class="text-xl text-text-muted mb-12">Electrical Load Analysis, Safety Recommendations, Energy Assessment and Planning Report</p>
        
        <div class="mt-24 space-y-4">
          <p class="text-sm font-bold uppercase tracking-widest text-text-muted">Prepared by</p>
          <p class="text-2xl font-bold" style="color:var(--accent)">ElectricityLoadCalculator.com</p>
        </div>

        <div class="mt-16 space-y-2">
          <p class="text-sm font-bold uppercase tracking-widest text-text-muted">Generated Date</p>
          <p class="text-lg font-mono text-text-primary" id="print-date"></p>
        </div>
      </div>
    </div>

    <!-- SECTION 2: Executive Summary -->
    <div class="print-page" style="page-break-before: always; break-before: page;">
      <div class="border-b-2 border-border pb-4 mb-8">
        <h2 class="text-2xl font-display font-bold text-text-primary">Executive Summary</h2>
      </div>

      <div class="grid grid-cols-2 gap-6 mb-8">
        <div class="bg-card p-6 rounded-xl border border-border">
          <p class="text-xs font-mono uppercase tracking-widest text-text-muted mb-2">Connected Load</p>
          <p class="text-4xl font-bold font-display" style="color: var(--accent);"><span id="print-total-kw">0.00</span> kW</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <p class="text-xs font-mono uppercase tracking-widest text-text-muted mb-2">Daily Consumption</p>
          <p class="text-4xl font-bold font-display text-text-primary"><span id="print-daily-kwh">0.00</span> <span class="text-lg text-text-muted font-sans font-normal">kWh</span></p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <p class="text-xs font-mono uppercase tracking-widest text-text-muted mb-2">Monthly Consumption</p>
          <p class="text-4xl font-bold font-display text-text-primary"><span id="print-monthly-kwh">0</span> <span class="text-lg text-text-muted font-sans font-normal">kWh</span></p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <p class="text-xs font-mono uppercase tracking-widest text-text-muted mb-2">Health Score</p>
          <div class="flex items-baseline gap-2">
            <p class="text-4xl font-bold font-display" style="color: var(--accent);"><span id="print-health-score">0</span></p>
            <span class="text-lg text-text-muted font-sans font-bold">/ 100</span>
          </div>
        </div>
      </div>

      <!-- SECTION 3: Electrical Assessment Verdict -->
      <div class="bg-card border border-border rounded-xl p-8 mb-8 break-inside-avoid">
        <h3 class="text-lg font-bold text-text-primary mb-4">Electrical Assessment Verdict</h3>
        <div class="flex items-center gap-3 mb-6">
          <span class="text-sm font-bold uppercase tracking-widest text-text-muted">Overall Status:</span>
          <span id="print-health-label" class="px-3 py-1 text-sm font-bold rounded-full" style="background:color-mix(in srgb, var(--accent), transparent 85%); color:var(--accent);">—</span>
        </div>
        <h4 class="text-sm font-bold uppercase tracking-widest text-text-muted mb-3">Key Findings:</h4>
        <ul id="print-verdict-findings" class="space-y-2 text-sm text-text-primary"></ul>
      </div>

      <!-- SECTION 4: Load Analysis -->
      <div class="border-b-2 border-border pb-4 mb-6 mt-12 break-inside-avoid">
        <h2 class="text-2xl font-display font-bold text-text-primary">Load Analysis</h2>
      </div>
      <div class="grid grid-cols-2 gap-6 mb-8 break-inside-avoid">
        <div class="space-y-4 text-sm">
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">Connected Load</span>
            <span class="font-bold text-text-primary"><span id="print-analysis-load">0.00</span> kW</span>
          </div>
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">Daily Consumption</span>
            <span class="font-bold text-text-primary"><span id="print-analysis-daily">0.00</span> kWh</span>
          </div>
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">Monthly Consumption</span>
            <span class="font-bold text-text-primary"><span id="print-analysis-monthly">0</span> kWh</span>
          </div>
        </div>
        <div class="bg-card border border-border p-6 rounded-xl flex flex-col justify-center text-sm">
          <div class="flex justify-between border-b border-border pb-3 mb-3">
            <span class="text-text-muted">Assumed Voltage</span>
            <span class="font-bold text-text-primary">230V</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="font-bold text-text-primary">Operating Current</span>
            <span class="font-bold text-2xl" style="color:var(--accent)"><span id="print-analysis-current">0.0</span> A</span>
          </div>
        </div>
      </div>
      
      <!-- SECTION 5: Recommendation Matrix -->
      <div class="border-b-2 border-border pb-4 mb-6 mt-12 break-inside-avoid">
        <h2 class="text-2xl font-display font-bold text-text-primary">Recommendation Matrix</h2>
      </div>
      <div class="bg-card border border-border rounded-xl overflow-hidden break-inside-avoid">
        <table class="w-full text-left text-sm">
          <thead class="bg-border/30">
            <tr>
              <th class="px-6 py-3 font-bold uppercase tracking-widest text-text-muted text-xs">Component</th>
              <th class="px-6 py-3 font-bold uppercase tracking-widest text-text-muted text-xs">Recommended Value</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr>
              <td class="px-6 py-4 font-semibold text-text-primary">Main MCB Rating</td>
              <td class="px-6 py-4 font-bold" style="color:var(--accent)" id="print-matrix-mcb">—</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-text-primary">Main Cable Gauge</td>
              <td class="px-6 py-4 font-bold" style="color:var(--accent)" id="print-matrix-cable">—</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-text-primary">Inverter Capacity</td>
              <td class="px-6 py-4 font-bold" style="color:var(--accent)" id="print-matrix-inverter">—</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-text-primary">Solar System Size</td>
              <td class="px-6 py-4 font-bold" style="color:var(--accent)" id="print-matrix-solar">—</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- SECTION 6: Detailed Recommendations -->
    <div class="print-page" style="page-break-before: always; break-before: page;">
      <div class="border-b-2 border-border pb-4 mb-8">
        <h2 class="text-2xl font-display font-bold text-text-primary">Detailed Recommendations</h2>
      </div>

      <div class="grid grid-cols-2 gap-8">
        <div class="bg-card border border-border rounded-xl p-6 break-inside-avoid">
          <h3 class="text-lg font-bold text-text-primary border-b border-border pb-3 mb-4">MCB Recommendation</h3>
          <p class="text-3xl font-bold mb-6" style="color:var(--accent)" id="print-det-mcb">—</p>
          <p class="text-xs font-bold uppercase tracking-widest text-text-muted mb-2">Calculation Path</p>
          <div class="space-y-2 text-sm text-text-muted">
            <div class="flex justify-between"><span>Load:</span> <span class="font-mono text-text-primary"><span id="print-det-mcb-load">0</span> kW</span></div>
            <div class="flex justify-between"><span>Current:</span> <span class="font-mono text-text-primary"><span id="print-det-mcb-curr">0</span> A</span></div>
            <div class="flex justify-between"><span>Safety Margin:</span> <span class="font-mono text-text-primary">25%</span></div>
          </div>
        </div>

        <div class="bg-card border border-border rounded-xl p-6 break-inside-avoid">
          <h3 class="text-lg font-bold text-text-primary border-b border-border pb-3 mb-4">Cable Recommendation</h3>
          <p class="text-3xl font-bold mb-6" style="color:var(--accent)" id="print-det-cable">—</p>
          <p class="text-xs font-bold uppercase tracking-widest text-text-muted mb-2">Calculation Path</p>
          <div class="space-y-2 text-sm text-text-muted">
            <div class="flex justify-between"><span>Current:</span> <span class="font-mono text-text-primary"><span id="print-det-cab-curr">0</span> A</span></div>
            <div class="flex justify-between"><span>Required MCB:</span> <span class="font-mono text-text-primary" id="print-det-cab-mcb">—</span></div>
          </div>
        </div>

        <div class="bg-card border border-border rounded-xl p-6 break-inside-avoid">
          <h3 class="text-lg font-bold text-text-primary border-b border-border pb-3 mb-4">Inverter Recommendation</h3>
          <p class="text-3xl font-bold mb-6" style="color:var(--accent)" id="print-det-inverter">—</p>
          <p class="text-xs font-bold uppercase tracking-widest text-text-muted mb-2">Calculation Path</p>
          <div class="space-y-2 text-sm text-text-muted">
            <div class="flex justify-between"><span>Load:</span> <span class="font-mono text-text-primary"><span id="print-det-inv-load">0</span> kW</span></div>
            <div class="flex justify-between"><span>Sizing Factor:</span> <span class="font-mono text-text-primary">1.2 (20% margin)</span></div>
            <div class="flex justify-between"><span>Required Capacity:</span> <span class="font-mono text-text-primary"><span id="print-det-inv-req">0</span> kVA</span></div>
          </div>
        </div>

