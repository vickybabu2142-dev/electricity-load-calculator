---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

const schemaGraph = [
  {
    "@type": "WebPage",
    "name": "Electrical Load Assessment Report",
    "description": "Comprehensive analysis of household electrical load, including health score, energy-saving tips, and component recommendations.",
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://electricityloadcalculator.com" },
        { "@type": "ListItem", "position": 2, "name": "Assessment" }
      ]
    }
  }
];
---

<BaseLayout
  title="Electrical Assessment Report | Electricity Load Calculator"
  description="View your detailed household electrical load assessment. Get your health score, energy saving opportunities, and tailored component recommendations based on your usage."
  keywords="electrical assessment report, electrical load assessment, MCB recommendation, cable sizing recommendation, inverter recommendation, solar recommendation, electrical health score, energy consumption analysis"
  noindex={true}
  schemaGraph={schemaGraph}
>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Electrical Assessment' }]} />

  <!-- LOADING STATE -->
  <div id="assess-loading" class="max-w-[1300px] mx-auto px-4 sm:px-6 pt-16 pb-32 text-center">
    <p class="text-sm text-text-muted font-mono animate-pulse">Loading your assessment…</p>
  </div>

  <!-- EMPTY STATE -->
  <div id="assess-empty" class="max-w-[600px] mx-auto px-4 sm:px-6 py-20 text-center" style="display:none">
    <div class="rounded-xl border border-border bg-card p-10">
      <div class="flex justify-center mb-5">
        <span class="flex h-14 w-14 items-center justify-center rounded-2xl border border-border" style="background:color-mix(in srgb, var(--accent), transparent 94%)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-accent" aria-hidden="true"><path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/></svg>
        </span>
      </div>
      <h1 class="font-display font-bold text-2xl text-text-primary mb-3">No Assessment Data</h1>
      <p class="text-text-muted text-sm leading-relaxed mb-6">You haven't configured your appliances yet. Use the calculator to select your appliances, then come back to view your full assessment.</p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent text-accent-text font-medium hover:bg-accent-dim transition-colors shadow-lg shadow-accent/20">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd"/></svg>
        Configure Your Appliances
      </a>
    </div>
  </div>

  <!-- ASSESSMENT CONTENT -->
  <main id="assess-content" class="max-w-[1300px] mx-auto px-4 sm:px-6 pb-24 print:hidden" style="display:none">

    <!-- S1: Header -->
    <div class="pt-8 pb-8 border-b border-border mb-10">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
          <p class="text-[10px] font-mono uppercase tracking-widest text-accent mb-2">Electrical Assessment Report</p>
          <h1 class="font-display font-bold text-3xl sm:text-4xl text-text-primary leading-tight mb-2">Your Electrical Assessment</h1>
          <p class="text-sm text-text-muted">Generated from your appliance configuration &nbsp;·&nbsp; <span id="assess-timestamp" class="font-mono"></span></p>
        </div>
        <a href="/" class="flex-shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-lg border text-sm font-medium transition-colors" style="color:var(--accent); border-color:color-mix(in srgb,var(--accent),transparent 60%); background:color-mix(in srgb,var(--accent),transparent 92%)" data-astro-prefetch="hover">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd"/></svg>
          Edit Load
        </a>
      </div>
    </div>

    <!-- S2: Load Summary -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-[10px] font-mono uppercase tracking-widest text-text-muted flex-shrink-0">01</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="text-lg font-display font-bold text-text-primary uppercase tracking-wide flex-shrink-0">Load Summary</h2>
        <div class="flex-1 h-px bg-border"></div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">

        <div class="rounded-xl border border-border bg-card p-5" title="The total power capacity of all your active appliances combined.">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3 flex items-center gap-1">
            Total Load
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 opacity-50"><path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.25a.75.75 0 0 1 .75.75v1.75a.75.75 0 0 0 1.5 0v-2.25A.75.75 0 0 0 10.75 9H9Z" clip-rule="evenodd" /></svg>
          </p>
          <p class="font-display font-bold text-4xl tabular-nums leading-none mb-1" style="color:var(--accent)"><span id="assess-total-kw">—</span></p>
          <p class="text-xs font-mono text-text-muted">kW connected</p>
        </div>

        <div class="rounded-xl border border-border bg-card p-5" title="Estimated energy used in a 24-hour period based on your usage hours.">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3 flex items-center gap-1">
            Daily Usage
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 opacity-50"><path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.25a.75.75 0 0 1 .75.75v1.75a.75.75 0 0 0 1.5 0v-2.25A.75.75 0 0 0 10.75 9H9Z" clip-rule="evenodd" /></svg>
          </p>
          <p class="font-display font-bold text-4xl tabular-nums leading-none mb-1" style="color:var(--accent)"><span id="assess-daily-kwh">—</span></p>
          <p class="text-xs font-mono text-text-muted">kWh(unit) per day</p>
        </div>

        <div class="rounded-xl border border-border bg-card p-5" title="Total energy units consumed in a typical 30-day month.">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3 flex items-center gap-1">
            Monthly Usage
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 opacity-50"><path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.25a.75.75 0 0 1 .75.75v1.75a.75.75 0 0 0 1.5 0v-2.25A.75.75 0 0 0 10.75 9H9Z" clip-rule="evenodd" /></svg>
          </p>
          <div class="flex items-baseline gap-2 mb-1">
            <span id="assess-monthly-kwh-original" class="hidden text-xl line-through text-text-muted font-normal">—</span>
            <p class="font-display font-bold text-4xl tabular-nums leading-none" style="color:var(--accent)"><span id="assess-monthly-kwh">—</span></p>
          </div>
          <p id="assess-monthly-label" class="text-xs font-mono text-text-muted">kWh(unit) per month</p>
        </div>

        <div class="rounded-xl border border-border bg-card p-5" title="The appliance that consumes the most energy in your home.">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3 flex items-center gap-1">
            Top Consumer
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 opacity-50"><path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.25a.75.75 0 0 1 .75.75v1.75a.75.75 0 0 0 1.5 0v-2.25A.75.75 0 0 0 10.75 9H9Z" clip-rule="evenodd" /></svg>
          </p>
          <p id="assess-top-consumer-name" class="font-display font-bold text-lg leading-tight mb-1 truncate" style="color:var(--accent)">—</p>
          <p id="assess-top-consumer-watts" class="text-xs font-mono" style="color:color-mix(in srgb, var(--accent), transparent 20%)">—</p>
        </div>

        <div class="rounded-xl border border-border bg-card p-5" title="A combined rating of your home's electrical safety, efficiency, and balance.">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3 flex items-center gap-1">
            Health Score
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 opacity-50"><path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.25a.75.75 0 0 1 .75.75v1.75a.75.75 0 0 0 1.5 0v-2.25A.75.75 0 0 0 10.75 9H9Z" clip-rule="evenodd" /></svg>
          </p>
          <p class="font-display font-bold text-4xl tabular-nums leading-none mb-1" style="color:var(--accent)"><span id="assess-health-score-summary">—</span></p>
          <p id="assess-health-label-summary" class="text-xs font-mono text-text-muted">/ 100</p>
        </div>

      </div>
    </section>

    <!-- S3: Smart Recommendations -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-[10px] font-mono uppercase tracking-widest text-text-muted flex-shrink-0">02</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="text-lg font-display font-bold text-text-primary uppercase tracking-wide flex-shrink-0">Smart Recommendations</h2>
        <div class="flex-1 h-px bg-border"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">

        <!-- MCB — Amber -->
        <a href="/recommendations/mcb"
          class="rec-card rec-glow-amber group relative flex flex-col gap-4 rounded-2xl p-6 no-underline overflow-hidden transition-all duration-200 hover:scale-[1.02] hover:-translate-y-0.5"
          style="background:color-mix(in srgb,#F59E0B,transparent 96%); border:1px solid color-mix(in srgb,#F59E0B,transparent 84%); box-shadow:0 0 20px color-mix(in srgb,#F59E0B,transparent 88%),0 8px 24px color-mix(in srgb,#F59E0B,transparent 94%);"
          aria-label="View MCB recommendation"
          title="Miniature Circuit Breaker: Automatically switches off power if there is a fault or overload to prevent fires.">
          <div class="flex items-start justify-between">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0"
              style="background:color-mix(in srgb,#F59E0B,transparent 82%); border:1px solid color-mix(in srgb,#F59E0B,transparent 65%)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" style="color:#F59E0B" aria-hidden="true"><path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/></svg>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity mt-1" style="color:#F59E0B" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1" style="color:color-mix(in srgb,#F59E0B,transparent 30%)">Main Breaker (MCB)</p>
            <p id="assess-mcb-value" class="font-display font-bold text-3xl leading-tight mb-2" style="color:#F59E0B">—</p>
            <p class="text-xs leading-relaxed" style="color:color-mix(in srgb,#F59E0B,transparent 40%)">Safety switch for your total connected load.</p>
          </div>
          <div class="flex items-center gap-1.5 text-xs font-semibold" style="color:color-mix(in srgb,#F59E0B,transparent 25%)">
            View Details
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="box-shadow:inset 0 0 0 1.5px color-mix(in srgb,#F59E0B,transparent 48%)"></div>
        </a>

        <!-- Cable — Sky Blue -->
        <a href="/recommendations/cable"
          class="rec-card rec-glow-sky group relative flex flex-col gap-4 rounded-2xl p-6 no-underline overflow-hidden transition-all duration-200 hover:scale-[1.02] hover:-translate-y-0.5"
          style="background:color-mix(in srgb,#38BDF8,transparent 96%); border:1px solid color-mix(in srgb,#38BDF8,transparent 84%); box-shadow:0 0 20px color-mix(in srgb,#38BDF8,transparent 88%),0 8px 24px color-mix(in srgb,#38BDF8,transparent 94%);"
          aria-label="View cable recommendation"
          title="Cable Thickness: Thicker wires carry more electricity without heating up or wasting energy.">
          <div class="flex items-start justify-between">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0"
              style="background:color-mix(in srgb,#38BDF8,transparent 82%); border:1px solid color-mix(in srgb,#38BDF8,transparent 65%)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5" style="color:#38BDF8" aria-hidden="true"><path d="M4 12h16M7 5v14M17 5v14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity mt-1" style="color:#38BDF8" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1" style="color:color-mix(in srgb,#38BDF8,transparent 30%)">Main Wiring</p>
            <p id="assess-cable-value" class="font-display font-bold text-3xl leading-tight mb-2" style="color:#38BDF8">—</p>
            <p class="text-xs leading-relaxed" style="color:color-mix(in srgb,#38BDF8,transparent 40%)">Recommended wire gauge for your main line.</p>
          </div>
          <div class="flex items-center gap-1.5 text-xs font-semibold" style="color:color-mix(in srgb,#38BDF8,transparent 25%)">
            View Details
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="box-shadow:inset 0 0 0 1.5px color-mix(in srgb,#38BDF8,transparent 48%)"></div>
        </a>

        <!-- Stabilizer — Rose -->
        <a href="/recommendations/stabilizer"
          class="rec-card rec-glow-rose group relative flex flex-col gap-4 rounded-2xl p-6 no-underline overflow-hidden transition-all duration-200 hover:scale-[1.02] hover:-translate-y-0.5"
          style="background:color-mix(in srgb,#F43F5E,transparent 96%); border:1px solid color-mix(in srgb,#F43F5E,transparent 84%); box-shadow:0 0 20px color-mix(in srgb,#F43F5E,transparent 88%),0 8px 24px color-mix(in srgb,#F43F5E,transparent 94%);"
          aria-label="View stabilizer recommendation"
          title="Voltage Stabilizer: Protects the whole house from high/low voltage fluctuations and utility line surges.">
          <div class="flex items-start justify-between">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0"
              style="background:color-mix(in srgb,#F43F5E,transparent 82%); border:1px solid color-mix(in srgb,#F43F5E,transparent 65%)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" style="color:#F43F5E" aria-hidden="true">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-1 6h2v5h-2V7zm0 7h2v2h-2v-2z"/>
              </svg>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity mt-1" style="color:#F43F5E" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1" style="color:color-mix(in srgb,#F43F5E,transparent 30%)">Mainline Stabilizer</p>
            <p id="assess-stabilizer-value" class="font-display font-bold text-3xl leading-tight mb-2" style="color:#F43F5E">—</p>
            <p class="text-xs leading-relaxed" style="color:color-mix(in srgb,#F43F5E,transparent 40%)">Protects your home appliances from voltage surges.</p>
          </div>
          <div class="flex items-center gap-1.5 text-xs font-semibold" style="color:color-mix(in srgb,#F43F5E,transparent 25%)">
            View Details
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="box-shadow:inset 0 0 0 1.5px color-mix(in srgb,#F43F5E,transparent 48%)"></div>
        </a>

        <!-- Inverter — Violet -->
        <a href="/recommendations/inverter"
          class="rec-card rec-glow-violet group relative flex flex-col gap-4 rounded-2xl p-6 no-underline overflow-hidden transition-all duration-200 hover:scale-[1.02] hover:-translate-y-0.5"
          style="background:color-mix(in srgb,#A78BFA,transparent 96%); border:1px solid color-mix(in srgb,#A78BFA,transparent 84%); box-shadow:0 0 20px color-mix(in srgb,#A78BFA,transparent 88%),0 8px 24px color-mix(in srgb,#A78BFA,transparent 94%);"
          aria-label="View inverter recommendation"
          title="Inverter/UPS: Converts battery power to household power during blackouts.">
          <div class="flex items-start justify-between">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0"
              style="background:color-mix(in srgb,#A78BFA,transparent 82%); border:1px solid color-mix(in srgb,#A78BFA,transparent 65%)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" style="color:#A78BFA" aria-hidden="true"><path d="M4 7h16a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Zm14 2H6v6h12V9Zm2-3h1v2h-1V6Zm-17 0H2v2h1V6Z"/></svg>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity mt-1" style="color:#A78BFA" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1" style="color:color-mix(in srgb,#A78BFA,transparent 30%)">Inverter (Backup)</p>
            <p id="assess-inverter-value" class="font-display font-bold text-3xl leading-tight mb-2" style="color:#A78BFA">—</p>
            <p class="text-xs leading-relaxed" style="color:color-mix(in srgb,#A78BFA,transparent 40%)">Backup capacity needed for your essential load.</p>
          </div>
          <div class="flex items-center gap-1.5 text-xs font-semibold" style="color:color-mix(in srgb,#A78BFA,transparent 25%)">
            View Details
