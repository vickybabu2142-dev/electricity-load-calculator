  .rec-card { transition: box-shadow 0.25s ease, transform 0.2s ease; }
  .rec-glow-amber:hover  { box-shadow: 0 0 38px color-mix(in srgb,#F59E0B,transparent 50%), 0 12px 40px color-mix(in srgb,#F59E0B,transparent 62%) !important; }
  .rec-glow-sky:hover    { box-shadow: 0 0 38px color-mix(in srgb,#38BDF8,transparent 50%), 0 12px 40px color-mix(in srgb,#38BDF8,transparent 62%) !important; }
  .rec-glow-violet:hover { box-shadow: 0 0 38px color-mix(in srgb,#A78BFA,transparent 50%), 0 12px 40px color-mix(in srgb,#A78BFA,transparent 62%) !important; }
