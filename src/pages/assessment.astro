---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<BaseLayout
  title="Electrical Assessment Report | Electricity Load Calculator"
  description="Your personalised electrical load assessment — total load, MCB, cable, inverter and solar recommendations, health score, and energy savings based on your appliance configuration."
  keywords="electrical assessment report, electrical load assessment, MCB recommendation, cable sizing recommendation, inverter recommendation, solar panel recommendation, electrical health score, energy consumption analysis"
>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Electrical Assessment' }]} />

  <!-- LOADING STATE -->
  <div id="assess-loading" class="max-w-[1300px] mx-auto px-4 sm:px-6 pt-16 pb-32 text-center">
    <p class="text-sm text-text-muted font-mono animate-pulse">Loading your assessment…</p>
  </div>

  <!-- EMPTY STATE -->
  <div id="assess-empty" class="max-w-[600px] mx-auto px-4 sm:px-6 py-20 text-center" style="display:none">
    <div class="rounded-xl border border-border bg-card p-10">
      <div class="flex justify-center mb-5">
        <span class="flex h-14 w-14 items-center justify-center rounded-2xl border border-border" style="background:color-mix(in srgb, var(--accent), transparent 88%)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-accent" aria-hidden="true"><path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/></svg>
        </span>
      </div>
      <h1 class="font-display font-bold text-2xl text-text-primary mb-3">No Assessment Data</h1>
      <p class="text-text-muted text-sm leading-relaxed mb-6">You haven't configured your appliances yet. Use the calculator to select your appliances, then come back to view your full assessment.</p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent text-accent-text font-medium hover:bg-accent-dim transition-colors shadow-lg shadow-accent/20">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd"/></svg>
        Configure Your Appliances
      </a>
    </div>
  </div>

  <!-- ASSESSMENT CONTENT -->
  <main id="assess-content" class="max-w-[1300px] mx-auto px-4 sm:px-6 pb-24 print:hidden" style="display:none">

    <!-- S1: Header -->
    <div class="pt-8 pb-8 border-b border-border mb-10">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-2">Electrical Assessment Report</p>
          <h1 class="font-display font-bold text-3xl sm:text-4xl text-text-primary leading-tight mb-2">Your Electrical Assessment</h1>
          <p class="text-sm text-text-muted">Generated from your appliance configuration &nbsp;·&nbsp; <span id="assess-timestamp" class="font-mono"></span></p>
        </div>
        <a href="/" class="flex-shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-lg border text-sm font-medium transition-colors" style="color:var(--accent); border-color:color-mix(in srgb,var(--accent),transparent 60%); background:color-mix(in srgb,var(--accent),transparent 92%)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd"/></svg>
          Edit Configuration
        </a>
      </div>
    </div>

    <!-- S2: Load Summary -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-[10px] font-mono uppercase tracking-widest text-text-muted flex-shrink-0">01</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="text-lg font-display font-bold text-text-primary uppercase tracking-wide flex-shrink-0">Load Summary</h2>
        <div class="flex-1 h-px bg-border"></div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">

        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3">Total Load</p>
          <p class="font-display font-bold text-4xl tabular-nums leading-none mb-1" style="color:var(--accent)"><span id="assess-total-kw">—</span></p>
          <p class="text-xs font-mono text-text-muted">kW connected</p>
        </div>

        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3">Daily Usage</p>
          <p class="font-display font-bold text-4xl tabular-nums leading-none mb-1 text-text-primary"><span id="assess-daily-kwh">—</span></p>
          <p class="text-xs font-mono text-text-muted">kWh per day</p>
        </div>

        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3">Monthly Usage</p>
          <p class="font-display font-bold text-4xl tabular-nums leading-none mb-1 text-text-primary"><span id="assess-monthly-kwh">—</span></p>
          <p class="text-xs font-mono text-text-muted">kWh per month</p>
        </div>

        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3">Top Consumer</p>
          <p id="assess-top-consumer-name" class="font-display font-bold text-lg leading-tight text-text-primary mb-1 truncate">—</p>
          <p id="assess-top-consumer-watts" class="text-xs font-mono text-text-muted">—</p>
        </div>

        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-3">Health Score</p>
          <p class="font-display font-bold text-4xl tabular-nums leading-none mb-1" style="color:var(--accent)"><span id="assess-health-score-summary">—</span></p>
          <p id="assess-health-label-summary" class="text-xs font-mono text-text-muted">/ 100</p>
        </div>

      </div>
    </section>

    <!-- S3: Smart Recommendations -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-[10px] font-mono uppercase tracking-widest text-text-muted flex-shrink-0">02</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="text-lg font-display font-bold text-text-primary uppercase tracking-wide flex-shrink-0">Smart Recommendations</h2>
        <div class="flex-1 h-px bg-border"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

        <!-- MCB — Amber -->
        <a href="/recommendations/mcb"
          class="rec-card rec-glow-amber group relative flex flex-col gap-4 rounded-2xl p-6 no-underline overflow-hidden transition-all duration-200 hover:scale-[1.02] hover:-translate-y-0.5"
          style="background:color-mix(in srgb,#F59E0B,transparent 92%); border:1px solid color-mix(in srgb,#F59E0B,transparent 70%); box-shadow:0 0 22px color-mix(in srgb,#F59E0B,transparent 72%),0 8px 28px color-mix(in srgb,#F59E0B,transparent 82%);"
          aria-label="View MCB recommendation">
          <div class="flex items-start justify-between">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0"
              style="background:color-mix(in srgb,#F59E0B,transparent 78%); border:1px solid color-mix(in srgb,#F59E0B,transparent 58%)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" style="color:#F59E0B" aria-hidden="true"><path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/></svg>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity mt-1" style="color:#F59E0B" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1" style="color:color-mix(in srgb,#F59E0B,transparent 25%)">Circuit Breaker</p>
            <p id="assess-mcb-value" class="font-display font-bold text-3xl leading-tight mb-2" style="color:#F59E0B">—</p>
            <p class="text-xs leading-relaxed" style="color:color-mix(in srgb,#F59E0B,transparent 35%)">MCB with 25% safety margin for your connected load.</p>
          </div>
          <div class="flex items-center gap-1.5 text-xs font-semibold" style="color:color-mix(in srgb,#F59E0B,transparent 20%)">
            View Details
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="box-shadow:inset 0 0 0 1.5px color-mix(in srgb,#F59E0B,transparent 42%)"></div>
        </a>

        <!-- Cable — Sky Blue -->
        <a href="/recommendations/cable"
          class="rec-card rec-glow-sky group relative flex flex-col gap-4 rounded-2xl p-6 no-underline overflow-hidden transition-all duration-200 hover:scale-[1.02] hover:-translate-y-0.5"
          style="background:color-mix(in srgb,#38BDF8,transparent 92%); border:1px solid color-mix(in srgb,#38BDF8,transparent 70%); box-shadow:0 0 22px color-mix(in srgb,#38BDF8,transparent 72%),0 8px 28px color-mix(in srgb,#38BDF8,transparent 82%);"
          aria-label="View cable recommendation">
          <div class="flex items-start justify-between">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0"
              style="background:color-mix(in srgb,#38BDF8,transparent 78%); border:1px solid color-mix(in srgb,#38BDF8,transparent 58%)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5" style="color:#38BDF8" aria-hidden="true"><path d="M4 12h16M7 5v14M17 5v14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity mt-1" style="color:#38BDF8" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1" style="color:color-mix(in srgb,#38BDF8,transparent 25%)">Wiring</p>
            <p id="assess-cable-value" class="font-display font-bold text-3xl leading-tight mb-2" style="color:#38BDF8">—</p>
            <p class="text-xs leading-relaxed" style="color:color-mix(in srgb,#38BDF8,transparent 35%)">Wire cross-section for safe, efficient power delivery.</p>
          </div>
          <div class="flex items-center gap-1.5 text-xs font-semibold" style="color:color-mix(in srgb,#38BDF8,transparent 20%)">
            View Details
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="box-shadow:inset 0 0 0 1.5px color-mix(in srgb,#38BDF8,transparent 42%)"></div>
        </a>

        <!-- Inverter — Violet -->
        <a href="/recommendations/inverter"
          class="rec-card rec-glow-violet group relative flex flex-col gap-4 rounded-2xl p-6 no-underline overflow-hidden transition-all duration-200 hover:scale-[1.02] hover:-translate-y-0.5"
          style="background:color-mix(in srgb,#A78BFA,transparent 92%); border:1px solid color-mix(in srgb,#A78BFA,transparent 70%); box-shadow:0 0 22px color-mix(in srgb,#A78BFA,transparent 72%),0 8px 28px color-mix(in srgb,#A78BFA,transparent 82%);"
          aria-label="View inverter recommendation">
          <div class="flex items-start justify-between">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0"
              style="background:color-mix(in srgb,#A78BFA,transparent 78%); border:1px solid color-mix(in srgb,#A78BFA,transparent 58%)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" style="color:#A78BFA" aria-hidden="true"><path d="M4 7h16a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Zm14 2H6v6h12V9Zm2-3h1v2h-1V6Zm-17 0H2v2h1V6Z"/></svg>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity mt-1" style="color:#A78BFA" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1" style="color:color-mix(in srgb,#A78BFA,transparent 25%)">Backup Power</p>
            <p id="assess-inverter-value" class="font-display font-bold text-3xl leading-tight mb-2" style="color:#A78BFA">—</p>
            <p class="text-xs leading-relaxed" style="color:color-mix(in srgb,#A78BFA,transparent 35%)">Minimum inverter capacity for reliable backup power.</p>
          </div>
          <div class="flex items-center gap-1.5 text-xs font-semibold" style="color:color-mix(in srgb,#A78BFA,transparent 20%)">
            View Details
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="box-shadow:inset 0 0 0 1.5px color-mix(in srgb,#A78BFA,transparent 42%)"></div>
        </a>

        <!-- Solar — Emerald -->
        <a href="/recommendations/solar"
          class="rec-card rec-glow-emerald group relative flex flex-col gap-4 rounded-2xl p-6 no-underline overflow-hidden transition-all duration-200 hover:scale-[1.02] hover:-translate-y-0.5"
          style="background:color-mix(in srgb,#4ADE80,transparent 92%); border:1px solid color-mix(in srgb,#4ADE80,transparent 70%); box-shadow:0 0 22px color-mix(in srgb,#4ADE80,transparent 72%),0 8px 28px color-mix(in srgb,#4ADE80,transparent 82%);"
          aria-label="View solar recommendation">
          <div class="flex items-start justify-between">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl flex-shrink-0"
              style="background:color-mix(in srgb,#4ADE80,transparent 78%); border:1px solid color-mix(in srgb,#4ADE80,transparent 58%)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" style="color:#4ADE80" aria-hidden="true"><path d="M12 2a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1Zm0 15a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm8-6a1 1 0 0 1 0 2h-1a1 1 0 1 1 0-2h1ZM5 11a1 1 0 0 1 0 2H4a1 1 0 1 1 0-2h1Zm14.07-6.07a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0ZM6.34 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0Zm12.02 1.41a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 1 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41ZM5.64 5.64a1 1 0 0 1 1.41 0l.71.71A1 1 0 1 1 6.34 7.76l-.71-.71a1 1 0 0 1 0-1.41ZM12 20a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1Z"/></svg>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity mt-1" style="color:#4ADE80" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1" style="color:color-mix(in srgb,#4ADE80,transparent 25%)">Renewable</p>
            <p id="assess-solar-value" class="font-display font-bold text-3xl leading-tight mb-2" style="color:#4ADE80">—</p>
            <p class="text-xs leading-relaxed" style="color:color-mix(in srgb,#4ADE80,transparent 35%)">Solar panel capacity to offset your monthly consumption.</p>
          </div>
          <div class="flex items-center gap-1.5 text-xs font-semibold" style="color:color-mix(in srgb,#4ADE80,transparent 20%)">
            View Details
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" aria-hidden="true"><path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.03a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
          </div>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="box-shadow:inset 0 0 0 1.5px color-mix(in srgb,#4ADE80,transparent 42%)"></div>
        </a>

      </div>
      <p class="mt-4 text-xs text-text-muted leading-relaxed opacity-80">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 inline mr-1 mb-0.5" style="color:var(--warning)" aria-hidden="true"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/></svg>
        Estimates based on single-phase 230V supply. Always consult a licensed electrician before purchasing or installing electrical components.
      </p>
    </section>

    <!-- S4: Consumption Analysis -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-[10px] font-mono uppercase tracking-widest text-text-muted flex-shrink-0">03</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="text-lg font-display font-bold text-text-primary uppercase tracking-wide flex-shrink-0">Consumption Analysis</h2>
        <div class="flex-1 h-px bg-border"></div>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Donut chart -->
        <div class="rounded-xl border border-border bg-card p-6">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted mb-4">Distribution by Category</p>
          <div class="flex items-center gap-6">
            <div class="flex-shrink-0 relative" style="width:160px; height:160px;">
              <svg id="assess-donut-svg" viewBox="0 0 100 100" class="w-full h-full" style="transform:rotate(-90deg);" aria-hidden="true">
                <circle cx="50" cy="50" r="35" fill="none" stroke="var(--toggle-off)" stroke-width="9"/>
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none text-center px-2">
                <div id="assess-donut-center-default">
                  <span id="assess-donut-kwh" class="font-display font-bold text-lg tabular-nums leading-tight" style="color:var(--accent)">0.0</span>
                  <span class="block text-[10px] font-mono text-text-muted leading-tight mt-0.5">kWh/day</span>
                </div>
                <div id="assess-donut-center-hover" style="display:none">
                  <span id="assess-donut-hover-pct" class="font-display font-bold text-xl tabular-nums leading-tight" style="color:var(--accent)">0%</span>
                  <span id="assess-donut-hover-kwh" class="block text-[10px] font-mono text-text-muted leading-tight mt-0.5">0 kWh</span>
                </div>
              </div>
            </div>
            <div id="assess-donut-legend" class="flex-1 min-w-0 space-y-1"></div>
          </div>
