<script>
import type { Appliance } from '@/types';
import { SECTIONS } from '@/data/appliances';
import { calculateTotals, calculateRowKWh } from '@/utils/calculations';
import { calculateInsights } from '@/utils/insights';
import { calculateHealthScore, calculateCategoryBreakdown, generateSavingsTips, getHighConsumptionAlerts } from '@/utils/health';

const STORAGE_KEY = 'electricity_load_calculator_state';

function setText(id: string, val: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

function escapeHtml(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

function formatNumber(val: number, decimals = 0): string {
  return new Intl.NumberFormat(navigator.language || 'en', {
    minimumFractionDigits: decimals,
    maximumFractionDigits: decimals,
  }).format(val);
}

let bdItems: Array<{ category: string; kWhDay: number; percent: number; color: string }> = [];

function highlightSlice(idx: number) {
  const item = bdItems[idx];
  if (!item) return;
  document.querySelectorAll<SVGElement>('#assess-donut-svg .assess-slice').forEach((s, i) => {
    s.style.opacity = i === idx ? '1' : '0.18';
    s.setAttribute('stroke-width', i === idx ? '12' : '9');
  });
  document.querySelectorAll<HTMLElement>('#assess-donut-legend .assess-leg-row').forEach((r, i) => {
    r.style.opacity = i === idx ? '1' : '0.35';
  });
  const def = document.getElementById('assess-donut-center-default');
  const hov = document.getElementById('assess-donut-center-hover');
  const pct = document.getElementById('assess-donut-hover-pct');
  const kwh = document.getElementById('assess-donut-hover-kwh');
  if (def) def.style.display = 'none';
  if (hov) hov.style.display = '';
  if (pct) { pct.textContent = `${Math.round(item.percent)}%`; pct.style.color = item.color; }
  if (kwh) kwh.textContent = `${item.kWhDay.toFixed(1)} kWh(unit)`;
}

function resetSlices() {
  document.querySelectorAll<SVGElement>('#assess-donut-svg .assess-slice').forEach(s => {
    s.style.opacity = '1'; s.setAttribute('stroke-width', '9');
  });
  document.querySelectorAll<HTMLElement>('#assess-donut-legend .assess-leg-row').forEach(r => { r.style.opacity = '1'; });
  const def = document.getElementById('assess-donut-center-default');
  const hov = document.getElementById('assess-donut-center-hover');
  if (def) def.style.display = '';
  if (hov) hov.style.display = 'none';
}

function initAssessment() {
  const loadingEl = document.getElementById('assess-loading');
  const emptyEl   = document.getElementById('assess-empty');
  const contentEl = document.getElementById('assess-content');

  function showEmpty() {
    if (loadingEl) loadingEl.style.display = 'none';
    if (emptyEl)   emptyEl.style.display   = '';
    if (contentEl) contentEl.style.display = 'none';
  }

  const saved = localStorage.getItem(STORAGE_KEY);
  if (!saved) { showEmpty(); return; }

  let state: { appliances: Appliance[]; tariff?: number; currentCurrency?: string; maxCapacityKW?: number } | null = null;
  try { state = JSON.parse(saved); } catch { showEmpty(); return; }

  const appliances: Appliance[] = state?.appliances ?? [];
  if (!Array.isArray(appliances) || !appliances.some(a => a.qty > 0)) { showEmpty(); return; }

  const tariff      = typeof state?.tariff      === 'number' && state.tariff      > 0 ? state.tariff      : 0;
  const maxCapacity = typeof state?.maxCapacityKW === 'number' && state.maxCapacityKW > 0 ? state.maxCapacityKW : 5;

  // ── Run all calculations ──────────────────────────────────
  const result   = calculateTotals(appliances, tariff, maxCapacity);
  const insights = calculateInsights(result.totalKW, result.monthlyKWh);

  const active = appliances.filter(a => a.qty > 0);
  const topApp = active.reduce<Appliance | null>((best, a) =>
    !best || (a.watts * a.qty * a.hours) > (best.watts * best.qty * best.hours) ? a : best, null);
  const topConsumerDailyKWh = topApp
    ? (topApp.watts * topApp.qty * Math.min(24, topApp.hours)) / 1000 : 0;

  const health    = calculateHealthScore({ loadPercent: result.loadPercent, dailyKWh: result.dailyKWh, topConsumerDailyKWh, monthlyKWh: result.monthlyKWh, hasMCB: insights.mcbAmps > 0, hasCable: true });
  const breakdown = calculateCategoryBreakdown(appliances);
  const savings   = generateSavingsTips(appliances, result.monthlyKWh);
  const alerts    = getHighConsumptionAlerts(appliances, result.dailyKWh);

  // ── Show content ──────────────────────────────────────────
  if (loadingEl) loadingEl.style.display = 'none';
  if (emptyEl)   emptyEl.style.display   = 'none';
  if (contentEl) contentEl.style.display = '';

  // ── S1: Timestamp ─────────────────────────────────────────
  setText('assess-timestamp', new Date().toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' }));

  // ── S2: Load Summary ──────────────────────────────────────
  setText('assess-total-kw',         result.totalKW.toFixed(2));
  setText('assess-daily-kwh',        result.dailyKWh.toFixed(2));
  setText('assess-monthly-kwh',      Math.round(result.monthlyKWh).toString());
  setText('assess-top-consumer-name',result.topConsumerName);
  setText('assess-top-consumer-watts', result.topConsumerWatts > 0 ? `${result.topConsumerWatts} W` : '—');
  setText('assess-health-score-summary', health.score.toString());
  const hlSummary = document.getElementById('assess-health-label-summary');
  if (hlSummary) { hlSummary.textContent = `/ 100 · ${health.label}`; hlSummary.style.color = health.color; }
  const kwEl = document.getElementById('assess-health-score-summary');
  if (kwEl) kwEl.style.color = health.color;

  // ── S3: Recommendations ───────────────────────────────────
  setText('assess-mcb-value',      insights.recommendedMCB);
  setText('assess-cable-value',    insights.recommendedCable);
  setText('assess-inverter-value', insights.recommendedInverter);
  setText('assess-solar-value',    insights.recommendedSolar);
  setText('assess-stabilizer-value', insights.recommendedStabilizer);

  // ── S4: Consumption Analysis ──────────────────────────────
  if (breakdown.items.length > 0) {
    bdItems = breakdown.items;
    setText('assess-donut-kwh', result.dailyKWh.toFixed(1));

    const R = 35, C = 2 * Math.PI * R;
    const svgEl = document.getElementById('assess-donut-svg');
    if (svgEl) {
      svgEl.querySelectorAll('.assess-slice').forEach(s => s.remove());
      let acc = 0;
      breakdown.items.forEach((item, idx) => {
        const dashLen = (item.percent / 100) * C;
        const circle  = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('cx', '50'); circle.setAttribute('cy', '50');
        circle.setAttribute('r', String(R)); circle.setAttribute('fill', 'none');
        circle.setAttribute('stroke', item.color); circle.setAttribute('stroke-width', '9');
        circle.setAttribute('stroke-dasharray', `${dashLen} ${C}`);
        circle.setAttribute('stroke-dashoffset', String(-acc));
        circle.setAttribute('pointer-events', 'visibleStroke');
        circle.classList.add('assess-slice');
        circle.style.cursor = 'pointer';
        circle.style.transition = 'opacity 0.2s ease';
        circle.addEventListener('mouseenter', () => highlightSlice(idx));
        circle.addEventListener('mouseleave', resetSlices);
        svgEl.appendChild(circle);
        acc += dashLen;
      });
    }

    const legend = document.getElementById('assess-donut-legend');
    if (legend) {
      legend.innerHTML = breakdown.items.map((item, idx) => `
        <div class="assess-leg-row flex items-center gap-2 min-w-0 cursor-pointer rounded-md px-1.5 py-1 transition-all hover:bg-white/5" data-li="${idx}">
          <span class="flex-shrink-0 w-2.5 h-2.5 rounded-sm" style="background:${item.color}"></span>
          <span class="text-[11px] text-text-muted truncate flex-1">${item.category}</span>
          <div class="flex-shrink-0 text-right">
            <div class="text-[11px] font-mono font-bold tabular-nums" style="color:${item.color}">${Math.round(item.percent)}%</div>
            <div class="text-[9px] font-mono text-text-muted">${item.kWhDay.toFixed(1)} kWh</div>
          </div>
        </div>`).join('');
      legend.querySelectorAll<HTMLElement>('.assess-leg-row').forEach(row => {
        const i = Number(row.dataset.li);
        row.addEventListener('mouseenter', () => highlightSlice(i));
        row.addEventListener('mouseleave', resetSlices);
      });
    }

    const topColor   = breakdown.items[0]?.color ?? 'var(--accent)';
    const insightBox = document.getElementById('assess-breakdown-insight');
    const insightDot = document.getElementById('assess-breakdown-dot');
    const insightLbl = document.getElementById('assess-breakdown-label');
    if (insightBox) { insightBox.style.background = `color-mix(in srgb, ${topColor}, transparent 95%)`; insightBox.style.borderColor = `color-mix(in srgb, ${topColor}, transparent 84%)`; }
    if (insightDot) insightDot.style.color = topColor;
    if (insightLbl) { insightLbl.textContent = `${breakdown.topCategory} · ${Math.round(breakdown.topPercent)}% of total daily usage`; insightLbl.style.color = topColor; }

    const table = document.getElementById('assess-breakdown-table');
    if (table) {
      table.innerHTML = `
        <div class="flex text-[10px] font-bold uppercase tracking-widest py-2 mb-1 border-b-2 border-border text-text-muted">
          <span class="flex-1">Category</span><span class="w-28 text-right">kWh / day</span><span class="w-16 text-right">Share</span>
        </div>
        ${breakdown.items.map(item => `
          <div class="flex items-center text-sm py-2.5 border-b border-border/40 last:border-0">
            <div class="flex items-center gap-2 flex-1 min-w-0">
              <span class="w-2.5 h-2.5 rounded-sm flex-shrink-0" style="background:${item.color}"></span>
              <span class="text-text-muted truncate">${item.category}</span>
            </div>
            <span class="w-28 text-right font-mono text-text-primary">${item.kWhDay.toFixed(2)}</span>
            <span class="w-16 text-right font-mono font-semibold" style="color:${item.color}">${Math.round(item.percent)}%</span>
          </div>`).join('')}`;
    }
  }

  // ── S5: Health Score ──────────────────────────────────────
  const C_RING = 2 * Math.PI * 64;
  const ringEl = document.getElementById('assess-health-ring') as SVGCircleElement | null;
  if (ringEl) { ringEl.style.stroke = health.color; ringEl.style.strokeDashoffset = String(C_RING * (1 - health.score / 100)); }

  const hvEl = document.getElementById('assess-health-score-value');
  if (hvEl) { hvEl.textContent = health.score.toString(); hvEl.style.color = health.color; }

  const hlEl = document.getElementById('assess-health-label');
  if (hlEl) { hlEl.textContent = health.label; hlEl.style.color = health.color; hlEl.style.background = `color-mix(in srgb, ${health.color}, transparent 85%)`; hlEl.style.borderColor = `color-mix(in srgb, ${health.color}, transparent 55%)`; }

  const HEALTH_DESC: Record<string, string> = {
    'Excellent': 'Your electrical setup is well-balanced, efficient, and ready for expansion.',
    'Good':      'Good setup with minor improvements possible. Review sub-scores for guidance.',
    'Fair':      'Several improvements recommended to optimise safety and efficiency.',
    'Poor':      'Significant improvements needed. Consider consulting an electrician.',
  };
  setText('assess-health-desc', HEALTH_DESC[health.label] ?? '');

  const { utilization, efficiency, safety, renewable } = health.subScores;
  const setBar = (id: string, pct: number) => { const el = document.getElementById(id); if (el) el.style.width = `${pct}%`; };
  setText('assess-sub-util-pts',   `${utilization}/30`);
  setText('assess-sub-eff-pts',    `${efficiency}/30`);
  setText('assess-sub-safety-pts', `${safety}/20`);
  setText('assess-sub-renew-pts',  `${renewable}/20`);
  setBar('assess-sub-util-bar',   (utilization / 30) * 100);
  setBar('assess-sub-eff-bar',    (efficiency  / 30) * 100);
  setBar('assess-sub-safety-bar', (safety      / 20) * 100);
  setBar('assess-sub-renew-bar',  (renewable   / 20) * 100);

  // ── S6: Alerts (conditional) ──────────────────────────────
  const alertsSection = document.getElementById('assess-alerts-section');
  const alertsList    = document.getElementById('assess-alerts-list');
  if (alerts.length > 0 && alertsSection && alertsList) {
    alertsSection.style.display = '';
    alertsList.innerHTML = alerts.map(a => `
      <div class="flex items-center justify-between gap-4 rounded-lg px-4 py-3 bg-card border" style="border-color:color-mix(in srgb, var(--danger), transparent 65%)">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0" style="color:var(--danger)"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/></svg>
          <div>
            <p class="text-sm font-semibold text-text-primary">${a.name}</p>
            <p class="text-xs text-text-muted">${a.reason}</p>
          </div>
        </div>
        <div class="text-right flex-shrink-0">
          <p class="text-sm font-mono font-bold" style="color:var(--danger)">${a.kWhDay.toFixed(1)}</p>
          <p class="text-xs font-mono text-text-muted">${Math.round(a.percent)}% of total</p>
        </div>
      </div>`).join('');

    // Re-number subsequent sections
    setText('assess-saving-num', '06');
    setText('assess-cost-num',   '07');
    setText('assess-dl-num',     '08');
  } else {
    if (alertsSection) alertsSection.style.display = 'none';
    setText('assess-saving-num', '05');
    setText('assess-cost-num',   '06');
    setText('assess-dl-num',     '07');
  }

  // ── S7: Saving tips ───────────────────────────────────────
  setText('assess-saving-top',      savings.topConsumerName);
  setText('assess-saving-potential', `${savings.potentialSavings.toFixed(1)} kWh(unit)/month`);
  const tipsList = document.getElementById('assess-saving-tips');
  if (tipsList) {
    tipsList.innerHTML = savings.tips.map(tip => `
      <li class="flex items-start gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0 mt-0.5 text-accent"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd"/></svg>
        <span class="text-xs text-text-muted leading-relaxed">${tip}</span>
      </li>`).join('');
  }

  // ── S8: Cost Estimator ────────────────────────────────────
  setText('assess-est-monthly-kwh', Math.round(result.monthlyKWh).toString());

  // Populate from saved state
  const currencySelect = document.getElementById('assess-currency') as HTMLSelectElement | null;
  const rateInput = document.getElementById('assess-rate') as HTMLInputElement | null;
  
  if (currencySelect && state?.currentCurrencySymbol) {
    currencySelect.value = state.currentCurrencySymbol;
  }
  if (rateInput && tariff > 0) {
    rateInput.value = tariff.toString();
  }

  function updateCost() {
    const sym  = currencySelect?.value ?? '$';
    const rate = parseFloat(rateInput?.value ?? '');
    const subsidy = parseFloat((document.getElementById('assess-subsidy') as HTMLInputElement)?.value ?? '0') || 0;
    const resEl = document.getElementById('assess-est-result');
    if (!resEl) return;

    // Save to localStorage
    try {
      const currentSaved = localStorage.getItem(STORAGE_KEY);
      if (currentSaved) {
        const currentState = JSON.parse(currentSaved);
        currentState.tariff = rate || 0;
        currentState.currentCurrencySymbol = sym;
        currentState.subsidyUnits = subsidy;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(currentState));
      }
    } catch (e) {}

    const billableUnits = Math.max(0, result.monthlyKWh - subsidy);

    // 1. UPDATE COST ESTIMATOR CARD (STRIKETHROUGH PATTERN)
    const estOrigEl = document.getElementById('assess-est-monthly-kwh-original');
    const estTitle  = document.getElementById('assess-est-monthly-title');
    const estSub    = document.getElementById('assess-est-monthly-subtitle');
    
    setText('assess-est-monthly-kwh', Math.round(billableUnits).toString());
    
    if (subsidy > 0) {
      if (estOrigEl) {
        estOrigEl.textContent = Math.round(result.monthlyKWh).toString();
        estOrigEl.classList.remove('hidden');
      }
      if (estTitle) estTitle.textContent = 'Billable Usage (after subsidy)';
      if (estSub)   estSub.textContent   = `Total ${Math.round(result.monthlyKWh)} minus ${Math.round(subsidy)} subsidy`;
    } else {
      if (estOrigEl) estOrigEl.classList.add('hidden');
      if (estTitle) estTitle.textContent = 'Monthly Usage';
      if (estSub)   estSub.textContent   = 'Total units consumed';
    }

    // 2. UPDATE LOAD SUMMARY (TOTAL USAGE ONLY)
    setText('assess-monthly-kwh', Math.round(result.monthlyKWh).toString());
    const summaryOrigEl = document.getElementById('assess-monthly-kwh-original');
    const summaryLabel  = document.getElementById('assess-monthly-label');
    if (summaryOrigEl) summaryOrigEl.classList.add('hidden');
    if (summaryLabel)  summaryLabel.textContent = 'kWh(unit) per month';

    if (!rate || rate <= 0) {
      resEl.style.display = 'none';
      const pCost = document.getElementById('aprint-cost-estimator');
      if (pCost) pCost.style.display = 'none';
      return;
    }

    const fmt = (v: number) => `${sym}${v.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

    setText('assess-est-daily',   fmt((billableUnits * rate) / 30));
    setText('assess-est-monthly', fmt(billableUnits * rate));
    setText('assess-est-yearly',  fmt(billableUnits * rate * 12));
    resEl.style.display = '';

    // 3. UPDATE PRINT LAYOUT COST FIELDS
    const pCost = document.getElementById('aprint-cost-estimator');
    if (pCost) {
      pCost.style.display = '';
      setText('aprint-cost-rate',        `${sym}${rate}/kWh(unit)`);
      setText('aprint-estimated-cost',   fmt(billableUnits * rate));
      setText('aprint-cost-daily',        `${fmt((billableUnits * rate) / 30)} / day`);
      setText('aprint-cost-yearly',       `${fmt(billableUnits * rate * 12)} / year`);
      
      const billableEl = document.getElementById('aprint-cost-billable');
      const origEl     = document.getElementById('aprint-cost-monthly-kwh-original');
      const noteEl     = document.getElementById('aprint-cost-subsidy-note');
      
      if (billableEl) billableEl.textContent = Math.round(billableUnits).toString();
      
      if (subsidy > 0) {
        if (origEl) {
          origEl.textContent = Math.round(result.monthlyKWh).toString();
          origEl.classList.remove('hidden');
        }
        if (noteEl) {
          noteEl.textContent = `Includes ${Math.round(subsidy)} kWh(unit) subsidy reduction`;
          noteEl.classList.remove('hidden');
        }
      } else {
        if (origEl) origEl.classList.add('hidden');
        if (noteEl) noteEl.classList.add('hidden');
      }
    }

    // 4. UPDATE PRINT EXECUTIVE SUMMARY & ANALYSIS (TOTAL USAGE)
    setText('aprint-monthly-kwh',  Math.round(result.monthlyKWh).toString());
    setText('aprint-analysis-monthly', Math.round(result.monthlyKWh).toString());
    const pSummaryOrigEl = document.getElementById('aprint-monthly-kwh-original');
    if (pSummaryOrigEl) pSummaryOrigEl.classList.add('hidden');
  }
  document.getElementById('assess-currency')?.addEventListener('change', updateCost);
  document.getElementById('assess-rate')?.addEventListener('input', updateCost);
  document.getElementById('assess-subsidy')?.addEventListener('input', updateCost);

  // ── Print layout ──────────────────────────────────────────
  const operatingCurrent = result.totalWatts / 230;

  setText('aprint-total-kw',     result.totalKW.toFixed(2));
  setText('aprint-daily-kwh',    formatNumber(result.dailyKWh, 2));
  setText('aprint-monthly-kwh',  String(Math.round(result.monthlyKWh)));
  
  const now = new Date();
  const dateStr = now.toLocaleDateString(navigator.language || 'en', { dateStyle: 'long' });
  setText('aprint-date', dateStr);
  setText('aprint-date-cover', dateStr);
  setText('aprint-date-final', dateStr);

  // Enhancement 4: Report Metadata
  const localDate = new Date();
  const year = localDate.getFullYear();
  const month = String(localDate.getMonth() + 1).padStart(2, '0');
  const day = String(localDate.getDate()).padStart(2, '0');
  const reportId = `ELC-${year}${month}${day}-${Math.floor(Math.random() * 90000 + 10000)}`;
  
  setText('aprint-report-id', reportId);
  setText('aprint-report-id-cover', reportId);
  setText('aprint-report-id-final', reportId);
  const version = document.getElementById('footer-platform-version')?.textContent?.trim() || 'v1.0.4';
  setText('aprint-platform-version', version);
  setText('aprint-platform-version-final', version);

  const siteUrl = window.location.origin;
  document.querySelectorAll<HTMLElement>('.print-brand-url').forEach(el => {
    el.innerHTML = '<a href="https://electricityloadcalculator.com" style="color:var(--accent) !important;text-decoration:underline;">electricityloadcalculator.com</a>';
  });

  // KPI & Matrix
  setText('aprint-health-score', String(health.score));
  setText('aprint-health-score-large', String(health.score));
  setText('aprint-health-label', health.label);
  
  setText('aprint-analysis-load', result.totalKW.toFixed(2));
  setText('aprint-analysis-daily', result.dailyKWh.toFixed(2));
  setText('aprint-analysis-monthly', Math.round(result.monthlyKWh).toString());
  setText('aprint-analysis-current', operatingCurrent.toFixed(1));

  setText('aprint-matrix-mcb', insights.recommendedMCB);
  setText('aprint-matrix-cable', insights.recommendedCable);
  setText('aprint-matrix-inverter', insights.recommendedInverter);
  setText('aprint-matrix-solar', insights.recommendedSolar);
  setText('aprint-matrix-stabilizer', insights.recommendedStabilizer);

  // Detailed
  setText('aprint-det-mcb', insights.recommendedMCB);
  setText('aprint-det-mcb-load', result.totalKW.toFixed(2));
  setText('aprint-det-mcb-curr', operatingCurrent.toFixed(1));

  setText('aprint-det-cable', insights.recommendedCable);
  setText('aprint-det-cab-curr', operatingCurrent.toFixed(1));
  setText('aprint-det-cab-mcb', insights.recommendedMCB);

  setText('aprint-det-inverter', insights.recommendedInverter);
  setText('aprint-det-inv-load', result.totalKW.toFixed(2));
  setText('aprint-det-inv-req', (result.totalKW * 1.2).toFixed(2));

  setText('aprint-det-solar', insights.recommendedSolar);
  setText('aprint-det-sol-units', Math.round(result.monthlyKWh).toString());

  setText('aprint-det-stabilizer', insights.recommendedStabilizer);
  setText('aprint-det-stab-load', result.totalKW.toFixed(2));
  setText('aprint-det-stab-req', (result.totalKW * 1.3).toFixed(2));

  // Verdict Logic
  const verdictList = document.getElementById('aprint-verdict-findings');
  if (verdictList) {
    const findings = [];
    if (result.loadPercent < 50) findings.push('✓ Electrical load is within normal residential range.');
    else if (result.loadPercent < 80) findings.push('✓ Electrical load is moderate but within safe operating limits.');
    else findings.push('⚠ High load density detected; ensure main breaker is rated correctly.');

    findings.push('✓ Existing electrical sizing recommendations are suitable for your load profile.');
    
    if (health.subScores.renewable > 10) findings.push('✓ Solar adoption is highly feasible based on consumption units.');
    if (result.totalKW > 2) findings.push('✓ Inverter backup planning is recommended for essential services.');
    
    if (breakdown.items[0]) {
      findings.push(`⚠ ${breakdown.items[0].category} contributes significant energy usage (${Math.round(breakdown.items[0].percent)}%).`);
    }
    findings.push('⚠ Energy optimization opportunities identified in your consumption profile.');

    verdictList.innerHTML = findings.map(f => `<li>${f}</li>`).join('');
  }

  setText('aprint-health-desc-p', HEALTH_DESC[health.label] ?? '');
  const printDetails = document.getElementById('aprint-health-details-p');
  const sub = health.subScores;
  if (printDetails) {
    printDetails.innerHTML = `
      <div class="space-y-1"><p class="text-[10px] text-text-muted uppercase font-bold">Load Utilization</p><div class="flex items-center gap-4"><div class="flex-1 h-1.5 bg-border/40 rounded-full overflow-hidden"><div class="h-full bg-accent" style="width:${(sub.utilization/30)*100}%"></div></div><span class="text-xs font-mono font-bold">${sub.utilization}/30</span></div></div>
      <div class="space-y-1"><p class="text-[10px] text-text-muted uppercase font-bold">Energy Efficiency</p><div class="flex items-center gap-4"><div class="flex-1 h-1.5 bg-border/40 rounded-full overflow-hidden"><div class="h-full bg-accent" style="width:${(sub.efficiency/30)*100}%"></div></div><span class="text-xs font-mono font-bold">${sub.efficiency}/30</span></div></div>
      <div class="space-y-1"><p class="text-[10px] text-text-muted uppercase font-bold">Safety Readiness</p><div class="flex items-center gap-4"><div class="flex-1 h-1.5 bg-border/40 rounded-full overflow-hidden"><div class="h-full bg-accent" style="width:${(sub.safety/20)*100}%"></div></div><span class="text-xs font-mono font-bold">${sub.safety}/20</span></div></div>
      <div class="space-y-1"><p class="text-[10px] text-text-muted uppercase font-bold">Solar Readiness</p><div class="flex items-center gap-4"><div class="flex-1 h-1.5 bg-border/40 rounded-full overflow-hidden"><div class="h-full bg-accent" style="width:${(sub.renewable/20)*100}%"></div></div><span class="text-xs font-mono font-bold">${sub.renewable}/20</span></div></div>
    `;
  }

  // V3 Explainability Logic
  const reasons = [];
  const improvements = [];
  let potentialGain = 0;

  // Load Utilization Analysis
  if (sub.utilization < 30) {
    const deduction = 30 - sub.utilization;
    if (result.loadPercent > 80) {
      reasons.push(`<li class="flex items-start gap-2"><span class="text-danger font-bold">⚠</span><span><strong>Load Utilization:</strong> High connected load concentration near maximum capacity reduced the score by ${deduction} points.</span></li>`);
      improvements.push(`<li class="flex items-start gap-2"><span class="text-accent font-bold">✓</span><span><strong>Improve Load Balance:</strong> Avoid simultaneous operation of high-load devices (e.g., AC and Geyser together).</span></li>`);
    } else if (result.loadPercent < 20) {
      reasons.push(`<li class="flex items-start gap-2"><span class="text-warning font-bold">⚠</span><span><strong>Load Utilization:</strong> Very low utilization of sanctioned capacity resulted in a ${deduction} point deduction.</span></li>`);
      improvements.push(`<li class="flex items-start gap-2"><span class="text-accent font-bold">✓</span><span><strong>Improve Load Balance:</strong> Consider downgrading sanctioned load if future expansion is not planned to save on fixed charges.</span></li>`);
    }
    potentialGain += deduction;
  } else {
    reasons.push(`<li class="flex items-start gap-2"><span class="text-success font-bold">✓</span><span class="text-text-muted"><strong>Load Utilization:</strong> Load is optimally balanced. Full points awarded.</span></li>`);
  }

  // Energy Efficiency Analysis
  if (sub.efficiency < 30) {
    const deduction = 30 - sub.efficiency;
    reasons.push(`<li class="flex items-start gap-2"><span class="text-warning font-bold">⚠</span><span><strong>Energy Efficiency:</strong> Specific appliances contribute disproportionately to total energy use, causing a ${deduction} point deduction.</span></li>`);
    improvements.push(`<li class="flex items-start gap-2"><span class="text-accent font-bold">✓</span><span><strong>Improve Energy Efficiency:</strong> Replace older models of the top consumer (${result.topConsumerName}) with BEE 5-star rated equivalents.</span></li>`);
    improvements.push(`<li class="flex items-start gap-2"><span class="text-accent font-bold">✓</span><span><strong>Improve Energy Efficiency:</strong> Reduce unnecessary standby consumption by unplugging devices when not in use.</span></li>`);
    potentialGain += deduction;
  } else {
    reasons.push(`<li class="flex items-start gap-2"><span class="text-success font-bold">✓</span><span class="text-text-muted"><strong>Energy Efficiency:</strong> Energy distribution is efficient. Full points awarded.</span></li>`);
  }
  
  // Safety & Solar Readiness
  if (sub.safety === 20) {
     reasons.push(`<li class="flex items-start gap-2"><span class="text-success font-bold">✓</span><span class="text-text-muted"><strong>Safety Readiness:</strong> Electrical recommendations are within acceptable residential standards. No major safety concerns detected.</span></li>`);
  }
  if (sub.renewable === 20) {
     reasons.push(`<li class="flex items-start gap-2"><span class="text-success font-bold">✓</span><span class="text-text-muted"><strong>Solar Readiness:</strong> Current energy profile is highly suitable for solar integration.</span></li>`);
  } else {
     const deduction = 20 - sub.renewable;
     reasons.push(`<li class="flex items-start gap-2"><span class="text-warning font-bold">⚠</span><span><strong>Solar Readiness:</strong> Low monthly consumption reduces the immediate ROI of a solar installation (-${deduction} points).</span></li>`);
     improvements.push(`<li class="flex items-start gap-2"><span class="text-accent font-bold">✓</span><span><strong>Improve Solar Readiness:</strong> Monitor monthly energy usage trends before considering solar installation.</span></li>`);
     potentialGain += deduction;
  }

  const printReasons = document.getElementById('aprint-health-reasons-p');
  if (printReasons) printReasons.innerHTML = reasons.join('');
  
  const printImprovements = document.getElementById('aprint-health-improvements-p');
  if (printImprovements) printImprovements.innerHTML = improvements.length > 0 ? improvements.join('') : '<li class="text-text-muted italic">Your system is highly optimized. Maintain current usage patterns.</li>';

  // Calculate potential score
  const potentialScore = Math.min(100, health.score + Math.round(potentialGain * 0.8));
  setText('aprint-health-potential-score-p', `${potentialScore} / 100`);

  const printBreakdown = document.getElementById('aprint-breakdown-table');
  if (printBreakdown) {
    printBreakdown.innerHTML = breakdown.items.map(item => `
      <div class="flex text-sm py-1.5 border-b border-border last:border-0">
        <span class="flex-1 text-text-muted">${item.category}</span>
        <span class="w-32 text-right font-mono">${item.kWhDay.toFixed(2)}</span>
        <span class="w-20 text-right font-mono font-semibold" style="color:var(--accent)">${Math.round(item.percent)}%</span>
      </div>`).join('');
  }
  
  if (breakdown.items.length > 0) {
      setText('aprint-consumption-observation', `${breakdown.topCategory} contributes ${Math.round(breakdown.topPercent)}% of total energy consumption, representing the largest optimization opportunity.`);
  }

  const printList = document.getElementById('aprint-appliances-list');
  if (printList) {
    let html = `
      <div class="flex text-[10px] font-bold uppercase tracking-widest py-2 mb-1 border-b-2 border-border text-text-muted">
        <span class="flex-1 text-text-primary">Home Appliance</span>
        <span class="w-24 text-right text-text-primary">kWh(unit)/day</span>
      </div>
    `;
    let totalQty = 0;
    let totalKWh = 0;

    SECTIONS.forEach(section => {
      const sectionItems = active.filter(a => section.categories.includes(a.category));
      if (sectionItems.length > 0) {
        html += `<div class="pt-2"><h3 class="text-[10px] font-bold uppercase tracking-widest mb-2 border-l-2 pl-2" style="color:#F4A826; border-color:#F4A826">${section.title}</h3><div class="space-y-1">`;
        section.categories.forEach(cat => {
          const catItems = sectionItems.filter(a => a.category === cat);
          if (catItems.length > 0) {
            catItems.forEach(a => {
              const rowKWh = calculateRowKWh(a);
              totalQty += a.qty;
              totalKWh += rowKWh;
              html += `
                <div class="flex justify-between items-center text-[11px] py-0.5 border-b border-border/10 last:border-0">
                  <div class="flex-1">
                    <span class="font-medium text-text-primary">${escapeHtml(a.name)}</span>
                    <span class="text-text-muted ml-2 text-[9px]">${a.qty} × ${a.watts}W</span>
                  </div>
                  <div class="text-right font-mono font-medium text-text-primary">${rowKWh.toFixed(2)}</div>
                </div>`;
            });
          }
        });
        html += `</div></div>`;
      }
    });

    // Add Total Row
    html += `
      <div class="mt-4 pt-3 border-t-2 border-border flex justify-between items-center">
        <div class="flex-1">
          <p class="text-[10px] font-bold uppercase tracking-widest text-text-primary">Total Daily Consumption</p>
          <p class="text-[9px] text-text-muted mt-0.5">${totalQty} Active Appliances</p>
        </div>
        <div class="text-right">
          <p class="text-lg font-bold font-mono text-accent">${totalKWh.toFixed(2)}</p>
          <p class="text-[8px] font-bold uppercase tracking-tighter text-text-muted">kWh(unit)/day</p>
        </div>
      </div>
    `;

    printList.innerHTML = html || '<p class="text-text-muted italic">No active appliances selected.</p>';
  }

  setText('aprint-opt-priority', health.score > 80 ? 'Low' : (health.score > 50 ? 'Medium' : 'High'));
  setText('aprint-opt-target', savings.topConsumerName);
  setText('aprint-opt-impact', `${savings.potentialSavings.toFixed(1)} kWh(unit)/mo`);

  const printSaving = document.getElementById('aprint-saving-tips-p');
  if (printSaving) {
    printSaving.innerHTML = savings.tips.map(tip => `
      <div class="flex items-start gap-2 text-sm text-text-muted"><span class="text-accent font-bold">✓</span><span>${tip}</span></div>
    `).join('');
  }

  // Action Plan
  const actionPlan = document.getElementById('aprint-action-plan');
  if (actionPlan) {
    const topAppObj = appliances.filter(a => a.qty > 0).sort((a,b) => calculateRowKWh(b) - calculateRowKWh(a))[0];
    actionPlan.innerHTML = `
      <div class="space-y-4">
        <p class="text-xs font-bold uppercase tracking-widest text-accent">Immediate</p>
        <ul class="text-xs space-y-2 text-text-primary">
          <li>✓ Review ${topAppObj?.name || 'top appliance'} usage patterns</li>
          <li>✓ Implement standby power reduction</li>
          <li>✓ Verify MCB & Cable sizes with electrician</li>
        </ul>
      </div>
      <div class="space-y-4 border-l border-border pl-6">
        <p class="text-xs font-bold uppercase tracking-widest text-accent">Short-Term</p>
        <ul class="text-xs space-y-2 text-text-primary">
          <li>✓ Consider inverter sizing for backup</li>
          <li>✓ Improve energy efficiency of lighting</li>
          <li>✓ Monitor weekly unit consumption</li>
        </ul>
      </div>
      <div class="space-y-4 border-l border-border pl-6">
        <p class="text-xs font-bold uppercase tracking-widest text-accent">Long-Term</p>
        <ul class="text-xs space-y-2 text-text-primary">
          <li>✓ Evaluate rooftop solar installation</li>
          <li>✓ Upgrade to 5-star rated appliances</li>
          <li>✓ Plan for future expansion capacity</li>
        </ul>
      </div>
    `;
  }
  
  // Initial cost update
  updateCost();

  // ── Mobile Scroll Glow Effect (IntersectionObserver) ──
  if (window.matchMedia('(hover: none)').matches) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('mobile-visible');
        } else {
          entry.target.classList.remove('mobile-visible');
        }
      });
    }, {
      rootMargin: '-15% 0px -15% 0px', // Center 70% trigger
      threshold: 0.4
    });

    document.querySelectorAll('.rec-card, section .bg-card').forEach(card => observer.observe(card));
  }
}

// ── Global Event Delegation ───────────────────────────────
document.addEventListener('click', (e) => {
  const target = e.target as HTMLElement;
  const action = target.dataset.action || target.closest('[data-action]')?.getAttribute('data-action');
  const shareType = target.id || target.closest('button')?.id;

  if (action === 'print-report') {
    e.preventDefault();
    e.stopImmediatePropagation();
    const originalTitle = document.title;
    const dateStr = new Date().toISOString().split('T')[0];
    document.title = `electricity-load-calculator-assessment-report-${dateStr}`;
    window.print();
    document.title = originalTitle;
    return;
  }

  // Social Sharing Logic
  if (shareType && shareType.startsWith('share-')) {
    const score = document.getElementById('assess-health-score-summary')?.textContent || '0';
    const label = document.getElementById('assess-health-label')?.textContent || 'Check out my score';
    const url = window.location.origin;
    const text = `I just assessed my home's Electrical Health! My score is ${score}/100 (${label}). Calculate your home load and get safety recommendations here: ${url}`;

    if (shareType === 'share-whatsapp') {
      window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(text)}`, '_blank');
    } else if (shareType === 'share-twitter') {
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`, '_blank');
    } else if (shareType === 'share-facebook') {
      window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(text)}`, '_blank');
    } else if (shareType === 'share-instagram') {
      // Instagram doesn't support direct web sharing links. Copy context automatically and navigate user to platform.
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('share-instagram');
        if (btn) {
          const originalHtml = btn.innerHTML;
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>';
          setTimeout(() => { btn.innerHTML = originalHtml; }, 2000);
        }
        window.open('https://www.instagram.com', '_blank');
      });
    } else if (shareType === 'share-copy') {
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('share-copy');
        if (btn) {
          const originalHtml = btn.innerHTML;
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>';
          setTimeout(() => { btn.innerHTML = originalHtml; }, 2000);
        }
      });
    }
  }
});

// Persistence for Action Plan checkboxes
document.addEventListener('change', (e) => {
  const target = e.target as HTMLInputElement;
  if (target.type === 'checkbox' && target.closest('#assess-action-plan-ui')) {
    const labels = document.querySelectorAll('#assess-action-plan-ui input[type="checkbox"]');
    const states = Array.from(labels).map(input => (input as HTMLInputElement).checked);
    localStorage.setItem('elc_action_plan_states', JSON.stringify(states));
  }
});

function loadActionPlanStates() {
  const saved = localStorage.getItem('elc_action_plan_states');
  if (saved) {
    try {
      const states = JSON.parse(saved);
      const inputs = document.querySelectorAll('#assess-action-plan-ui input[type="checkbox"]');
      inputs.forEach((input, i) => {
        if (states[i] !== undefined) (input as HTMLInputElement).checked = states[i];
      });
    } catch (e) {}
  }
}

document.addEventListener('astro:page-load', () => {
  initAssessment();
  loadActionPlanStates();
});
</script>
