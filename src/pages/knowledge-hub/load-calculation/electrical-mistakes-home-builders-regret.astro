  { id: 'mistake-kitchen', label: '1. The Kitchen Load Trap', depth: 2 as const },
  { id: 'mistake-sanctioned', label: '2. Underestimating Sanctioned Load', depth: 2 as const },
  { id: 'mistake-surge', label: '3. Sizing for Run Watts, Ignoring Surge', depth: 2 as const },
  { id: 'mistake-expandability', label: '4. Zero Expansion Headroom (Solar/EV)', depth: 2 as const },
  { id: 'mistake-phase', label: '5. Phase Imbalance & Looping ACs', depth: 2 as const },
  { id: 'mistake-voltagedrop', label: '6. Ignoring Voltage Drop over Long Runs', depth: 2 as const },
