---
import KnowledgeHubLayout from '@/layouts/KnowledgeHubLayout.astro';
import QuickAnswerBox from '@/components/QuickAnswerBox.astro';
import KnowledgeHubCTA from '@/components/KnowledgeHubCTA.astro';
import { SOLAR_INVERTER_ARTICLES } from '@/data/knowledgeHub';
import { DAYS_PER_MONTH, SOLAR_PEAK_SUN_HOURS } from '@/data/constants';
import type { SchemaNode } from '@/types';

export const prerender = true;

const SITE = 'https://electricityloadcalculator.com';

const toc = [
  { id: 'quick-answer', label: 'Quick Answer', depth: 2 as const },
  { id: 'why-it-matters', label: 'Why Sizing Matters', depth: 2 as const },
  { id: 'solar-sizing-chart', label: 'Solar Sizing Chart', depth: 2 as const },
  { id: 'sizing-formula', label: 'Step-by-Step Sizing Formula', depth: 2 as const },
  { id: 'panel-space-calc', label: 'Panel Count & Roof Space', depth: 2 as const },
  { id: 'worked-example', label: 'Worked Example: 3 BHK', depth: 2 as const },
  { id: 'common-mistakes', label: 'Common Sizing Mistakes', depth: 2 as const },
  { id: 'use-the-calculator', label: 'Use the Calculator', depth: 2 as const },
  { id: 'faqs', label: 'FAQs', depth: 2 as const },
];

const relatedArticles = SOLAR_INVERTER_ARTICLES.filter(a => a.slug !== 'how-to-size-a-solar-panel-system-for-home');

const schemaGraph: SchemaNode[] = [
  {
    "@type": "Article",
    "headline": "How to Size a Solar Panel System for Your Home",
    "description": "Understand how to calculate required rooftop solar capacity (kW), panel count, roof area, and expected daily generation based on your home energy usage.",
    "author": { "@type": "Organization", "name": "ElectricityLoadCalculator.com" },
    "publisher": { "@type": "Organization", "name": "ElectricityLoadCalculator.com", "url": SITE },
    "datePublished": "2026-06-20",
    "dateModified": "2026-06-20",
    "url": `${SITE}/knowledge-hub/solar-inverter/how-to-size-a-solar-panel-system-for-home`,
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE },
      { "@type": "ListItem", "position": 2, "name": "Knowledge Hub", "item": `${SITE}/knowledge-hub` },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Solar & Inverter",
        "item": `${SITE}/knowledge-hub/solar-inverter`,
      },
      { "@type": "ListItem", "position": 4, "name": "How to Size a Solar Panel System" },
    ],
  },
  {
    "@type": "HowTo",
    "name": "How to Size a Rooftop Solar Panel System",
    "description": "A step-by-step methodology to determine the correct kW size of rooftop solar for home use.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Determine daily energy consumption", "text": "Divide your monthly electricity units (kWh) by 30 to get daily kWh consumption." },
      { "@type": "HowToStep", "position": 2, "name": "Factor in peak sun hours", "text": "India receives an average of 4 peak sun hours of standard sunlight daily." },
      { "@type": "HowToStep", "position": 3, "name": "Apply system safety losses", "text": "Factor in 30% system losses due to heat, inverter conversion, and dust." },
      { "@type": "HowToStep", "position": 4, "name": "Calculate target system capacity", "text": "Divide daily kWh consumption by the product of peak hours (4) and system efficiency (0.7)." },
    ],
  },
  {
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much electricity does a 3 kW solar system generate?", "acceptedAnswer": { "@type": "Answer", "text": "A 3 kW solar system generates approximately 12 kWh (units) of electricity per day under clear sky conditions. This equates to roughly 360 units per month, which is sufficient for a standard 2 BHK home." }},
      { "@type": "Question", "name": "How much roof space is needed for 1 kW solar panels?", "acceptedAnswer": { "@type": "Answer", "text": "Each 1 kW of rooftop solar panels requires approximately 80 to 100 square feet of flat, shadow-free roof area. A standard 3 kW system requires roughly 240 to 300 square feet." }},
      { "@type": "Question", "name": "What is the PM Surya Ghar subsidy for residential solar?", "acceptedAnswer": { "@type": "Answer", "text": "Under the PM Surya Ghar scheme, residential solar receives a subsidy of ₹30,000 per kW for the first 2 kW, and an additional ₹18,000 for the 3rd kW, capping at ₹78,000 for systems 3 kW or larger." }},
    ],
  },
];
---

<KnowledgeHubLayout
  title="How to Size a Solar Panel System for Your Home | Knowledge Hub"
  description="Learn how to calculate rooftop solar panel capacity in kW, estimate panel count, calculate required roof area, and plan net-metering solar systems."
  keywords="solar panel sizing, rooftop solar calculator, how many solar panels do I need, solar capacity calculation, PM Surya Ghar subsidy, solar roof area"
  breadcrumb={[
    { label: 'Home', href: '/' },
    { label: 'Knowledge Hub', href: '/knowledge-hub' },
    { label: 'Solar & Inverter', href: '/knowledge-hub/solar-inverter' },
    { label: 'How to Size a Solar Panel System' },
  ]}
  toc={toc}
  readingTime={8}
  datePublished="2026-06-20"
  dateModified="2026-06-20"
  schemaGraph={schemaGraph}
  relatedArticles={relatedArticles}
  clusterSlug="solar-inverter"
  clusterTitle="Solar & Inverter"
  showProgressBar={true}
  nextStep={{ clusterSlug: 'solar-inverter', slug: 'how-to-choose-the-right-inverter-capacity', caption: 'Inverter Sizing' }}
>

  <!-- ① QUICK ANSWER -->
  <QuickAnswerBox id="quick-answer">
    <div class="mb-4">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-1.5">Quick Solar Capacity Reference Matrix</p>
      <p class="text-sm text-text-secondary leading-relaxed">Rooftop solar system capacities, panels required, shadow-free roof area, and expected daily generation:</p>
    </div>

    <!-- Visual Dashboard Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-4">
      <!-- 1 kW System -->
      <div class="group flex flex-col items-center p-4 rounded-xl border border-border bg-base/50 hover:border-accent/40 hover:bg-card hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 rounded-full bg-card border border-border flex items-center justify-center mb-3 relative group-hover:border-accent/30 transition-colors" aria-hidden="true">
          <!-- Solar cell visual -->
          <div class="rounded-lg bg-[linear-gradient(135deg,#eab308,#ca8a04)] shadow-[0_0_8px_rgba(234,179,8,0.2)] group-hover:shadow-[0_0_12px_rgba(234,179,8,0.5)] group-hover:scale-110 transition-all duration-300 w-4 h-4"></div>
        </div>
        <span class="font-display font-bold text-xl text-text-primary mb-1">1 kW System</span>
        <span class="text-[10px] font-mono uppercase tracking-wider text-accent mb-2">4 kWh / Day</span>
        <p class="text-xs text-text-muted text-center leading-normal">2–3 Panels | 80–100 sq.ft</p>
      </div>

      <!-- 3 kW System -->
      <div class="group flex flex-col items-center p-4 rounded-xl border border-border bg-base/50 hover:border-accent/40 hover:bg-card hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 rounded-full bg-card border border-border flex items-center justify-center mb-3 relative group-hover:border-accent/30 transition-colors" aria-hidden="true">
          <!-- Solar cell visual -->
          <div class="rounded-lg bg-[linear-gradient(135deg,#eab308,#ca8a04)] shadow-[0_0_8px_rgba(234,179,8,0.2)] group-hover:shadow-[0_0_12px_rgba(234,179,8,0.5)] group-hover:scale-110 transition-all duration-300 w-6.5 h-6.5"></div>
        </div>
        <span class="font-display font-bold text-xl text-text-primary mb-1">3 kW System</span>
        <span class="text-[10px] font-mono uppercase tracking-wider text-accent mb-2">12 kWh / Day</span>
        <p class="text-xs text-text-muted text-center leading-normal">6–7 Panels | 240–300 sq.ft</p>
      </div>

      <!-- 5 kW System -->
      <div class="group flex flex-col items-center p-4 rounded-xl border border-border bg-base/50 hover:border-accent/40 hover:bg-card hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 rounded-full bg-card border border-border flex items-center justify-center mb-3 relative group-hover:border-accent/30 transition-colors" aria-hidden="true">
          <!-- Solar cell visual -->
          <div class="rounded-lg bg-[linear-gradient(135deg,#eab308,#ca8a04)] shadow-[0_0_8px_rgba(234,179,8,0.2)] group-hover:shadow-[0_0_12px_rgba(234,179,8,0.5)] group-hover:scale-110 transition-all duration-300 w-8.5 h-8.5"></div>
        </div>
        <span class="font-display font-bold text-xl text-text-primary mb-1">5 kW System</span>
        <span class="text-[10px] font-mono uppercase tracking-wider text-accent mb-2">20 kWh / Day</span>
        <p class="text-xs text-text-muted text-center leading-normal">10–11 Panels | 400–500 sq.ft</p>
      </div>

      <!-- 10 kW System -->
      <div class="group flex flex-col items-center p-4 rounded-xl border border-border bg-base/50 hover:border-accent/40 hover:bg-card hover:-translate-y-1 transition-all duration-300">
        <div class="w-14 h-14 rounded-full bg-card border border-border flex items-center justify-center mb-3 relative group-hover:border-accent/30 transition-colors" aria-hidden="true">
          <!-- Solar cell visual -->
          <div class="rounded-lg bg-[linear-gradient(135deg,#eab308,#ca8a04)] shadow-[0_0_8px_rgba(234,179,8,0.2)] group-hover:shadow-[0_0_12px_rgba(234,179,8,0.5)] group-hover:scale-110 transition-all duration-300 w-10 h-10"></div>
        </div>
        <span class="font-display font-bold text-xl text-text-primary mb-1">10 kW System</span>
        <span class="text-[10px] font-mono uppercase tracking-wider text-accent mb-2">40 kWh / Day</span>
        <p class="text-xs text-text-muted text-center leading-normal">20–22 Panels | 800–1000 sq.ft</p>
      </div>
    </div>
  </QuickAnswerBox>

  <!-- ② WHY IT MATTERS -->
  <h2 id="why-it-matters">Why Rooftop Solar Sizing Matters</h2>
  <p>Sizing your rooftop solar system correctly ensures you do not waste money buying unnecessary panels, while generating enough energy to offset your bill.</p>
  <div class="example-box">
    <p class="example-label"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accent inline-block mr-1.5 align-text-bottom" aria-hidden="true"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>Rooftop Solar Financial Highlights (India)</p>
    <ul class="space-y-3 mt-2 list-none text-sm text-text-secondary">
      <li class="flex items-start gap-2.5">
        <svg class="w-4 h-4 text-success mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
        <span><strong>Payback period:</strong> A properly sized system recovers its initial cost in 4–5 years through utility savings.</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg class="w-4 h-4 text-success mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
        <span><strong>PM Surya Ghar Subsidy:</strong> Claim a flat subsidy of up to ₹78,000 for standard systems 3 kW or larger.</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg class="w-4 h-4 text-success mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
        <span><strong>25-Year Lifespan:</strong> Solar panels come with a 25-year performance warranty, offering free energy for two decades.</span>
      </li>
    </ul>
  </div>

  <!-- ③ SOLAR SIZING CHART -->
  <h2 id="solar-sizing-chart">Rooftop Solar Sizing Reference Table</h2>
  <p>Standard solar system capacities differ in panel requirements, space needs, and daily energy yield, matching typical residential monthly bills.</p>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>System Capacity (kW)</th>
          <th>Expected Generation (Units/Day)</th>
          <th>Number of Panels (540W)</th>
          <th>Required Area (sq.ft)</th>
          <th>Typical Monthly Bill Offset</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>1 kW</strong></td>
          <td><code>4 kWh</code></td>
          <td>2 Panels</td>
          <td>80 – 100 sq.ft</td>
          <td>₹800 – 1,200</td>
        </tr>
        <tr>
          <td><strong>2 kW</strong></td>
          <td><code>8 kWh</code></td>
          <td>4 Panels</td>
          <td>160 – 200 sq.ft</td>
          <td>₹1,800 – 2,500</td>
        </tr>
        <tr>
          <td><strong>3 kW</strong></td>
          <td><code>12 kWh</code></td>
          <td>6 Panels</td>
          <td>240 – 300 sq.ft</td>
          <td>₹2,800 – 3,800</td>
        </tr>
        <tr>
          <td><strong>5 kW</strong></td>
          <td><code>20 kWh</code></td>
          <td>10 Panels</td>
          <td>400 – 500 sq.ft</td>
          <td>₹4,500 – 6,000</td>
        </tr>
        <tr>
          <td><strong>10 kW</strong></td>
          <td><code>40 kWh</code></td>
          <td>19 Panels</td>
          <td>800 – 1,000 sq.ft</td>
          <td>₹9,000 – 12,000</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ④ SIZING FORMULA -->
  <h2 id="sizing-formula">Step-by-Step Sizing Formula</h2>
  <p>You can calculate the exact rooftop solar capacity required by converting your monthly electricity units into a daily average and factoring in standard system efficiency losses.</p>

  <div class="step-card">
    <div class="step-number">1</div>
    <div>
      <strong class="text-text-primary block mb-1">Calculate daily energy usage</strong>
      <p class="text-text-muted text-sm m-0">Find your average monthly electricity consumption in units (kWh) from your bill and divide it by {DAYS_PER_MONTH} days.</p>
      <p class="font-mono text-sm bg-base border border-border rounded-lg px-4 py-2.5 mt-2 text-accent">Daily Consumption (kWh) = Monthly Units ÷ {DAYS_PER_MONTH}</p>
    </div>
  </div>

  <div class="step-card">
    <div class="step-number">2</div>
    <div>
      <strong class="text-text-primary block mb-1">Factor in peak sun hours</strong>
      <p class="text-text-muted text-sm m-0">Indian geography receives an average of {SOLAR_PEAK_SUN_HOURS} hours of peak standard solar radiation per day.</p>
      <p class="font-mono text-sm bg-base border border-border rounded-lg px-4 py-2.5 mt-2 text-accent">Peak Sun Hours = {SOLAR_PEAK_SUN_HOURS}</p>
    </div>
  </div>

  <div class="step-card">
    <div class="step-number">3</div>
    <div>
      <strong class="text-text-primary block mb-1">Account for system losses</strong>
      <p class="text-text-muted text-sm m-0">Rooftop solar systems lose about 30% of energy to heat, wiring resistance, dust, and inverter conversion (0.7 efficiency factor).</p>
      <p class="font-mono text-sm bg-base border border-border rounded-lg px-4 py-2.5 mt-2 text-accent">System Efficiency = 0.70</p>
    </div>
  </div>

  <div class="step-card">
    <div class="step-number">4</div>
    <div>
      <strong class="text-text-primary block mb-1">Compute required solar capacity</strong>
      <p class="text-text-muted text-sm m-0">Divide daily energy usage by the product of peak sun hours ({SOLAR_PEAK_SUN_HOURS}) and efficiency (0.70).</p>
      <p class="font-mono text-sm bg-base border border-border rounded-lg px-4 py-2.5 mt-2 text-accent">Capacity (kW) = Daily kWh ÷ ({SOLAR_PEAK_SUN_HOURS} × 0.70)</p>
    </div>
  </div>

  <!-- ⑤ PANEL SPACE CALC -->
  <h2 id="panel-space-calc">Panel Count &amp; Roof Space Calculation</h2>
  <p>Rooftop solar systems are constructed from individual monocrystalline panels that require specific shadow-free flat roof space to prevent hotspots.</p>
  <div class="example-box">
    <p class="example-label"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accent inline-block mr-1.5 align-text-bottom" aria-hidden="true"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>Panel Count & Area Math</p>
    <ul class="space-y-3 mt-2 list-none text-sm text-text-secondary">
      <li class="flex items-start gap-2.5">
        <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span><strong>Panel Count:</strong> Divide system Watts by panel rating (e.g. 3,000W system ÷ 540W panel ≈ 6 panels).</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span><strong>Flat Roof Area:</strong> Each modern high-efficiency panel requires approximately 25 sq.ft of flat area including maintenance pathways.</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span><strong>Total Area formula:</strong> <code>Total Roof Space (sq.ft) = Panel Count × 25</code>.</span>
      </li>
    </ul>
  </div>

  <!-- ⑥ WORKED EXAMPLE -->
  <h2 id="worked-example">Worked Sizing Example: A 3 BHK Home</h2>
  <p>Let's run a calculation for a typical Indian home consuming 420 units of electricity per month (averaging 14 kWh per day) to size its solar system correctly.</p>
  <div class="example-box">
    <p class="example-label"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accent inline-block mr-1.5 align-text-bottom" aria-hidden="true"><rect x="8" y="2" width="8" height="4" rx="1" ry="1" /><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" /><path d="M9 14h6" /><path d="M9 18h6" /><path d="M9 10h6" /></svg>3 BHK Solar Sizing Worked Calculation</p>
    <div class="space-y-2 mt-2 text-sm text-text-secondary">
      <p><strong>Step 1: Calculate Daily Consumption</strong></p>
      <p class="font-mono text-accent">420 kWh ÷ {DAYS_PER_MONTH} days = 14.0 kWh / day</p>
      
      <p class="mt-3"><strong>Step 2: Calculate Required Capacity</strong></p>
      <p class="font-mono text-accent">14.0 kWh ÷ ({SOLAR_PEAK_SUN_HOURS} hours × 0.70 efficiency) = 5.0 kW Solar System</p>
      
      <p class="mt-3"><strong>Step 3: Calculate Panel Count & Space</strong></p>
      <p>Using standard 540W solar modules: 5,000W ÷ 540W = 9.25 modules (size up to <strong>10 Panels</strong>). This 5 kW system requires 10 panels × 25 sq.ft = <strong>250 sq.ft</strong> of flat shadow-free rooftop space.</p>
    </div>
  </div>

  <KnowledgeHubCTA variant="inline" />

  <!-- ⑦ COMMON MISTAKES -->
  <h2 id="common-mistakes">Common Solar Sizing Mistakes</h2>
  <div class="mistake-card">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-danger flex-shrink-0" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
    <div>
      <strong class="text-text-primary block mb-1">Sizing solar capacity for connected load</strong>
      <p class="text-sm m-0 text-text-muted">Solar generates daily units, so size it according to your monthly kWh consumption rather than connected kW load. A house with a 10 kW connected load but low usage might only require a 3 kW solar system.</p>
    </div>
  </div>

  <div class="mistake-card">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-danger flex-shrink-0" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
    <div>
      <strong class="text-text-primary block mb-1">Ignoring winter or monsoon output drops</strong>
      <p class="text-sm m-0 text-text-muted">Peak sun hours drop during monsoon or winter seasons. Ensure your solar setup is sized for average annual irradiance rather than peak summer solar performance.</p>
    </div>
  </div>

  <div class="mistake-card">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-danger flex-shrink-0" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
    <div>
      <strong class="text-text-primary block mb-1">Overlooking nearby shadow-casting obstacles</strong>
      <p class="text-sm m-0 text-text-muted">A shadow cast over even a single panel cell can drop the generation of the entire string by 50%. Map shadows throughout the day before choosing panel positions.</p>
    </div>
  </div>

  <!-- ⑧ USE THE CALCULATOR -->
  <KnowledgeHubCTA id="use-the-calculator" />

  <!-- ⑨ FAQS -->
  <h2 id="faqs">Frequently Asked Questions</h2>
  <div class="kh-faq">
    <details>
      <summary>How many units does a 3 kW solar system generate per day in India?<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="faq-chevron w-4 h-4"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg></summary>
      <div class="faq-body">A 3 kW rooftop solar system generates approximately 12 kWh (units) of electricity per day. Over a month, this equals roughly 360 units, which is adequate for standard 2 BHK homes.</div>
    </details>
    <details>
      <summary>What is the cost of a 3 kW solar system after subsidy in India?<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="faq-chevron w-4 h-4"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg></summary>
      <div class="faq-body">A standard 3 kW solar rooftop system costs about ₹1.6–1.8 lakhs before subsidy. After claiming the PM Surya Ghar subsidy of ₹78,000, the net cost drops to around ₹82,000–1,02,000.</div>
    </details>
    <details>
      <summary>Can I run an air conditioner (AC) on a 3 kW solar system?<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="faq-chevron w-4 h-4"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg></summary>
      <div class="faq-body">Yes. An on-grid 3 kW solar system feeds power into the grid, offsetting AC electricity use. For off-grid solar, a 3 kW system can run a 1.5 Ton inverter AC during peak sunny hours if paired with a 5 kVA solar inverter.</div>
    </details>
    <details>
      <summary>How much roof area is required for a 5 kW solar system?<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="faq-chevron w-4 h-4"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg></summary>
      <div class="faq-body">A 5 kW solar rooftop system requires roughly 400 to 500 square feet of flat, shadow-free roof area. It typically consists of 9–10 high-efficiency monocrystalline panels.</div>
    </details>
    <details>
      <summary>What is net metering in rooftop solar?<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="faq-chevron w-4 h-4"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg></summary>
      <div class="faq-body">Net metering is a billing mechanism that credits solar homeowners for excess electricity exported to the utility grid. If your solar generates more than you consume, the surplus units roll over to reduce future bills.</div>
    </details>
  </div>

  <!-- Sidebar nav slot -->
  <Fragment slot="sidebar-nav">
    {SOLAR_INVERTER_ARTICLES.map(a => (
      <a
        href={`/knowledge-hub/solar-inverter/${a.slug}`}
        class={`text-sm py-1.5 flex items-center gap-2 transition-colors ${a.isPillar ? 'text-accent font-medium' : 'text-text-muted hover:text-accent'}`}
        data-astro-prefetch="hover"
      >
        <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${a.isPillar ? 'bg-accent' : 'bg-border'}`} aria-hidden="true"></span>
        {a.title}
      </a>
    ))}
  </Fragment>
</KnowledgeHubLayout>
