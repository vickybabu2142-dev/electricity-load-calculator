---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import KnowledgeHubCTA from '@/components/KnowledgeHubCTA.astro';
import { SOLAR_INVERTER_ARTICLES, CLUSTERS } from '@/data/knowledgeHub';

export const prerender = true;

const SITE = 'https://electricityloadcalculator.com';
const cluster = CLUSTERS.find(c => c.slug === 'solar-inverter')!;
const pillar = SOLAR_INVERTER_ARTICLES.find(a => a.isPillar)!;
const supporting = SOLAR_INVERTER_ARTICLES.filter(a => !a.isPillar);

const comingTopics = [
  {
    icon: 'plug',
    title: 'Battery Backup Calculation for Home Inverters',
    desc: 'How to calculate the battery bank size (Ah) needed for your desired backup hours, accounting for depth of discharge and efficiency losses.',
  },
  {
    icon: 'bolt',
    title: 'On-Grid vs Off-Grid vs Hybrid Solar Systems',
    desc: 'A plain-language comparison of on-grid (net metering), off-grid, and hybrid solar setups — and which makes economic sense for Indian homes in 2026.',
  },
  {
    icon: 'money',
    title: 'Solar ROI Calculator: When Does It Pay Off?',
    desc: 'A step-by-step financial analysis showing payback period, 25-year savings, and NPV for rooftop solar in major Indian cities.',
  },
  {
    icon: 'chart',
    title: 'Understanding MNRE Subsidy & Net Metering in India',
    desc: "How to claim PM Surya Ghar subsidies, calculate net metering credits on your DISCOM bill, and what documentation you'll need.",
  },
];

function getTopicIcon(icon: string) {
  switch (icon) {
    case 'battery':
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-accent" aria-hidden="true"><rect width="16" height="10" x="2" y="7" rx="2" ry="2"/><line x1="22" y1="11" x2="22" y2="13"/></svg>`;
    case 'plug':
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-accent" aria-hidden="true"><path d="M12 2v10"/><path d="M18 8V6a4 4 0 0 0-8 0v2"/><path d="M5 8h14a2 2 0 0 1 2 2v3a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3v-3a2 2 0 0 1 2-2Z"/><path d="M10 16v4a2 2 0 0 0 4 0v-4"/></svg>`;
    case 'bolt':
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-accent" aria-hidden="true"><path d="m13 2-2 10h9L9 22l2-10H3Z"/></svg>`;
    case 'money':
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-accent" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`;
    case 'chart':
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-accent" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`;
    default:
      return '';
  }
}

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE },
    { "@type": "ListItem", "position": 2, "name": "Knowledge Hub", "item": `${SITE}/knowledge-hub` },
    { "@type": "ListItem", "position": 3, "name": "Solar & Inverter" },
  ],
};

const schemaGraph = [
  {
    "@type": "CollectionPage",
    "name": "Solar & Inverter Sizing Guides",
    "description": "Learn how to size your home solar panel system, choose the correct inverter capacity, and calculate battery backup requirements safely.",
    "url": `${SITE}/knowledge-hub/solar-inverter`,
    "breadcrumb": breadcrumbSchema,
    "hasPart": SOLAR_INVERTER_ARTICLES.map(a => ({
      "@type": "Article",
      "name": a.title,
      "url": `${SITE}/knowledge-hub/solar-inverter/${a.slug}`,
      "description": a.description,
    })),
  },
];
---

<BaseLayout
  title="Solar & Inverter Sizing Guides — Electrical Knowledge Hub"
  description="Master home solar and inverter planning. Learn how to calculate solar panel kW capacity, size inverter VA ratings, and estimate battery backup sizes."
  keywords="solar panel sizing, inverter selection, battery backup calculation, on-grid solar, off-grid solar, solar ROI India, home inverter size, PM Surya Ghar subsidy"
  schemaGraph={schemaGraph}
  breadcrumbSchema={breadcrumbSchema}
>
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Knowledge Hub', href: '/knowledge-hub' },
    { label: 'Solar & Inverter' },
  ]} />

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-6 pb-20">

    <!-- Cluster Hero -->
    <div class="max-w-4xl mb-12">
      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-text-muted mb-2 flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accent" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
        </svg>
        Knowledge Hub / Solar &amp; Inverter Sizing
      </p>
      <h1 class="font-display font-bold text-4xl sm:text-5xl text-text-primary leading-tight tracking-tight mb-4">
        Solar &amp; Inverter <span class="text-accent">Sizing</span> Guides
      </h1>
      <p class="text-text-muted text-base sm:text-lg leading-relaxed max-w-2xl mb-6">
        Practical, jargon-free guides to help you size rooftop solar PV systems, calculate battery backup times, and select the right inverter capacity for your home.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href={`/knowledge-hub/solar-inverter/${pillar.slug}`} class="btn-primary px-5 py-2.5 text-sm">
          Read the Pillar Guide
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true"><path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd"/></svg>
        </a>
        <a href="/" class="btn-secondary px-5 py-2.5 text-sm">Use Solar &amp; Inverter Sizer</a>
      </div>
    </div>

    <div class="flex gap-8 xl:gap-12 items-start">
      <!-- Main Content -->
      <div class="min-w-0 flex-1">

        <!-- Pillar Article (featured) -->
        <section class="mb-10" aria-labelledby="pillar-heading">
          <h2 id="pillar-heading" class="font-mono text-[10px] uppercase tracking-[0.2em] text-accent mb-4 flex items-center gap-2">
            <span class="w-4 h-px bg-accent" aria-hidden="true"></span>
            Featured Guide
          </h2>
          <a
            href={`/knowledge-hub/solar-inverter/${pillar.slug}`}
            class="group block rounded-xl border border-border bg-card p-6 sm:p-8 hover:border-accent/40 transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
            style="box-shadow: 0 4px 32px -8px color-mix(in srgb, var(--accent), transparent 85%);"
            data-astro-prefetch="hover"
          >
            <div class="flex items-center gap-3 mb-4">
              <span class="text-[9px] font-mono uppercase tracking-widest px-2.5 py-1 rounded-full bg-accent/10 border border-accent/30 text-accent flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 text-accent" aria-hidden="true">
                  <path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                </svg>
                Pillar Guide
              </span>
              <span class="text-[10px] font-mono text-text-faint">{pillar.readingTime} min read</span>
            </div>
            <h3 class="font-display font-bold text-2xl text-text-primary group-hover:text-accent transition-colors mb-3 leading-tight">
              {pillar.title}
            </h3>
            <p class="text-text-muted leading-relaxed mb-5">{pillar.description}</p>
            <div class="flex items-center gap-2 text-sm text-accent font-medium">
              Read complete guide
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" aria-hidden="true"><path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd"/></svg>
            </div>
          </a>
        </section>

        <!-- All Guides (Supporting) -->
        {supporting.length > 0 && (
          <section aria-labelledby="all-guides-heading" class="mb-10">
            <h2 id="all-guides-heading" class="font-display font-bold text-2xl text-text-primary mb-5 flex items-center gap-3">
              <span class="w-1 h-6 rounded-full bg-accent flex-shrink-0" aria-hidden="true"></span>
              All Solar Sizing Guides
            </h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {supporting.map((article, i) => (
                <a
                  href={`/knowledge-hub/solar-inverter/${article.slug}`}
                  class="group block rounded-xl border border-border bg-card p-5 hover:border-accent/40 hover:-translate-y-0.5 transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
                  data-astro-prefetch="hover"
                >
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-[10px] font-mono text-text-faint">Guide {String(i + 2).padStart(2, '0')}</span>
                    <span class="text-[10px] font-mono text-text-faint">{article.readingTime} min</span>
                  </div>
                  <h3 class="font-display font-semibold text-base text-text-primary group-hover:text-accent transition-colors mb-2 leading-snug">
                    {article.title}
                  </h3>
                  <p class="text-xs text-text-muted leading-relaxed line-clamp-2">{article.description}</p>
                  <p class="mt-3 text-xs text-accent flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                    Read
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" fill="currentColor" class="w-3 h-3" aria-hidden="true"><path fill-rule="evenodd" d="M3.22 8.53a.75.75 0 0 1 0-1.06l2.22-2.22-2.22-2.22a.75.75 0 1 1 1.06-1.06l2.75 2.75a.75.75 0 0 1 0 1.06l-2.75 2.75a.75.75 0 0 1-1.06 0Z" clip-rule="evenodd"/></svg>
                  </p>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Upcoming Guides -->
        <section aria-labelledby="guides-heading">
          <h2 id="guides-heading" class="font-display font-bold text-2xl text-text-primary mb-5 flex items-center gap-3">
            <span class="w-1 h-6 rounded-full bg-accent flex-shrink-0" aria-hidden="true"></span>
            Upcoming Solar &amp; Inverter Guides
          </h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {comingTopics.map((topic) => (
              <div
                class="group block rounded-xl border border-border bg-card/60 p-5 overflow-hidden hover:border-accent/20 transition-all duration-200"
              >
                <div class="flex items-center justify-between mb-3">
                  <span class="text-[10px] font-mono text-text-faint flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-text-faint" aria-hidden="true">
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                    Upcoming
                  </span>
                  <span class="text-[9px] font-mono uppercase tracking-widest px-2.5 py-0.5 rounded border border-border text-text-faint bg-base/40">Soon</span>
                </div>
                <h3 class="font-display font-semibold text-base text-text-primary mb-2 leading-snug">
                  {topic.title}
                </h3>
                <p class="text-xs text-text-muted leading-relaxed line-clamp-2">{topic.desc}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Calculator CTA -->
        <KnowledgeHubCTA />

        <!-- Other Clusters -->
        <section class="mt-12 pt-8 border-t border-border" aria-labelledby="other-clusters-heading">
          <h2 id="other-clusters-heading" class="font-display font-bold text-lg text-text-primary mb-4">Explore Other Topics</h2>
          <div class="flex flex-wrap gap-3">
            {[
              { label: 'Load Calculation', href: '/knowledge-hub/load-calculation' },
              { label: 'MCB Sizing', href: '/knowledge-hub/mcb-sizing' },
              { label: 'Wire Sizing', href: '/knowledge-hub/wire-sizing' },
              { label: 'All Topics', href: '/knowledge-hub' },
            ].map(link => (
              <a href={link.href} class="btn-secondary text-sm px-4 py-2" data-astro-prefetch="hover">{link.label} →</a>
            ))}
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="hidden xl:block w-72 flex-shrink-0 sticky top-24">
        <div class="rounded-xl border border-border bg-card p-5 mb-5" style="box-shadow: 0 2px 16px -4px color-mix(in srgb, var(--accent), transparent 80%);">
          <div class="flex items-center gap-2 mb-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent/10 border border-accent/30">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-accent" aria-hidden="true"><path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/></svg>
            </div>
            <p class="text-[10px] font-mono uppercase tracking-widest text-accent">Free Tool</p>
          </div>
          <p class="font-display font-bold text-base text-text-primary mb-1.5">Solar Sizing Calculator</p>
          <p class="text-xs text-text-muted leading-relaxed mb-4">Calculate recommended solar rooftop kW and battery backup size for your appliances.</p>
          <a href="/" class="btn-primary w-full text-sm py-2.5 justify-center" data-astro-prefetch="hover">
            Start Sizing →
          </a>
        </div>
        <div class="rounded-xl border border-border bg-card p-5" style="box-shadow: 0 2px 16px -4px color-mix(in srgb, var(--accent), transparent 80%);">
          <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-text-muted mb-3">
            Cluster Articles
          </p>
          <nav aria-label="Solar &amp; Inverter Sizing Guides">
            {SOLAR_INVERTER_ARTICLES.map(a => (
              <a
                href={`/knowledge-hub/solar-inverter/${a.slug}`}
                class={`text-sm py-1.5 flex items-center gap-2 transition-colors ${a.isPillar ? 'text-accent font-medium' : 'text-text-muted hover:text-accent'}`}
                data-astro-prefetch="hover"
              >
                <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${a.isPillar ? 'bg-accent' : 'bg-border'}`} aria-hidden="true"></span>
                {a.title}
              </a>
            ))}
          </nav>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>
