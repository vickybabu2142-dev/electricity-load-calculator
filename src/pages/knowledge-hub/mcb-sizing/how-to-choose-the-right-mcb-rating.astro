// Main reference table
const mcbChartData = [
  { circuit: 'Lighting circuit (LEDs, fans)',  typicalLoad: '< 800W',       currentCalc: '3.5A',     wireGauge: '1.5 mm²', recMcb: '6A (Type B)',          note: '' },
  { circuit: 'General power sockets',          typicalLoad: '1,000–1,800W', currentCalc: '4–8A',     wireGauge: '2.5 mm²', recMcb: '10A or 16A (Type B)',  note: '' },
  { circuit: 'AC — 1 Ton',                     typicalLoad: '900W',         currentCalc: '3.9A',     wireGauge: '2.5 mm²', recMcb: '10A or 16A (Type C)',  note: 'Dedicated circuit' },
  { circuit: 'AC — 1.5 Ton',                   typicalLoad: '1,600W',       currentCalc: '7A',       wireGauge: '2.5 mm²', recMcb: '16A (Type C)',         note: 'Dedicated circuit' },
  { circuit: 'AC — 2 Ton',                     typicalLoad: '2,200W',       currentCalc: '9.6A',     wireGauge: '4 mm²',   recMcb: '20A (Type C)',         note: 'Dedicated circuit' },
  { circuit: 'Electric geyser / water heater', typicalLoad: '2,000–3,000W', currentCalc: '8.7–13A',  wireGauge: '4 mm²',   recMcb: '16A or 20A (Type B)', note: 'Resistive load' },
  { circuit: 'Water pump — 0.5 HP',            typicalLoad: '370W',         currentCalc: '1.6A',     wireGauge: '1.5 mm²', recMcb: '6A (Type C)',          note: '' },
  { circuit: 'Water pump — 1.5 HP',            typicalLoad: '1,100W',       currentCalc: '4.8A',     wireGauge: '2.5 mm²', recMcb: '16A (Type C)',         note: 'High inrush' },
  { circuit: 'Kitchen heavy sockets',          typicalLoad: '2,500–3,500W', currentCalc: '11–15A',   wireGauge: '4 mm²',   recMcb: '20A or 25A (Type B)', note: 'Kettle + microwave' },
  { circuit: 'Sub-DB feeder — 2 BHK',          typicalLoad: '5,000–8,000W', currentCalc: '22–35A',   wireGauge: '6–10 mm²',recMcb: '32A or 40A (Type C)', note: '' },
  { circuit: 'Main incomer — 3 BHK',           typicalLoad: '8,000–12,000W','currentCalc': '35–52A', wireGauge: '10–16 mm²',recMcb: '40A or 63A (Type C)', note: 'Ask utility for sanction' },
];

// Curve type comparison
const curveData = [
  { type: 'B', threshold: '3–5×', loads: 'Lighting, heaters, resistive sockets, home office', avoid: 'ACs, pumps, refrigerators, washing machines' },
  { type: 'C', threshold: '5–10×', loads: 'ACs, water pumps, refrigerators, washing machines, motors', avoid: 'Pure lighting circuits (wasteful oversizing)' },
  { type: 'D', threshold: '10–20×', loads: 'Very large motors, transformers, X-ray machines, welding equipment', avoid: 'Any domestic home circuit — D curves provide inadequate protection for household wiring' },
