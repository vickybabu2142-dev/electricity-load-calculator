// Main reference table
const mcbChartData = [
  { circuit: 'Lighting circuit (LEDs, fans)',  typicalLoad: '< 800W',       currentCalc: '3.5A',     wireGauge: '1.5 mm²', recMcb: '6A (Type B)',          note: '' },
  { circuit: 'General power sockets',          typicalLoad: '1,000–1,800W', currentCalc: '4–8A',     wireGauge: '2.5 mm²', recMcb: '10A or 16A (Type B)',  note: '' },
  { circuit: 'AC — 1 Ton',                     typicalLoad: '900W',         currentCalc: '3.9A',     wireGauge: '2.5 mm²', recMcb: '10A or 16A (Type C)',  note: 'Dedicated circuit' },
  { circuit: 'AC — 1.5 Ton',                   typicalLoad: '1,600W',       currentCalc: '7A',       wireGauge: '2.5 mm²', recMcb: '16A (Type C)',         note: 'Dedicated circuit' },
  { circuit: 'AC — 2 Ton',                     typicalLoad: '2,200W',       currentCalc: '9.6A',     wireGauge: '4 mm²',   recMcb: '20A (Type C)',         note: 'Dedicated circuit' },
  { circuit: 'Electric geyser / water heater', typicalLoad: '2,000–3,000W', currentCalc: '8.7–13A',  wireGauge: '4 mm²',   recMcb: '16A or 20A (Type B)', note: 'Resistive load' },
  { circuit: 'Water pump — 0.5 HP',            typicalLoad: '370W',         currentCalc: '1.6A',     wireGauge: '1.5 mm²', recMcb: '6A (Type C)',          note: '' },
  { circuit: 'Water pump — 1.5 HP',            typicalLoad: '1,100W',       currentCalc: '4.8A',     wireGauge: '2.5 mm²', recMcb: '16A (Type C)',         note: 'High inrush' },
  { circuit: 'Kitchen heavy sockets',          typicalLoad: '2,500–3,500W', currentCalc: '11–15A',   wireGauge: '4 mm²',   recMcb: '20A or 25A (Type B)', note: 'Kettle + microwave' },
  { circuit: 'Sub-DB feeder — 2 BHK',          typicalLoad: '5,000–8,000W', currentCalc: '22–35A',   wireGauge: '6–10 mm²',recMcb: '32A or 40A (Type C)', note: '' },
  { circuit: 'Main incomer — 3 BHK',           typicalLoad: '8,000–12,000W','currentCalc': '35–52A', wireGauge: '10–16 mm²',recMcb: '40A or 63A (Type C)', note: 'Ask utility for sanction' },
];

// Curve type comparison
const curveData = [
  { type: 'B', threshold: '3–5×', loads: 'Lighting, heaters, resistive sockets, home office', avoid: 'ACs, pumps, refrigerators, washing machines' },
  { type: 'C', threshold: '5–10×', loads: 'ACs, water pumps, refrigerators, washing machines, motors', avoid: 'Pure lighting circuits (wasteful oversizing)' },
  { type: 'D', threshold: '10–20×', loads: 'Very large motors, transformers, X-ray machines, welding equipment', avoid: 'Any domestic home circuit — D curves provide inadequate protection for household wiring' },
];
---

<KnowledgeHubLayout
  title="How to Choose the Right MCB Rating — The Definitive Guide"
  description="Master the 4-step formula for MCB sizing. Covers ampere calculation, B/C/D curve types, wire-gauge pairing, and worked examples for every circuit in your home — ACs, geysers, pumps, and main incomers."
  keywords="how to choose mcb rating, mcb size selection, b curve vs c curve mcb, wire gauge mcb pairing, circuit breaker sizing india, 16a mcb load capacity"
  breadcrumb={[
    { label: 'Home',          href: '/' },
    { label: 'Knowledge Hub', href: '/knowledge-hub' },
    { label: 'MCB Sizing',    href: '/knowledge-hub/mcb-sizing' },
    { label: 'How to Choose the Right MCB Rating' },
  ]}
  toc={toc}
  readingTime={9}
  datePublished="2026-06-19"
  dateModified="2026-06-20"
  schemaGraph={schemaGraph}
  relatedArticles={relatedArticles}
  clusterSlug="mcb-sizing"
  clusterTitle="MCB Sizing"
  showProgressBar={true}
  nextStep={{ clusterSlug: 'mcb-sizing', slug: 'why-does-my-mcb-keep-tripping', caption: 'Troubleshooting' }}
>

  <!-- ① QUICK ANSWER -->
  <QuickAnswerBox id="quick-answer" heading="The One Thing Most People Get Wrong">
    <p>
      Choosing an MCB is <em>not</em> just about amps. Most homeowners pick the right ampere rating
      and then install the wrong <strong>curve type</strong> — causing either nuisance trips every time
      the AC starts, or dangerously slow protection on a circuit that needs fast response.
    </p>
    <p class="mt-3">
      Every MCB has <strong>two numbers</strong> that matter: the <strong>ampere rating</strong>
      (how much continuous current it allows) and the <strong>curve type</strong> (how fast it reacts
      to a sudden surge). Both must be correct. Here's the quick formula:
    </p>
    <ol class="mt-3 space-y-1.5 text-sm text-text-muted leading-relaxed list-none">
      <li class="flex items-start gap-2.5">
        <span class="font-mono font-bold text-accent flex-shrink-0">①</span>
        <span><strong>Design current</strong> = (Total Watts ÷ 230V) × 1.25</span>
      </li>
      <li class="flex items-start gap-2.5">
        <span class="font-mono font-bold text-accent flex-shrink-0">②</span>
        <span><strong>Round up</strong> to the next standard rating: 6 / 10 / 16 / 20 / 25 / 32 / 40 / 63A</span>
      </li>
      <li class="flex items-start gap-2.5">
        <span class="font-mono font-bold text-accent flex-shrink-0">③</span>
        <span><strong>Curve:</strong> Type B for lights & heaters — Type C for motors, ACs & pumps</span>
      </li>
    </ol>
    <p class="mt-4 text-sm">
      Example: 2,300W geyser → 2300 ÷ 230 = 10A → 10 × 1.25 = 12.5A → next size up = <strong>16A Type B</strong>
      (geysers are purely resistive, so Type B is correct here). Read on for the full explanation and every common circuit worked out.
    </p>
  </QuickAnswerBox>

  <p class="mt-6">
    Your electrical panel is the spine of your home's power system. Every circuit, every socket,
    every appliance ultimately traces back to a row of small switches on that panel. Get the sizing
    right and you have invisible, reliable protection for decades. Get it wrong and you have either
    nuisance trips that cut power mid-use — or, worse, a silent fire hazard hiding inside your walls.
    This guide gives you the complete, professional-grade method.
  </p>

  <!-- ② WHAT AN MCB ACTUALLY PROTECTS -->
  <h2 id="why-mcb">What an MCB Actually Protects — And Why Sizing Is Critical</h2>

  <p>
    The most widespread misconception about MCBs is that they protect your appliances. They do not —
    at least not primarily. An MCB's core job is to <strong>protect the copper wiring inside your walls</strong>
    from carrying more current than it was designed for.
  </p>
  <p>
    Every electrical cable has a maximum safe current rating, determined by its copper cross-section
    (wire gauge). Exceed that rating and the conductor heats up. At high enough temperatures, the
    plastic insulation around the wire softens, then melts, then ignites. A wiring fire inside a wall
    cavity is one of the most difficult house fires to detect and control — because it's hidden,
    it burns slowly, and it can smoulder for hours before breaking out.
  </p>

  <div class="example-box">
    <p class="example-label">The Pressure Cooker Safety Valve Analogy</p>
    <p>Think of your entire home electrical system as a pressure cooker:</p>
    <ul class="space-y-3 my-4 list-none">
      <li class="flex items-start gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent mt-1.5 flex-shrink-0" aria-hidden="true"><path d="M12.8 18a2.2 2.2 0 0 0 2.2-2.2c0-1.2-1-2.2-2.2-2.2H2"/><path d="M20 12a2.5 2.5 0 0 0 0-5H2"/><path d="M16 21a1.5 1.5 0 0 0 0-3H2"/></svg>
        <span class="text-sm text-text-secondary leading-relaxed"><strong>Steam pressure</strong> = electrical current (Amperes) flowing through your wires.</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-danger mt-1.5 flex-shrink-0" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
        <span class="text-sm text-text-secondary leading-relaxed"><strong>The cooker exploding</strong> = wiring overheating, melting its insulation, starting a fire inside your walls.</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-success mt-1.5 flex-shrink-0" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="text-sm text-text-secondary leading-relaxed"><strong>The safety valve</strong> = the MCB. When pressure (current) exceeds the safe limit, the valve pops (MCB trips) to avert disaster.</span>
      </li>
    </ul>
    <p class="text-sm text-text-secondary">
      A safety valve <strong>calibrated too heavy</strong> (MCB rated too high) won't open until after
      the cooker has already burst. A valve <strong>calibrated too light</strong> (MCB rated too low)
      pops during normal cooking and ruins every meal. The perfect calibration — matched exactly to
      the cooker's design pressure — is what you are calculating when you size an MCB.
    </p>
  </div>

  <!-- ③ THE 4-STEP FORMULA -->
  <h2 id="step-by-step">The 4-Step Sizing Formula</h2>
  <p>
    This is the method used by professional electricians. It takes under 2 minutes once you know
    your appliance wattage.
  </p>

  <div class="step-card">
    <div class="step-number">1</div>
    <div>
      <strong class="text-text-primary block mb-1">Sum the wattage of the circuit</strong>
      <p class="text-text-muted text-sm">
        List every device that could be switched on simultaneously on this circuit. Add up their
        peak running wattages — not their standby power, but their full operational draw. For a
        dedicated single-appliance circuit (AC, geyser, pump), this is just that appliance's rated
        wattage. You can find wattage on the appliance's rating label (usually at the back or bottom).
      </p>
      <p class="text-text-muted text-sm mt-2">
        <strong>Pro tip:</strong> If the label shows current (Amps) instead of watts,
        convert using: <code class="text-xs">Watts = Amps × 230</code>
      </p>
    </div>
  </div>

  <div class="step-card">
    <div class="step-number">2</div>
    <div>
      <strong class="text-text-primary block mb-1">Calculate the load current (Amps)</strong>
      <p class="text-text-muted text-sm">
        Divide the total wattage by your supply voltage. In India and most of Europe, single-phase
        supply is <strong>230V</strong>. In the United States, residential circuits run at 120V or 240V.
      </p>
      <p class="font-mono text-sm bg-base border border-border rounded-lg px-4 py-2.5 mt-3 text-accent">
        Load Current (A) = Total Watts ÷ 230V
      </p>
    </div>
  </div>

  <div class="step-card">
    <div class="step-number">3</div>
    <div>
      <strong class="text-text-primary block mb-1">Apply the 1.25 safety margin</strong>
      <p class="text-text-muted text-sm">
        IEC 60898 (the international standard governing MCB design) requires that a breaker must
        carry 100% of its rated current indefinitely without tripping — but when used on a
        <strong>continuous load</strong> (running for 3 or more hours), the breaker and wiring
        inside the panel accumulate heat. To prevent thermal nuisance trips, design the circuit
        to only use 80% of the MCB's capacity — which means the MCB itself must be rated
        for 125% of the actual load (the inverse of 80%).
      </p>
      <p class="font-mono text-sm bg-base border border-border rounded-lg px-4 py-2.5 mt-3 text-accent">
        Design Current (A) = Load Current × 1.25
      </p>
    </div>
  </div>

  <div class="step-card">
    <div class="step-number">4</div>
    <div>
      <strong class="text-text-primary block mb-1">Select the next standard MCB rating</strong>
      <p class="text-text-muted text-sm">
        Round your Design Current <em>up</em> to the nearest standard MCB size. Always round up —
        never down. Rounding down means the breaker will trip during normal operation.
        Standard manufactured sizes are:
      </p>
      <div class="flex flex-wrap gap-2 mt-3">
        {['6A', '10A', '16A', '20A', '25A', '32A', '40A', '50A', '63A'].map(r => (
          <span class="px-2.5 py-1 rounded-md text-xs font-mono font-semibold bg-accent/10 text-accent border border-accent/20">{r}</span>
        ))}
      </div>
      <p class="text-text-muted text-sm mt-3">
        Then choose the correct <strong>curve type</strong> — explained in full in the next section.
        The ampere rating and curve type together are what's printed on the breaker face
        (e.g., <code>C16</code> = Type C curve, 16 Amps).
      </p>
    </div>
  </div>

  <!-- ④ CURVE TYPES -->
  <h2 id="curve-types">B, C & D Curve Types — The Half of MCB Sizing Nobody Talks About</h2>

  <p>
    The ampere rating tells the breaker <em>when</em> to trip on sustained overload (the thermal
    mechanism). The curve type tells it <em>how fast</em> to trip when a sudden current spike occurs
    (the magnetic mechanism). Installing the wrong curve type is the #1 preventable mistake in home
    electrical work.
  </p>
  <p>
    Here is why curve type matters: all motor-driven appliances — air conditioners, water pumps,
    refrigerators, washing machines — draw a massive surge of current for a fraction of a second
    when they start up. This <strong>inrush current</strong> can be 5–8× the running current.
    A Type B breaker's magnetic trip fires at 3–5× rated current, so it sees this normal motor
    surge as a short circuit and trips immediately. The motor is completely fine — the breaker
    doesn't know the difference.
  </p>

  <div class="overflow-x-auto my-6 border border-border rounded-xl bg-card">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-base border-b border-border">
          <th class="p-3 text-xs font-mono uppercase text-text-muted">Curve</th>
          <th class="p-3 text-xs font-mono uppercase text-text-muted">Magnetic Trip at</th>
          <th class="p-3 text-xs font-mono uppercase text-text-muted">Use For</th>
          <th class="p-3 text-xs font-mono uppercase text-danger">Do NOT Use For</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border/50 text-sm">
        {curveData.map(row => (
          <tr>
            <td class="p-3">
              <span class={`px-2.5 py-1 rounded font-mono font-bold text-sm ${
                row.type === 'B' ? 'bg-accent/10 text-accent border border-accent/20' :
                row.type === 'C' ? 'bg-amber-500/10 text-amber-500 border border-amber-500/20' :
                                   'bg-danger/10 text-danger border border-danger/20'
              }`}>Type {row.type}</span>
            </td>
            <td class="p-3 font-mono text-xs text-text-primary font-semibold">{row.threshold} rated current</td>
            <td class="p-3 text-xs text-text-muted leading-relaxed">{row.loads}</td>
            <td class="p-3 text-xs text-danger leading-relaxed">{row.avoid}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="example-box">
    <p class="example-label">Reading the label on your MCB</p>
    <p class="text-sm text-text-secondary">
      The label on the front face of every MCB shows the curve letter followed immediately by the
      ampere rating. Examples:
    </p>
    <ul class="mt-3 space-y-2 list-none text-sm text-text-secondary">
      <li class="flex items-start gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <span><code class="text-sm font-mono font-bold">B16</code> — Type B curve, 16 Amps. Correct for a general lighting or socket circuit.</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <span><code class="text-sm font-mono font-bold">C16</code> — Type C curve, 16 Amps. Correct for a 1.5 Ton AC or water pump circuit.</span>
      </li>
      <li class="flex items-start gap-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-danger mt-0.5 flex-shrink-0" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        <span><code class="text-sm font-mono font-bold">B16 on an AC circuit</code> — Wrong curve type. Will trip every time the compressor starts, even though the wiring and appliance are both fine.</span>
      </li>
    </ul>
  </div>

  <!-- ⑤ WIRE GAUGE PAIRING -->
  <h2 id="wire-pairing">MCB ↔ Wire Gauge Pairing — The Rule You Cannot Break</h2>

  <p>
    The MCB and the cable it protects are a matched pair. The breaker's ampere rating must
    <strong>never exceed the cable's current-carrying capacity</strong>. If it does, the cable can
    overheat and catch fire before the breaker trips — because the breaker is set to allow more
    current than the wire can safely handle.
  </p>
  <p>
    This is why you cannot simply swap a 16A breaker for a 32A breaker when trips become annoying.
    The wiring in your wall was installed to match the original 16A breaker. A 32A breaker on
    that same wiring is a hidden fire hazard from day one.
  </p>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Copper Wire Gauge</th>
          <th>Safe Current Capacity</th>
          <th>Maximum MCB Rating</th>
          <th>Typical Application</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>1.0 mm²</code></td>
          <td>10–12A</td>
          <td><strong>6A</strong></td>
          <td>Light fittings, very small loads</td>
        </tr>
        <tr>
          <td><code>1.5 mm²</code></td>
          <td>13–15A</td>
          <td><strong>6A or 10A</strong></td>
          <td>Lighting circuits, small fan circuits</td>
        </tr>
        <tr>
          <td><code>2.5 mm²</code></td>
          <td>18–20A</td>
          <td><strong>16A or 20A</strong></td>
          <td>General power sockets, ACs up to 1.5 Ton, small pumps</td>
        </tr>
        <tr>
          <td><code>4 mm²</code></td>
          <td>25–27A</td>
          <td><strong>25A or 32A</strong></td>
          <td>Geysers, 2 Ton ACs, kitchen heavy circuits</td>
        </tr>
        <tr>
          <td><code>6 mm²</code></td>
          <td>32–35A</td>
          <td><strong>32A or 40A</strong></td>
          <td>Sub-distribution board feeders</td>
        </tr>
        <tr>
          <td><code>10 mm²</code></td>
          <td>44–50A</td>
          <td><strong>40A or 50A</strong></td>
          <td>Main incomer feeder for apartments</td>
        </tr>
        <tr>
          <td><code>16 mm²</code></td>
          <td>60–65A</td>
          <td><strong>63A</strong></td>
          <td>Main incomer feeder for large homes / commercial</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p class="text-sm text-text-muted mt-4">
    <strong>Note:</strong> Current-carrying capacities above assume PVC-insulated copper conductors
    in conduit at 30°C ambient temperature. Values derate in high-temperature environments such
    as roof spaces — consult IS 1646 for full derating tables.
  </p>

  <!-- ⑥ REAL EXAMPLES -->
  <h2 id="real-examples">Real Sizing Examples — Every Common Home Circuit</h2>
  <p>
    Here is the 4-step formula applied to the most frequently asked-about circuits in Indian homes.
    Keep these as your reference — they cover the vast majority of residential sizing decisions.
  </p>

  <div class="example-box">
    <p class="example-label">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accent inline-block mr-1.5 align-middle -translate-y-[1px]" aria-hidden="true"><path d="M9 12l2 2 4-4"/><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/></svg>
      Example 1 — Lighting Circuit (LEDs + Fans)
    </p>
    <p>You have one circuit feeding 8 LED bulbs (9W each) and 3 ceiling fans (75W each).</p>
    <ul class="mt-2 space-y-1 text-sm">
      <li><strong>Step 1 (Watts):</strong> (8 × 9) + (3 × 75) = 72 + 225 = <strong>297W</strong></li>
      <li><strong>Step 2 (Current):</strong> 297 ÷ 230 = <strong>1.29A</strong></li>
      <li><strong>Step 3 (Safety):</strong> 1.29 × 1.25 = <strong>1.61A</strong></li>
      <li><strong>Step 4 (Rating):</strong> Next standard size above 1.61A = <strong>6A Type B</strong></li>
    </ul>
    <p class="mt-2 text-xs text-text-muted">Wire: 1.5 mm² is adequate and standard for lighting circuits.</p>
  </div>

  <div class="example-box">
    <p class="example-label">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accent inline-block mr-1.5 align-middle -translate-y-[1px]" aria-hidden="true"><path d="M9 12l2 2 4-4"/><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/></svg>
      Example 2 — Dedicated 1.5 Ton AC Circuit
    </p>
    <p>A 1.5 Ton inverter split AC is rated at 1,600W continuous running power.</p>
    <ul class="mt-2 space-y-1 text-sm">
      <li><strong>Step 1 (Watts):</strong> <strong>1,600W</strong></li>
      <li><strong>Step 2 (Current):</strong> 1,600 ÷ 230 = <strong>6.96A</strong></li>
      <li><strong>Step 3 (Safety):</strong> 6.96 × 1.25 = <strong>8.70A</strong></li>
      <li><strong>Step 4 (Rating):</strong> Next size above 8.70A = 10A. But AC compressors have inrush surges of 30–40A, so the industry standard is <strong>16A Type C</strong> on a dedicated circuit.</li>
    </ul>
    <p class="mt-2 text-xs text-text-muted">Wire: 2.5 mm² on a dedicated circuit. Do not share this circuit with other sockets.</p>
  </div>

  <div class="example-box">
    <p class="example-label">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accent inline-block mr-1.5 align-middle -translate-y-[1px]" aria-hidden="true"><path d="M9 12l2 2 4-4"/><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/></svg>
      Example 3 — Electric Geyser (Water Heater)
    </p>
    <p>A 2,000W instant geyser on a dedicated circuit.</p>
    <ul class="mt-2 space-y-1 text-sm">
      <li><strong>Step 1 (Watts):</strong> <strong>2,000W</strong></li>
      <li><strong>Step 2 (Current):</strong> 2,000 ÷ 230 = <strong>8.70A</strong></li>
      <li><strong>Step 3 (Safety):</strong> 8.70 × 1.25 = <strong>10.87A</strong></li>
      <li><strong>Step 4 (Rating):</strong> Next size above 10.87A = <strong>16A Type B</strong>. Geysers are purely resistive — no motor, no inrush surge — so Type B is correct and provides tighter, faster protection.</li>
    </ul>
    <p class="mt-2 text-xs text-text-muted">Wire: 2.5 mm² minimum. For 3,000W geysers, use 4 mm² cable and a 20A breaker.</p>
  </div>

  <div class="example-box">
    <p class="example-label">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accent inline-block mr-1.5 align-middle -translate-y-[1px]" aria-hidden="true"><path d="M9 12l2 2 4-4"/><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/></svg>
      Example 4 — 1.5 HP Submersible Water Pump
    </p>
    <p>A submersible pump rated at 1,100W (1.5 HP) with high starting inrush.</p>
    <ul class="mt-2 space-y-1 text-sm">
      <li><strong>Step 1 (Watts):</strong> <strong>1,100W</strong></li>
      <li><strong>Step 2 (Current):</strong> 1,100 ÷ 230 = <strong>4.78A</strong></li>
      <li><strong>Step 3 (Safety):</strong> 4.78 × 1.25 = <strong>5.98A</strong></li>
      <li><strong>Step 4 (Rating):</strong> Next size above 5.98A = 6A — but pumps have very high inrush. A <strong>16A Type C</strong> is the safe recommendation to absorb the starting surge without nuisance tripping.</li>
    </ul>
    <p class="mt-2 text-xs text-text-muted">
      This is a case where formula alone undersizes — pump inrush can hit 5–8× running current.
      Real-world install: 16A Type C on 2.5 mm² wire.
      For more on inrush tripping, see our guide on
      <a href="/knowledge-hub/mcb-sizing/why-does-my-mcb-keep-tripping" class="text-accent hover:underline">why MCBs keep tripping</a>.
    </p>
  </div>

  <div class="example-box">
    <p class="example-label">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-accent inline-block mr-1.5 align-middle -translate-y-[1px]" aria-hidden="true"><path d="M9 12l2 2 4-4"/><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/></svg>
      Example 5 — Main Incomer for a 3 BHK Apartment
    </p>
    <p>
      A 3 BHK home with 2 ACs (1.5T + 1T), a geyser, a fridge, a washing machine, lighting, and
      general sockets. Estimated peak simultaneous draw is 7,500W.
    </p>
    <ul class="mt-2 space-y-1 text-sm">
      <li><strong>Step 1 (Watts):</strong> <strong>7,500W</strong> (estimated peak)</li>
      <li><strong>Step 2 (Current):</strong> 7,500 ÷ 230 = <strong>32.6A</strong></li>
      <li><strong>Step 3 (Safety):</strong> 32.6 × 1.25 = <strong>40.8A</strong></li>
      <li><strong>Step 4 (Rating):</strong> Next standard size = <strong>40A or 63A Type C</strong> for the main incomer. Coordinate with your electricity utility — the sanctioned load on your meter must match or exceed your total connected load.</li>
    </ul>
    <p class="mt-2 text-xs text-text-muted">Wire: 10–16 mm² for the incomer cable from meter to main DB. Consult a licensed electrician for main incomer work.</p>
  </div>

  <KnowledgeHubCTA
    variant="inline"
    id="use-the-calculator"
  />

