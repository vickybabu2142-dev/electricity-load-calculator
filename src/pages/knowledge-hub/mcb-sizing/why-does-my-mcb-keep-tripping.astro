<KnowledgeHubLayout
  title="Why Does My MCB Keep Tripping? The Expert Diagnosis Guide"
  description="A homeowner's deep-dive into why circuit breakers trip. Covers overloads, short circuits, motor surges, ground faults, and aging breakers — with a trip-behaviour chart, Common Mistakes section, and a safe 4-step reset checklist."
  keywords="why does my mcb keep tripping, circuit breaker keeps tripping, mcb trip diagnosis, overload short circuit ground fault, how to reset mcb safely"
  breadcrumb={[
    { label: 'Home',          href: '/' },
    { label: 'Knowledge Hub', href: '/knowledge-hub' },
    { label: 'MCB Sizing',    href: '/knowledge-hub/mcb-sizing' },
    { label: 'Why MCB Keeps Tripping' },
  ]}
