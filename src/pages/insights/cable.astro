---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<BaseLayout title="Cable Recommendation | Electricity Load Calculator" description="Find the right wire/cable size for your electrical load.">
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Cable Recommendation' }]} />

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-8 pb-16">
    <div class="max-w-2xl mx-auto">
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-6">

        <!-- Header -->
        <div class="flex items-start gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-base flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 text-accent" aria-hidden="true">
              <path d="M4 12h16M7 5v14M17 5v14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            </svg>
          </span>
          <div class="pt-0.5">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1.5 text-text-muted">Cable Recommendation</p>
            <h1 class="font-display font-bold text-2xl sm:text-3xl text-text-primary leading-tight">Copper Wire / Cable Size</h1>
          </div>
        </div>

        <!-- Recommended value -->
        <div class="rounded-xl border border-border bg-base p-6 text-center">
          <p class="text-[10px] font-mono uppercase tracking-widest mb-3 text-text-muted">Recommended Size</p>
          <p id="insight-value" class="font-display font-bold text-5xl tracking-tight text-accent">—</p>
          <p id="insight-context" class="text-sm text-text-muted mt-3"></p>
        </div>

        <!-- Educational content -->
        <div class="space-y-3 text-sm text-text-muted leading-relaxed">
          <h2 class="font-display font-semibold text-text-primary text-lg">Why cable size matters</h2>
          <p>Using undersized cable causes excessive heat, voltage drops, and is a fire hazard. Using oversized cable wastes money. The cross-sectional area (sq mm) determines how much current the cable can safely carry.</p>
          <p><strong class="text-text-primary">Copper</strong> conductors are preferred for their low resistance, flexibility, and long-term reliability.</p>
          <h2 class="font-display font-semibold text-text-primary text-lg mt-4">Standard copper cable ratings</h2>
          <div class="rounded-lg border border-border bg-base overflow-hidden">
            <table class="w-full text-xs font-mono">
              <thead><tr class="border-b border-border"><th class="text-left px-3 py-2 text-text-muted">MCB Rating</th><th class="text-left px-3 py-2 text-text-muted">Cable Size</th></tr></thead>
              <tbody>
                {[['6A','1.0 sq mm'],['10A','1.5 sq mm'],['16A','2.5 sq mm'],['25A','4 sq mm'],['32A','6 sq mm'],['40A','10 sq mm'],['63A','16 sq mm']].map(([r,c]) => (
                  <tr class="border-b border-border last:border-0">
                    <td class="px-3 py-2 text-text-primary">{r}</td>
                    <td class="px-3 py-2 text-accent">{c}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="flex gap-2.5 mt-3 p-3.5 rounded-lg border" style="border-color:color-mix(in srgb, var(--warning), transparent 55%); background:color-mix(in srgb, var(--warning), transparent 90%)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:var(--warning)" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/>
            </svg>
            <p class="text-xs text-text-primary leading-relaxed">These recommendations are estimates. Always verify with a licensed electrician based on cable run length and installation method.</p>
          </div>
        </div>

      </div>
    </div>
  </main>
</BaseLayout>

<script>
  function init() {
    const params = new URLSearchParams(window.location.search);
    const value = params.get('value');
    const load = params.get('load');

    const valueEl = document.getElementById('insight-value');
    const contextEl = document.getElementById('insight-context');

    if (valueEl) valueEl.textContent = value || '—';
    if (contextEl) {
      const kw = parseFloat(load || '');
      contextEl.textContent = load && !isNaN(kw) ? `For a ${kw.toFixed(2)} kW connected load` : '';
    }
  }

  document.addEventListener('astro:page-load', init);
</script>
