---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<BaseLayout title="Inverter Recommendation | Electricity Load Calculator" description="Find the right inverter or UPS size for your electrical load.">
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Inverter Recommendation' }]} />

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-8 pb-16">
    <div class="max-w-2xl mx-auto">
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-6">

        <!-- Header -->
        <div class="flex items-start gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-base flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-accent" aria-hidden="true">
              <path d="M4 7h16a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Zm14 2H6v6h12V9Zm2-3h1v2h-1V6Zm-17 0H2v2h1V6Z"/>
            </svg>
          </span>
          <div class="pt-0.5">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1.5 text-text-muted">Inverter Recommendation</p>
            <h1 class="font-display font-bold text-2xl sm:text-3xl text-text-primary leading-tight">Inverter / UPS Size</h1>
          </div>
        </div>

        <!-- Recommended value -->
        <div class="rounded-xl border border-border bg-base p-6 text-center">
          <p class="text-[10px] font-mono uppercase tracking-widest mb-3 text-text-muted">Recommended Size</p>
          <p id="insight-value" class="font-display font-bold text-5xl tracking-tight text-accent">—</p>
          <p id="insight-context" class="text-sm text-text-muted mt-3"></p>
        </div>

        <!-- Educational content -->
        <div class="space-y-3 text-sm text-text-muted leading-relaxed">
          <h2 class="font-display font-semibold text-text-primary text-lg">What is inverter kVA?</h2>
          <p>kVA (kilovolt-ampere) is the apparent power rating of an inverter. The actual usable power (kW) depends on the power factor — typically 0.8 for home inverters.</p>
          <p>We recommend sizing your inverter at <strong class="text-text-primary">1.2× your total load</strong> to handle surge currents from motors and compressors (e.g. refrigerators, ACs).</p>
          <h2 class="font-display font-semibold text-text-primary text-lg mt-4">Standard inverter sizes</h2>
          <div class="flex flex-wrap gap-2">
            {['1 kVA','2 kVA','3 kVA','5 kVA','7.5 kVA','10 kVA','15 kVA'].map(s => (
              <span id={`std-${s}`} class="px-3 py-1 rounded-full border border-border font-mono text-xs text-text-muted bg-base">{s}</span>
            ))}
          </div>
          <div class="flex gap-2.5 mt-3 p-3.5 rounded-lg border" style="border-color:color-mix(in srgb, var(--warning), transparent 55%); background:color-mix(in srgb, var(--warning), transparent 90%)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:var(--warning)" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/>
            </svg>
            <p class="text-xs text-text-primary leading-relaxed">Battery backup duration depends on battery capacity (Ah), which is not covered here. Consult an inverter specialist for battery sizing.</p>
          </div>
        </div>

      </div>
    </div>
  </main>
</BaseLayout>

<script>
  function init() {
    const params = new URLSearchParams(window.location.search);
    const value = params.get('value');
    const load = params.get('load');

    const valueEl = document.getElementById('insight-value');
    const contextEl = document.getElementById('insight-context');

    if (valueEl) valueEl.textContent = value || '—';

    if (value) {
      document.querySelectorAll<HTMLElement>('[id^="std-"]').forEach(chip => {
        chip.style.borderColor = '';
        chip.style.color = '';
        chip.style.background = '';
      });
      const chip = document.getElementById(`std-${value}`);
      if (chip) {
        chip.style.borderColor = 'var(--accent)';
        chip.style.color = 'var(--accent)';
        chip.style.background = 'color-mix(in srgb, var(--accent), transparent 90%)';
      }
    }

    if (contextEl) contextEl.textContent = load ? `For a ${parseFloat(load).toFixed(2)} kW connected load` : '';
  }

  document.addEventListener('astro:page-load', init);
</script>
