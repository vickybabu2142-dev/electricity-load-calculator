---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

const schemaGraph = [
  {
    "@type": "Article",
    "headline": "Inverter & UPS Sizing Guide: Backup Power for Your Home",
    "description": "How to calculate the right inverter capacity (kVA) and battery bank for your household appliances and backup requirements.",
    "author": {
      "@type": "Organization",
      "name": "Electricity Load Calculator"
    }
  }
];
---

<BaseLayout
  title="Inverter / UPS Size Recommendation | Electricity Load Calculator"
  description="Calculate the ideal inverter and UPS size for your home. Guidance on VA ratings, battery backup hours, and pure sine wave vs square wave inverters."
  keywords="inverter size calculator, UPS for home, kVA to Watts calculator, pure sine wave inverter guide, battery backup calculation"
  schemaGraph={schemaGraph}
>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Inverter Recommendation' }]} />

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-8 pb-16">
    <div class="max-w-2xl mx-auto space-y-4">

      <!-- ① Header -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8">
        <div class="flex items-start gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-base flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-accent" aria-hidden="true">
              <path d="M4 7h16a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Zm14 2H6v6h12V9Zm2-3h1v2h-1V6Zm-17 0H2v2h1V6Z"/>
            </svg>
          </span>
          <div class="pt-0.5">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1.5 text-text-muted">Inverter Recommendation</p>
            <h1 class="font-display font-bold text-2xl sm:text-3xl text-text-primary leading-tight">Inverter / UPS Size</h1>
          </div>
        </div>
      </div>

      <!-- ② Personalized Recommendation -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8">
        <p class="text-[10px] font-mono uppercase tracking-widest mb-4 text-text-muted">Your Recommendation</p>
        <div class="rounded-xl border border-border bg-base p-6 text-center">
          <p class="text-[10px] font-mono uppercase tracking-widest mb-3 text-text-muted">Recommended Size</p>
          <p id="insight-value" class="font-display font-bold text-5xl tracking-tight text-accent">—</p>
          <p id="insight-context" class="text-sm text-text-muted mt-3"></p>
        </div>
        <!-- Standard sizes chips -->
        <div class="flex flex-wrap gap-2 mt-4">
          {['1 kVA','2 kVA','3 kVA','5 kVA','7.5 kVA','10 kVA','15 kVA'].map(s => (
            <span id={`std-${s}`} class="px-3 py-1 rounded-full border border-border font-mono text-xs text-text-muted bg-base">{s}</span>
          ))}
        </div>
        <p class="text-xs text-text-muted mt-4 text-center">
          Don't have a result yet? <a href="/" class="text-accent hover:underline">Calculate your load first →</a>
        </p>
      </div>

      <!-- ③ Calculation Breakdown -->
      <div id="calc-section" class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-4" style="display:none">
        <h2 class="font-display font-semibold text-text-primary text-lg">How This Was Calculated</h2>
        <div class="space-y-2">

          <div class="flex items-center gap-3 p-3 rounded-lg bg-base border border-border">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-mono font-bold flex-shrink-0">1</span>
            <div class="flex-1 min-w-0">
              <p class="text-xs text-text-muted">Your total connected load</p>
              <p class="font-mono font-semibold text-text-primary"><span id="inv-load">—</span> kW</p>
            </div>
          </div>

          <div class="flex items-center gap-3 p-3 rounded-lg bg-base border border-border">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-mono font-bold flex-shrink-0">2</span>
            <div class="flex-1 min-w-0">
              <p class="text-xs text-text-muted">Apply 1.2× sizing factor for motor surge currents (<span id="inv-load2">—</span> kW × 1.2)</p>
              <p class="font-mono font-semibold text-text-primary">= <span id="inv-required">—</span> kVA required</p>
            </div>
          </div>

          <div class="flex items-center gap-3 p-3 rounded-lg border" style="border-color:color-mix(in srgb, var(--accent), transparent 55%); background:color-mix(in srgb, var(--accent), transparent 90%)">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-accent text-[var(--base)] text-xs font-mono font-bold flex-shrink-0">3</span>
            <div class="flex-1 min-w-0">
              <p class="text-xs text-text-muted">Nearest standard inverter size above <span id="inv-required2">—</span> kVA</p>
              <p class="font-mono font-bold text-accent text-lg"><span id="inv-result">—</span></p>
            </div>
          </div>
        </div>
      </div>

      <!-- ④ What This Means + Backup Estimation -->
      <div id="means-section" class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-5" style="display:none">
        <h2 class="font-display font-semibold text-text-primary text-lg">What This Means For You</h2>

        <ul class="space-y-2">
          {[
            'Comfortably handles your entire connected load',
            '20% headroom absorbs motor startup surge currents',
            'Room to add appliances without upgrading the inverter',
          ].map(item => (
            <li class="flex items-start gap-2.5 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 mt-0.5 flex-shrink-0 text-accent" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/>
              </svg>
              <span class="text-text-primary">{item}</span>
            </li>
          ))}
        </ul>

        <!-- Backup estimation table -->
        <div>
          <h3 class="font-display font-semibold text-text-primary text-sm mb-3">Estimated Backup Duration</h3>
          <p class="text-xs text-text-muted mb-3">Based on 150Ah / 12V tubular batteries. Actual duration depends on your load at time of outage.</p>
          <div class="rounded-lg border border-border bg-base overflow-hidden">
            <table class="w-full text-xs font-mono">
              <thead>
                <tr class="border-b border-border">
                  <th class="text-left px-3 py-2 text-text-muted">Batteries</th>
                  <th class="text-left px-3 py-2 text-text-muted">Total Capacity</th>
                  <th class="text-left px-3 py-2 text-text-muted">Approx. Backup</th>
                </tr>
              </thead>
              <tbody id="backup-table">
                <!-- JS renders rows based on load -->
              </tbody>
            </table>
          </div>
          <p class="text-xs text-text-muted mt-2">Formula: Backup hours ≈ (Batteries × 150Ah × 12V × 0.8 efficiency) ÷ Load Watts</p>
        </div>
      </div>

      <!-- ⑤ Educational Content -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-5">
        <h2 class="font-display font-semibold text-text-primary text-lg">Understanding Inverters</h2>

        <div class="space-y-3 text-sm text-text-muted leading-relaxed">
          <h3 class="font-display font-semibold text-text-primary">kW vs kVA — What's the Difference?</h3>
          <p><strong class="text-text-primary">kW (kilowatts)</strong> is real power — the actual work done by your appliances. <strong class="text-text-primary">kVA (kilovolt-amperes)</strong> is apparent power — what the inverter must supply, accounting for power factor losses in motors and inductive loads.</p>
          <p>Typical home inverter power factor: <strong class="text-text-primary">0.8</strong>. So a 5 kVA inverter delivers about 4 kW of usable power.</p>
          <div class="rounded-lg border border-border bg-base p-3 font-mono text-xs text-accent">
            kW = kVA × Power Factor (0.8)
          </div>
        </div>

        <div class="space-y-3 text-sm text-text-muted leading-relaxed">
          <h3 class="font-display font-semibold text-text-primary">Inverter vs UPS</h3>
          <div class="rounded-lg border border-border bg-base overflow-hidden">
            <table class="w-full text-xs font-mono">
              <thead>
                <tr class="border-b border-border">
                  <th class="text-left px-3 py-2 text-text-muted">Feature</th>
                  <th class="text-left px-3 py-2 text-text-muted">Home Inverter</th>
                  <th class="text-left px-3 py-2 text-text-muted">Online UPS</th>
                </tr>
              </thead>
              <tbody>
                {[
                  ['Switchover time', '10–20 ms', '0 ms (zero)'],
                  ['Best for', 'Fans, lights, TVs', 'Computers, servers'],
                  ['Battery life', '3–5 years', '2–4 years'],
                  ['Cost', 'Lower', 'Higher'],
                ].map(([feat, inv, ups]) => (
                  <tr class="border-b border-border last:border-0">
                    <td class="px-3 py-2 text-text-muted">{feat}</td>
                    <td class="px-3 py-2 text-text-primary">{inv}</td>
                    <td class="px-3 py-2 text-text-primary">{ups}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div class="flex gap-2.5 p-3.5 rounded-lg border" style="border-color:color-mix(in srgb, var(--warning), transparent 55%); background:color-mix(in srgb, var(--warning), transparent 90%)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:var(--warning)" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/>
          </svg>
          <p class="text-xs text-text-primary leading-relaxed">Battery backup duration is not covered by this recommendation. Battery sizing depends on your required backup hours and should be discussed with an inverter specialist.</p>
        </div>
      </div>

      <!-- ⑥ FAQ -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-3">
        <h2 class="font-display font-semibold text-text-primary text-lg">Frequently Asked Questions</h2>
        <div class="space-y-2">
          {[
            {
              q: 'What inverter size do I need for my home?',
              a: 'Add up the wattage of all appliances you want to run during a power cut, then multiply by 1.2 to account for startup surges. Select the nearest standard inverter size above that figure. Our calculator does this automatically from your appliance list.',
            },
            {
              q: 'Can a smaller inverter handle my load?',
              a: 'If the inverter kVA is less than your actual load, it will overload and either shut down or degrade rapidly. Some inverters tolerate brief overloads (e.g. during startup), but running at or above rated capacity continuously shortens their lifespan significantly.',
            },
            {
              q: 'How is backup time calculated?',
              a: 'Backup time (hours) = (Battery capacity in Ah × Voltage × Efficiency) ÷ Load in Watts. For a 150Ah, 12V battery at 80% efficiency powering a 500W load: (150 × 12 × 0.8) ÷ 500 = 2.88 hours.',
            },
            {
              q: 'What is the difference between a pure sine wave and modified sine wave inverter?',
              a: 'Pure sine wave inverters produce AC power identical to the grid — safe for all appliances including sensitive electronics and motors. Modified sine wave inverters are cheaper but can cause humming in motors, reduced efficiency, and may damage some devices.',
            },
          ].map(({ q, a }) => (
            <details class="rounded-lg border border-border bg-base group">
              <summary class="flex items-center justify-between gap-3 px-4 py-3.5 cursor-pointer list-none text-sm font-semibold text-text-primary">
                <span>{q}</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0 text-text-muted transition-transform group-open:rotate-180" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
                </svg>
              </summary>
              <p class="px-4 pb-4 pt-1 text-sm text-text-muted leading-relaxed">{a}</p>
            </details>
          ))}
        </div>
      </div>

      <!-- ⑦ Related Recommendations -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-3">
        <h2 class="font-display font-semibold text-text-primary text-lg">Related Recommendations</h2>
        <p class="text-sm text-text-muted">Your load calculation also informs these selections.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <a id="rel-mcb" href="/insights/mcb" class="flex items-center gap-3 p-3.5 rounded-lg border border-border bg-base hover:border-accent/50 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-accent flex-shrink-0" aria-hidden="true">
              <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs font-mono uppercase tracking-widest text-text-muted">MCB</p>
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">Breaker Rating →</p>
            </div>
          </a>
          <a id="rel-cable" href="/insights/cable" class="flex items-center gap-3 p-3.5 rounded-lg border border-border bg-base hover:border-accent/50 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5 text-accent flex-shrink-0" aria-hidden="true">
              <path d="M4 12h16M7 5v14M17 5v14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs font-mono uppercase tracking-widest text-text-muted">Cable</p>
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">Wire Size →</p>
            </div>
          </a>
          <a id="rel-solar" href="/insights/solar" class="flex items-center gap-3 p-3.5 rounded-lg border border-border bg-base hover:border-accent/50 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-accent flex-shrink-0" aria-hidden="true">
              <path d="M12 2a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1Zm0 15a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm8-6a1 1 0 0 1 0 2h-1a1 1 0 1 1 0-2h1ZM5 11a1 1 0 0 1 0 2H4a1 1 0 1 1 0-2h1Zm14.07-6.07a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0ZM6.34 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0Zm12.02 1.41a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 1 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41ZM5.64 5.64a1 1 0 0 1 1.41 0l.71.71A1 1 0 1 1 6.34 7.76l-.71-.71a1 1 0 0 1 0-1.41ZM12 20a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1Z"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs font-mono uppercase tracking-widest text-text-muted">Solar</p>
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">Panel Size →</p>
            </div>
          </a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
  const STD_SIZES = [1, 2, 3, 5, 7.5, 10, 15];
  const MCB_RATINGS = [6, 10, 16, 20, 25, 32, 40, 50, 63, 80, 100];
  const CABLE_SIZE: Record<number, string> = {6:'1.0 sq mm',10:'1.5 sq mm',16:'2.5 sq mm',20:'4 sq mm',25:'4 sq mm',32:'6 sq mm',40:'10 sq mm',50:'16 sq mm',63:'16 sq mm',80:'25 sq mm',100:'35 sq mm'};

  function nextSize(kva: number): number {
    return STD_SIZES.find(s => s >= kva) ?? STD_SIZES[STD_SIZES.length - 1];
  }

  function computeValues(load: number, monthly: number) {
    if (!load || !monthly) return null;
    const design = (load * 1000 / 230) * 1.25;
    const mcbA = MCB_RATINGS.find(r => r >= design) ?? MCB_RATINGS[MCB_RATINGS.length - 1];
    const invKVA = nextSize(load * 1.2);
    const solarKW = Math.ceil((monthly / 120) * 2) / 2;
    return {
      mcb: `${mcbA}A C-Curve`,
      cable: `${CABLE_SIZE[mcbA] ?? '6 sq mm'} Copper`,
      inverter: `${invKVA} kVA`,
      solar: `${solarKW} kW Solar System`,
    };
  }

  function init() {
    const params = new URLSearchParams(window.location.search);
    const load = parseFloat(params.get('load') || '');
    const monthly = parseInt(params.get('monthly') || '', 10);
    const value = params.get('value') || '';

    const valueEl = document.getElementById('insight-value');
    const contextEl = document.getElementById('insight-context');
    if (valueEl) valueEl.textContent = value || '—';
    if (contextEl) contextEl.textContent = !isNaN(load) && load > 0 ? `For a ${load.toFixed(2)} kW connected load` : '';

    // Highlight selected standard size chip
    if (value) {
      document.querySelectorAll<HTMLElement>('[id^="std-"]').forEach(chip => {
        chip.style.borderColor = '';
        chip.style.color = '';
        chip.style.background = '';
      });
      const chip = document.getElementById(`std-${value}`);
      if (chip) {
        chip.style.borderColor = 'var(--accent)';
        chip.style.color = 'var(--accent)';
        chip.style.background = 'color-mix(in srgb, var(--accent), transparent 90%)';
      }
    }

    // Related links — include computed values for destination pages
    const base = `?load=${params.get('load') || ''}&monthly=${params.get('monthly') || ''}&bill=${params.get('bill') || ''}`;
    const vals = computeValues(load, monthly);
    (['mcb', 'cable', 'solar'] as const).forEach(type => {
      const el = document.getElementById(`rel-${type}`) as HTMLAnchorElement | null;
      if (el) el.href = `/insights/${type}${base}${vals ? `&value=${encodeURIComponent(vals[type])}` : ''}`;
    });

    if (isNaN(load) || load <= 0) return;

    const required = load * 1.2;
    const selected = nextSize(required);

    const setText = (id: string, text: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    };

    setText('inv-load', load.toFixed(2));
    setText('inv-load2', load.toFixed(2));
    setText('inv-required', required.toFixed(2));
    setText('inv-required2', required.toFixed(2));
    setText('inv-result', value || `${selected} kVA`);

    // Backup estimation table
    const watts = load * 1000;
    const batteryWh = 150 * 12 * 0.8; // 1440 Wh per battery
    const tbody = document.getElementById('backup-table');
    if (tbody) {
      tbody.innerHTML = [2, 4, 6].map(n => {
        const hours = (n * batteryWh) / watts;
        return `<tr class="border-b border-border last:border-0">
          <td class="px-3 py-2 text-text-primary">${n} batteries</td>
          <td class="px-3 py-2 text-text-muted">${(n * 1.44).toFixed(1)} kWh</td>
          <td class="px-3 py-2 text-accent font-semibold">~${hours.toFixed(1)} hrs</td>
        </tr>`;
      }).join('');
    }

    const calcSection = document.getElementById('calc-section');
    const meansSection = document.getElementById('means-section');
    if (calcSection) calcSection.style.display = '';
    if (meansSection) meansSection.style.display = '';
  }

  document.addEventListener('astro:page-load', init);
</script>
