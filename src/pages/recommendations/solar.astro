---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<BaseLayout
  title="Solar Panel Recommendation | Electrical Assessment | Electricity Load Calculator"
  description="Your personalised solar panel capacity recommendation based on your monthly energy consumption. Includes calculation breakdown, payback period guidance, and system sizing tips."
  keywords="solar panel recommendation, solar system size, rooftop solar calculator, solar kW calculator, solar for home India"
>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Assessment', href: '/assessment' }, { label: 'Solar Recommendation' }]} />

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-8 pb-16">
    <div class="max-w-2xl mx-auto space-y-4">

      <!-- Back link -->
      <a href="/assessment" class="flex-shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-lg border text-sm font-medium transition-colors" style="color:var(--accent); border-color:color-mix(in srgb,var(--accent),transparent 60%); background:color-mix(in srgb,var(--accent),transparent 92%)">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd"/>
        </svg>
        Back to Assessment
      </a>

      <!-- ① Header -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8">
        <div class="flex items-start gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-base flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-accent" aria-hidden="true">
              <path d="M12 2a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1Zm0 15a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm8-6a1 1 0 0 1 0 2h-1a1 1 0 1 1 0-2h1ZM5 11a1 1 0 0 1 0 2H4a1 1 0 1 1 0-2h1Zm14.07-6.07a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0ZM6.34 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0Zm12.02 1.41a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 1 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41ZM5.64 5.64a1 1 0 0 1 1.41 0l.71.71A1 1 0 1 1 6.34 7.76l-.71-.71a1 1 0 0 1 0-1.41ZM12 20a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1Z"/>
            </svg>
          </span>
          <div class="pt-0.5">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1.5 text-text-muted">Solar Recommendation</p>
            <h1 class="font-display font-bold text-2xl sm:text-3xl text-text-primary leading-tight">Rooftop Solar System</h1>
          </div>
        </div>
      </div>

      <!-- ② Personalised Recommendation -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-4">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Your Recommendation</p>

        <div id="rec-empty" class="text-center py-4 text-sm text-text-muted">
          No assessment data found.
          <a href="/" class="text-accent hover:underline ml-1">Calculate your load first →</a>
        </div>

        <div id="rec-result" style="display:none">
          <div class="rounded-xl border border-border bg-base p-6 text-center mb-4">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-3 text-text-muted">Recommended Solar Capacity</p>
            <p id="rec-value" class="font-display font-bold text-5xl tracking-tight text-accent">—</p>
            <p id="rec-context" class="text-sm text-text-muted mt-3"></p>
          </div>

          <div class="space-y-2">
            <div class="flex items-center gap-3 p-3 rounded-lg bg-base border border-border">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-mono font-bold flex-shrink-0">1</span>
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-muted">Your monthly electricity consumption</p>
                <p class="font-mono font-semibold text-text-primary"><span id="solar-monthly">—</span> kWh/month</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg bg-base border border-border">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-mono font-bold flex-shrink-0">2</span>
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-muted">Daily consumption (<span id="solar-monthly2">—</span> kWh ÷ 30)</p>
                <p class="font-mono font-semibold text-text-primary">= <span id="solar-daily">—</span> kWh/day</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg bg-base border border-border">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-mono font-bold flex-shrink-0">3</span>
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-muted">Required capacity (÷ 4 sun-hours, ÷ 0.8 system efficiency)</p>
                <p class="font-mono font-semibold text-text-primary">= <span id="solar-calc">—</span> kW</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg border" style="border-color:color-mix(in srgb, var(--accent), transparent 55%); background:color-mix(in srgb, var(--accent), transparent 90%)">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-accent text-[var(--base)] text-xs font-mono font-bold flex-shrink-0">4</span>
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-muted">Rounded to nearest standard system size</p>
                <p class="font-mono font-bold text-accent text-lg"><span id="solar-rating">—</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ③ Educational Content -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-5">
        <h2 class="font-display font-semibold text-text-primary text-lg">Understanding Solar Systems</h2>

        <div class="space-y-3 text-sm text-text-muted leading-relaxed">
          <h3 class="font-display font-semibold text-text-primary">How Solar Sizing Works</h3>
          <p>A solar panel system's size (in kWp — kilowatt-peak) determines how much electricity it generates. The calculation depends on your daily consumption, the number of peak sun hours in your location, and system efficiency losses (~20% typical).</p>
          <p><strong class="text-text-primary">Formula:</strong> System size (kW) = Daily kWh ÷ (Peak Sun Hours × System Efficiency)</p>
        </div>

        <div class="space-y-3 text-sm text-text-muted leading-relaxed">
          <h3 class="font-display font-semibold text-text-primary">Standard Residential System Sizes</h3>
          <div class="rounded-lg border border-border bg-base overflow-hidden">
            <table class="w-full text-xs font-mono">
              <thead>
                <tr class="border-b border-border">
                  <th class="text-left px-3 py-2 text-text-muted">System</th>
                  <th class="text-left px-3 py-2 text-text-muted">Monthly Gen.</th>
                  <th class="text-left px-3 py-2 text-text-muted">Best For</th>
                </tr>
              </thead>
              <tbody>
                {[
                  ['1 kWp', '~90–110 kWh', 'Studio / 1 BHK'],
                  ['2 kWp', '~180–220 kWh', '1–2 BHK home'],
                  ['3 kWp', '~270–330 kWh', '2–3 BHK home'],
                  ['5 kWp', '~450–550 kWh', '3–4 BHK home'],
                  ['10 kWp', '~900–1100 kWh', 'Large villa / commercial'],
                ].map(([size, gen, use]) => (
                  <tr class="border-b border-border last:border-0">
                    <td class="px-3 py-2 text-accent font-bold">{size}</td>
                    <td class="px-3 py-2 text-text-primary">{gen}</td>
                    <td class="px-3 py-2 text-text-muted">{use}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p>Generation estimates assume ~4 peak sun hours/day and 80% system efficiency. Actual generation varies by location, orientation, and shading.</p>
        </div>

        <div class="space-y-3 text-sm text-text-muted leading-relaxed">
          <h3 class="font-display font-semibold text-text-primary">On-Grid vs Off-Grid</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="rounded-lg border border-border bg-base p-4">
              <p class="font-semibold text-text-primary mb-1">On-Grid (Grid-tied)</p>
              <p class="text-xs text-text-muted leading-relaxed">Connected to the utility grid. Excess power is exported (net metering). No batteries required. Best ROI. Cannot supply power during grid outages.</p>
            </div>
            <div class="rounded-lg border border-border bg-base p-4">
              <p class="font-semibold text-text-primary mb-1">Off-Grid (with battery)</p>
              <p class="text-xs text-text-muted leading-relaxed">Fully independent of the grid. Requires battery storage, significantly increasing cost. Best for areas with frequent or long outages.</p>
            </div>
          </div>
        </div>

        <div class="flex gap-2.5 p-3.5 rounded-lg border" style="border-color:color-mix(in srgb, #3ecf6e, transparent 55%); background:color-mix(in srgb, #3ecf6e, transparent 90%)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:#3ecf6e" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd"/>
          </svg>
          <p class="text-xs leading-relaxed" style="color:#3ecf6e">In India, a typical on-grid rooftop solar system pays back in 4–6 years and has a 25-year panel lifespan, delivering 19+ years of near-free electricity.</p>
        </div>
      </div>

      <!-- ④ FAQ -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-3">
        <h2 class="font-display font-semibold text-text-primary text-lg">Frequently Asked Questions</h2>
        <div class="space-y-2">
          {[
            { q: 'How much roof area do I need for solar panels?', a: 'Each kWp of solar requires approximately 8–10 sq metres of unshaded roof area with good south-facing orientation. A 3 kWp system needs about 24–30 sq metres.' },
            { q: 'Will solar work during a power cut?', a: 'On-grid systems automatically shut off during grid outages (for safety of lineworkers). To have power during cuts, you need either an off-grid system with batteries, or a hybrid inverter with battery backup.' },
            { q: 'What government subsidies are available?', a: 'In India, the PM Surya Ghar scheme (2024) offers subsidies of up to ₹78,000 for residential systems up to 3 kW. Check the national portal or your state DISCOM for current rates and eligibility.' },
            { q: 'Do I need to clean solar panels?', a: 'Yes — dust, bird droppings, and debris reduce output by 15–25%. In most Indian climates, cleaning every 4–6 weeks is recommended. Many installers offer annual maintenance contracts.' },
          ].map(({ q, a }) => (
            <details class="rounded-lg border border-border bg-base group">
              <summary class="flex items-center justify-between gap-3 px-4 py-3.5 cursor-pointer list-none text-sm font-semibold text-text-primary">
                <span>{q}</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0 text-text-muted transition-transform group-open:rotate-180" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
                </svg>
              </summary>
              <p class="px-4 pb-4 pt-1 text-sm text-text-muted leading-relaxed">{a}</p>
            </details>
          ))}
        </div>
      </div>

      <!-- ⑤ Related Recommendations -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-3">
        <h2 class="font-display font-semibold text-text-primary text-lg">Related Recommendations</h2>
        <p class="text-sm text-text-muted">Your load calculation also informs these selections.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <a href="/recommendations/mcb" class="flex items-center gap-3 p-3.5 rounded-lg border border-border bg-base hover:border-accent/50 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-accent flex-shrink-0" aria-hidden="true">
              <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs font-mono uppercase tracking-widest text-text-muted">MCB</p>
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">Breaker Rating →</p>
            </div>
          </a>
          <a href="/recommendations/cable" class="flex items-center gap-3 p-3.5 rounded-lg border border-border bg-base hover:border-accent/50 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5 text-accent flex-shrink-0" aria-hidden="true">
              <path d="M4 12h16M7 5v14M17 5v14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs font-mono uppercase tracking-widest text-text-muted">Cable</p>
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">Wire Size →</p>
            </div>
          </a>
          <a href="/recommendations/inverter" class="flex items-center gap-3 p-3.5 rounded-lg border border-border bg-base hover:border-accent/50 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-accent flex-shrink-0" aria-hidden="true">
              <path d="M4 7h16a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Zm14 2H6v6h12V9Zm2-3h1v2h-1V6Zm-17 0H2v2h1V6Z"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs font-mono uppercase tracking-widest text-text-muted">Inverter</p>
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">UPS Size →</p>
            </div>
          </a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
import type { Appliance } from '@/types';
import { calculateTotals } from '@/utils/calculations';
import { calculateInsights } from '@/utils/insights';

const STORAGE_KEY = 'electricity_load_calculator_state';
const SOLAR_SIZES = [1, 2, 3, 5, 7, 10, 15, 20];

function setText(id: string, val: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

function initPage() {
  const emptyEl  = document.getElementById('rec-empty');
  const resultEl = document.getElementById('rec-result');

  const saved = localStorage.getItem(STORAGE_KEY);
  if (!saved) { if (emptyEl) emptyEl.style.display = ''; return; }

  let state: { appliances: Appliance[]; tariff?: number; maxCapacityKW?: number } | null = null;
  try { state = JSON.parse(saved); } catch { return; }

  const appliances: Appliance[] = state?.appliances ?? [];
  if (!Array.isArray(appliances) || !appliances.some(a => a.qty > 0)) {
    if (emptyEl) emptyEl.style.display = '';
    return;
  }

  const tariff      = typeof state?.tariff      === 'number' ? state.tariff      : 0;
  const maxCapacity = typeof state?.maxCapacityKW === 'number' ? state.maxCapacityKW : 5;
  const result   = calculateTotals(appliances, tariff, maxCapacity);
  const insights = calculateInsights(result.totalKW, result.monthlyKWh);

  if (emptyEl)  emptyEl.style.display  = 'none';
  if (resultEl) resultEl.style.display = '';

  const dailyKWh = result.dailyKWh;
  const calcKW   = dailyKWh / (4 * 0.8);
  const solarKW  = SOLAR_SIZES.find(s => s >= calcKW) ?? SOLAR_SIZES[SOLAR_SIZES.length - 1];

  setText('rec-value',     insights.recommendedSolar);
  setText('rec-context',   `To offset ~${Math.round(result.monthlyKWh)} kWh/month consumption`);
  setText('solar-monthly', Math.round(result.monthlyKWh).toString());
  setText('solar-monthly2', Math.round(result.monthlyKWh).toString());
  setText('solar-daily',   dailyKWh.toFixed(2));
  setText('solar-calc',    calcKW.toFixed(2));
  setText('solar-rating',  `${solarKW} kWp On-Grid System`);
}

document.addEventListener('astro:page-load', initPage);
</script>
