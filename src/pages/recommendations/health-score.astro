---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

const schemaGraph = [
  {
    "@type": "Article",
    "headline": "Understanding Your Electrical Health Score: Safety and Efficiency Metrics",
    "description": "Learn how we calculate your home's electrical health score based on load utilization, energy efficiency, safety readiness, and renewable potential.",
    "author": {
      "@type": "Organization",
      "name": "Electricity Load Calculator"
    }
  }
];
---

<BaseLayout
  title="Electrical Health Score Logic | Electricity Load Calculator"
  description="Deep dive into the logic behind the Electrical Health Score. Learn how load balance, appliance efficiency, and safety margins impact your score."
  keywords="electrical health score, energy efficiency metrics, load utilization, electrical safety assessment, residential power health"
  schemaGraph={schemaGraph}
>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Assessment', href: '/assessment' }, { label: 'Health Score Logic' }]} />

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-8 pb-16">
    <div class="max-w-2xl mx-auto space-y-4">

      <!-- Back link -->
      <a href="/assessment" class="group inline-flex items-center gap-2 px-4 py-2 rounded-xl border text-sm font-medium transition-all hover:shadow-lg active:scale-95" style="color:var(--accent); border-color:color-mix(in srgb,var(--accent),transparent 60%); background:color-mix(in srgb,var(--accent),transparent 92%)">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 transition-transform group-hover:-translate-x-1" aria-hidden="true">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd"/>
        </svg>
        Back to Assessment
      </a>

      <!-- ① Header -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8">
        <div class="flex items-start gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-base flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-accent" aria-hidden="true">
              <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.5 3c1.557 0 3.046.812 3.945 2.027A4.912 4.912 0 0115.395 3c2.786 0 5.25 2.322 5.25 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
            </svg>
          </span>
          <div class="pt-0.5">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1.5 text-text-muted">Assessment Logic</p>
            <h1 class="font-display font-bold text-2xl sm:text-3xl text-text-primary leading-tight">Electrical Health Score</h1>
          </div>
        </div>
      </div>

      <!-- ② Concept -->
      <div class="rounded-2xl border border-border bg-card p-6 sm:p-10 space-y-6 overflow-hidden relative group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-accent/5 rounded-full -mr-16 -mt-16 blur-3xl group-hover:bg-accent/10 transition-colors"></div>
        <div class="relative">
          <h2 class="font-display font-bold text-text-primary text-xl sm:text-2xl mb-4">The Logic of "Electrical Health"</h2>
          <p class="text-base text-text-muted leading-relaxed max-w-xl">
            Think of this score as a <span class="text-text-primary font-medium">fitness tracker for your home</span>. It doesn't just measure how much power you consume—it analyzes the quality, balance, and safety of that consumption.
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-6">
             {[
               { label: 'Poor', range: '0-40', color: '#ef4444', bg: 'rgba(239,68,68,0.1)' },
               { label: 'Fair', range: '41-60', color: '#fb923c', bg: 'rgba(251,146,60,0.1)' },
               { label: 'Good', range: '61-80', color: '#3ecf6e', bg: 'rgba(62,207,110,0.1)' },
               { label: 'Excellent', range: '81-100', color: '#22d3ee', bg: 'rgba(34,211,238,0.1)' }
             ].map(item => (
               <div class="text-center p-4 rounded-xl border border-border bg-base transition-transform hover:-translate-y-1">
                 <p class="text-[10px] font-mono font-bold uppercase tracking-widest mb-1.5" style={`color:${item.color}`}>{item.label}</p>
                 <p class="text-lg font-display font-bold text-text-primary">{item.range}</p>
                 <div class="h-1 w-8 mx-auto mt-2 rounded-full" style={`background:${item.color}`}></div>
               </div>
             ))}
          </div>
        </div>
      </div>

      <!-- ③ The Four Pillars -->
      <div class="space-y-6">
        <div class="flex items-center gap-4">
          <h2 class="font-display font-bold text-text-primary text-xl">The 4 Strategic Pillars</h2>
          <div class="h-px bg-border flex-1"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Pillar 1: Load Utilization -->
          <div class="rounded-2xl border border-border bg-card p-6 sm:p-8 flex flex-col justify-between hover:border-accent/40 transition-colors">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/></svg>
                </span>
                <span class="text-xs font-mono font-bold text-text-muted bg-base px-2.5 py-1 rounded-md border border-border">30 POINTS</span>
              </div>
              <h3 class="font-display font-bold text-text-primary text-lg mb-1">Load Utilization</h3>
              <p class="text-xs font-mono uppercase tracking-wider text-accent mb-4">Is your power capacity sized right?</p>
              <div class="bg-base/50 rounded-xl p-4 border border-border/50 mb-6">
                <p class="text-xs text-text-muted leading-relaxed">
                  <strong class="text-accent text-[13px] block mb-1">🎒 The Backpack Metaphor:</strong>
                  If your backpack is empty, it's a waste of a bag. If you pack it 100% full to bursting, the seams will rip. You want it packed comfortably in the sweet spot (50% – 80% full)!
                </p>
              </div>
            </div>
            <div class="space-y-4">
              <div class="grid grid-cols-3 gap-2 text-center text-[10px] font-mono font-bold">
                <div class="p-2 rounded-lg bg-base border border-border text-text-muted flex flex-col justify-center">
                  <span class="text-sm">💤</span>
                  <span class="mt-1">Underloaded</span>
                  <span class="text-text-muted text-[9px] font-normal">&lt; 30%</span>
                </div>
                <div class="p-2 rounded-lg bg-accent/10 border border-accent/30 text-accent flex flex-col justify-center">
                  <span class="text-sm">⭐</span>
                  <span class="mt-1">Sweet Spot</span>
                  <span class="text-accent text-[9px] font-bold">50% – 80%</span>
                </div>
                <div class="p-2 rounded-lg bg-base border border-border text-text-muted flex flex-col justify-center">
                  <span class="text-sm">🔥</span>
                  <span class="mt-1">Overloaded</span>
                  <span class="text-text-muted text-[9px] font-normal">&gt; 80%</span>
                </div>
              </div>
              <div class="space-y-1.5 pt-2">
                <div class="flex items-center justify-between text-[10px] font-mono text-text-muted uppercase tracking-wider">
                  <span>Usage Level Gauge</span>
                  <span class="text-accent font-bold">50% - 80% Target</span>
                </div>
                <div class="h-2 w-full bg-base rounded-full overflow-hidden relative border border-border">
                  <div class="absolute top-0 bottom-0 left-[50%] right-[20%] bg-accent/20"></div>
                  <div class="absolute h-full w-2 bg-accent rounded-full left-[70%] z-10"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Pillar 2: Energy Distribution -->
          <div class="rounded-2xl border border-border bg-card p-6 sm:p-8 flex flex-col justify-between hover:border-accent/40 transition-colors">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8Z"/><path d="M12 6v6l4 2"/></svg>
                </span>
                <span class="text-xs font-mono font-bold text-text-muted bg-base px-2.5 py-1 rounded-md border border-border">30 POINTS</span>
              </div>
              <h3 class="font-display font-bold text-text-primary text-lg mb-1">Energy Distribution</h3>
              <p class="text-xs font-mono uppercase tracking-wider text-accent mb-4">Are you harboring any power hogs?</p>
              <div class="bg-base/50 rounded-xl p-4 border border-border/50 mb-6">
                <p class="text-xs text-text-muted leading-relaxed">
                  <strong class="text-accent text-[13px] block mb-1">🍕 The Pizza Metaphor:</strong>
                  If one person eats 80% of a shared pizza, the others starve. Similarly, if a single appliance hogs more than 40% of your power, it is highly inefficient and needs an upgrade!
                </p>
              </div>
            </div>
            <div class="space-y-4">
              <div class="bg-base/40 border border-border rounded-xl p-3 space-y-3">
                <p class="text-[10px] font-mono uppercase tracking-wider text-text-muted text-center">Appliance Consumption Share</p>
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-2 border-r border-border/50 pr-2">
                    <div class="flex justify-between text-[9px] font-mono text-text-muted">
                      <span>⚠️ Power Hog</span>
                      <span class="text-red-500 font-bold">Bad</span>
                    </div>
                    <div class="space-y-1">
                      <div class="flex items-center gap-1.5">
                        <span class="text-[8px] font-mono text-text-muted w-6">AC</span>
                        <div class="h-2 flex-1 bg-red-500/20 rounded-full overflow-hidden">
                          <div class="h-full bg-red-500" style="width: 65%"></div>
                        </div>
                        <span class="text-[8px] font-mono text-red-500 font-bold">65%</span>
                      </div>
                      <div class="flex items-center gap-1.5">
                        <span class="text-[8px] font-mono text-text-muted w-6">Other</span>
                        <div class="h-2 flex-1 bg-base rounded-full overflow-hidden">
                          <div class="h-full bg-accent/40" style="width: 35%"></div>
                        </div>
                        <span class="text-[8px] font-mono text-text-muted">35%</span>
                      </div>
                    </div>
                  </div>
                  <div class="space-y-2 pl-2">
                    <div class="flex justify-between text-[9px] font-mono text-text-muted">
                      <span>✨ Balanced</span>
                      <span class="text-emerald-500 font-bold">Good</span>
                    </div>
                    <div class="space-y-1">
                      <div class="flex items-center gap-1.5">
                        <span class="text-[8px] font-mono text-text-muted w-6">AC</span>
                        <div class="h-2 flex-1 bg-emerald-500/20 rounded-full overflow-hidden">
                          <div class="h-full bg-emerald-500" style="width: 30%"></div>
                        </div>
                        <span class="text-[8px] font-mono text-emerald-500 font-bold">30%</span>
                      </div>
                      <div class="flex items-center gap-1.5">
                        <span class="text-[8px] font-mono text-text-muted w-6">Other</span>
                        <div class="h-2 flex-1 bg-base rounded-full overflow-hidden">
                          <div class="h-full bg-accent" style="width: 70%"></div>
                        </div>
                        <span class="text-[8px] font-mono text-text-muted">70%</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Pillar 3: Safety Readiness -->
          <div class="rounded-2xl border border-border bg-card p-6 sm:p-8 flex flex-col justify-between hover:border-accent/40 transition-colors">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5Z"/></svg>
                </span>
                <span class="text-xs font-mono font-bold text-text-muted bg-base px-2.5 py-1 rounded-md border border-border">20 POINTS</span>
              </div>
              <h3 class="font-display font-bold text-text-primary text-lg mb-1">Safety Readiness</h3>
              <p class="text-xs font-mono uppercase tracking-wider text-accent mb-4">Are you exceeding residential limits?</p>
              <div class="bg-base/50 rounded-xl p-4 border border-border/50 mb-6">
                <p class="text-xs text-text-muted leading-relaxed">
                  <strong class="text-accent text-[13px] block mb-1">🛣️ The Highway Metaphor:</strong>
                  A neighborhood street is built for cars, not giant cargo trucks. If your home draws factory-level power (Industrial), your wiring is under major stress and fire risk!
                </p>
              </div>
            </div>
            <div class="space-y-4">
              <div class="bg-base/40 border border-border rounded-xl p-3 flex flex-col justify-center">
                <div class="flex justify-between items-center text-[10px] font-mono text-text-muted mb-2">
                  <span>Wiring Stress level</span>
                  <span class="text-emerald-500 font-bold">Safe Limit &lt; 10kW</span>
                </div>
                <div class="grid grid-cols-3 gap-1 h-3">
                  <div class="h-full bg-emerald-500 rounded-l-md" title="Residential (< 5 kW) - Safe"></div>
                  <div class="h-full bg-amber-500" title="Moderate (5-10 kW) - Caution"></div>
                  <div class="h-full bg-red-500/20 rounded-r-md" title="Industrial (> 10 kW) - Overloaded"></div>
                </div>
                <div class="flex justify-between text-[8px] font-mono text-text-muted mt-1.5">
                  <span>Residential (Safe)</span>
                  <span>Moderate</span>
                  <span>Industrial (High Risk)</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Pillar 4: Renewable Potential -->
          <div class="rounded-2xl border border-border bg-card p-6 sm:p-8 flex flex-col justify-between hover:border-accent/40 transition-colors">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Zm0 2a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                </span>
                <span class="text-xs font-mono font-bold text-text-muted bg-base px-2.5 py-1 rounded-md border border-border">20 POINTS</span>
              </div>
              <h3 class="font-display font-bold text-text-primary text-lg mb-1">Solar ROI Potential</h3>
              <p class="text-xs font-mono uppercase tracking-wider text-accent mb-4">How fast will Solar pay for itself?</p>
              <div class="bg-base/50 rounded-xl p-4 border border-border/50 mb-6">
                <p class="text-xs text-text-muted leading-relaxed">
                  <strong class="text-accent text-[13px] block mb-1">🛒 The Wholesale Metaphor:</strong>
                  If you buy groceries in bulk, a warehouse club membership pays for itself instantly. The higher your electricity bills, the faster your solar investment pays off!
                </p>
              </div>
            </div>
            <div class="space-y-4">
              <div class="bg-base/40 border border-border rounded-xl p-3 space-y-3">
                <div class="flex justify-between items-center text-[10px] font-mono text-text-muted">
                  <span>Solar Payback Timeline</span>
                  <span class="text-accent font-bold">High Usage = Fast ROI</span>
                </div>
                <div class="relative pt-2">
                  <div class="flex justify-between text-[9px] font-mono text-text-muted z-10 relative">
                    <div class="flex flex-col items-center bg-base border border-border rounded px-1.5 py-0.5">
                      <span>Low Usage</span>
                      <span class="font-bold text-text-muted">7-10 Yrs ⏳</span>
                    </div>
                    <div class="flex flex-col items-center bg-accent/20 border border-accent/40 rounded px-1.5 py-0.5 text-accent">
                      <span>High Usage</span>
                      <span class="font-bold text-accent">3-4 Yrs 🚀</span>
                    </div>
                  </div>
                  <div class="absolute h-0.5 left-6 right-6 top-[20px] bg-border -z-0"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ④ Improvement Checklist -->
      <div class="space-y-6">
        <div class="flex items-center gap-4">
          <h2 class="font-display font-bold text-text-primary text-xl">Actionable Checklist</h2>
          <div class="h-px bg-border flex-1"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="p-6 rounded-2xl bg-card border border-border hover:border-accent/30 transition-all">
            <div class="flex items-center gap-3 mb-4">
              <div class="h-8 w-8 rounded-lg bg-success/10 flex items-center justify-center text-success">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd"/></svg>
              </div>
              <p class="text-xs font-bold text-text-primary uppercase tracking-widest">Energy Efficiency</p>
            </div>
            <ul class="text-xs text-text-muted space-y-4">
              <li class="flex gap-3">
                <span class="text-accent">•</span>
                <span><strong>Appliance Audit:</strong> Upgrade old refrigerators and fixed-speed ACs to 5-star inverter models.</span>
              </li>
              <li class="flex gap-3">
                <span class="text-accent">•</span>
                <span><strong>Standby Kill:</strong> Unplug non-essential electronics to eliminate "phantom" energy leaks.</span>
              </li>
            </ul>
          </div>
          
          <div class="p-6 rounded-2xl bg-card border border-border hover:border-accent/30 transition-all">
            <div class="flex items-center gap-3 mb-4">
              <div class="h-8 w-8 rounded-lg bg-accent/10 flex items-center justify-center text-accent">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path d="M10 2a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 10 2ZM10 15a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 10 15ZM10 7a3 3 0 1 0 0 6 3 3 0 0 0 0-6ZM15.657 5.404a.75.75 0 1 0-1.06-1.06l-1.061 1.06a.75.75 0 0 0 1.06 1.061l1.061-1.06ZM6.464 14.596a.75.75 0 1 0-1.06-1.06l-1.06 1.06a.75.75 0 0 0 1.06 1.061l1.06-1.06ZM18 10a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5A.75.75 0 0 1 18 10ZM5.5 10a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5A.75.75 0 0 1 5.5 10ZM15.657 14.596a.75.75 0 1 1-1.06 1.06l-1.06-1.06a.75.75 0 1 1 1.06-1.061l1.06 1.06ZM6.464 5.404a.75.75 0 1 1-1.06 1.06l-1.061-1.06a.75.75 0 1 1 1.06-1.061l1.061 1.06Z"/></svg>
              </div>
              <p class="text-xs font-bold text-text-primary uppercase tracking-widest">Load Balancing</p>
            </div>
            <ul class="text-xs text-text-muted space-y-4">
              <li class="flex gap-3">
                <span class="text-accent">•</span>
                <span><strong>Peak Shift:</strong> Move high-energy tasks (laundry, dishwashing) to non-peak hours.</span>
              </li>
              <li class="flex gap-3">
                <span class="text-accent">•</span>
                <span><strong>Anti-Stacking:</strong> Never run your Water Geyser, Microwave, and AC on the same circuit at once.</span>
              </li>
            </ul>
          </div>

          <div class="p-6 rounded-2xl bg-card border border-border sm:col-span-2 hover:border-accent/30 transition-all">
            <div class="flex items-center gap-3 mb-4">
              <div class="h-8 w-8 rounded-lg bg-cyan-500/10 flex items-center justify-center text-cyan-500">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-11.25a.75.75 0 0 0-1.5 0v2.5h-2.5a.75.75 0 0 0 0 1.5h2.5v2.5a.75.75 0 0 0 1.5 0v-2.5h2.5a.75.75 0 0 0 0-1.5h-2.5v-2.5Z" clip-rule="evenodd"/></svg>
              </div>
              <p class="text-xs font-bold text-text-primary uppercase tracking-widest">Renewable Readiness</p>
            </div>
            <ul class="text-xs text-text-muted grid grid-cols-1 sm:grid-cols-2 gap-4">
              <li class="flex gap-3">
                <span class="text-accent">•</span>
                <span><strong>Solar Sizing:</strong> Use our Solar Recommendation to offset your heaviest consumption periods.</span>
              </li>
              <li class="flex gap-3">
                <span class="text-accent">•</span>
                <span><strong>Trend Tracking:</strong> Keep a log of monthly unit trends to calculate your exact ROI for solar panels.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- ⑤ FAQ -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-3">
        <h2 class="font-display font-semibold text-text-primary text-lg">Frequently Asked Questions</h2>
        <div class="space-y-2">
          {[
            {
              q: 'Does a low score mean my house is dangerous?',
