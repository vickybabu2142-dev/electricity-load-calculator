---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

const schemaGraph = [
  {
    "@type": "WebPage",
    "name": "Voltage Stabilizer Sizing Guide",
    "description": "Personalized mainline voltage stabilizer sizing recommendation based on your specific household electrical load.",
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://electricityloadcalculator.com" },
        { "@type": "ListItem", "position": 2, "name": "Assessment", "item": "https://electricityloadcalculator.com/assessment" },
        { "@type": "ListItem", "position": 3, "name": "Stabilizer Recommendation" }
      ]
    }
  }
];
---

<BaseLayout
  title="Mainline Stabilizer Recommendation | Electricity Load Calculator"
  description="Determine the correct mainline voltage stabilizer size for your home. Protect your electronics from voltage swings and spikes with engineering-based sizing."
  keywords="voltage stabilizer recommendation, mainline stabilizer sizing, home stabilizer calculation, surge protector, voltage regulation"
  schemaGraph={schemaGraph}
>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Assessment', href: '/assessment' }, { label: 'Stabilizer Recommendation' }]} />

  <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-8 pb-16">
    <div class="max-w-2xl mx-auto space-y-4">

      <!-- Back link -->
      <a href="/assessment" class="flex-shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-lg border text-sm font-medium transition-colors" style="color:var(--accent); border-color:color-mix(in srgb,var(--accent),transparent 60%); background:color-mix(in srgb,var(--accent),transparent 92%)">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd"/>
        </svg>
        Back to Assessment
      </a>

      <!-- ① Header -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8">
        <div class="flex items-start gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-xl border border-border bg-base flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" style="color:#F43F5E" aria-hidden="true">
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-1 6h2v5h-2V7zm0 7h2v2h-2v-2z"/>
            </svg>
          </span>
          <div class="pt-0.5">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-1.5 text-text-muted">Stabilizer Recommendation</p>
            <h1 class="font-display font-bold text-2xl sm:text-3xl text-text-primary leading-tight">Voltage Stabilizer</h1>
          </div>
        </div>
      </div>

      <!-- ② Personalised Recommendation -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-4">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Your Recommendation</p>

        <!-- Loading / Empty state -->
        <div id="rec-empty" class="text-center py-4 text-sm text-text-muted">
          No assessment data found.
          <a href="/" class="text-accent hover:underline ml-1">Calculate your load first →</a>
        </div>

        <!-- Populated result -->
        <div id="rec-result" style="display:none">
          <div class="rounded-xl border border-border bg-base p-6 text-center mb-4">
            <p class="text-[10px] font-mono uppercase tracking-widest mb-3 text-text-muted">Recommended Mainline Sizing</p>
            <p id="rec-value" class="font-display font-bold text-5xl tracking-tight" style="color:#F43F5E">—</p>
            <p id="rec-context" class="text-sm text-text-muted mt-3"></p>
          </div>

          <!-- Calculation steps -->
          <div class="space-y-2">
            <div class="flex items-center gap-3 p-3 rounded-lg bg-base border border-border">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-rose-500/10 text-rose-500 text-xs font-mono font-bold flex-shrink-0">1</span>
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-muted">Your connected load</p>
                <p class="font-mono font-semibold text-text-primary"><span id="stab-load">—</span> kW</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg bg-base border border-border">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-rose-500/10 text-rose-500 text-xs font-mono font-bold flex-shrink-0">2</span>
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-muted">Sizing factor overhead (30% safety margin for stabilizer coils)</p>
                <p class="font-mono font-semibold text-text-primary">Multiplier = 1.3</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg bg-base border border-border">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-rose-500/10 text-rose-500 text-xs font-mono font-bold flex-shrink-0">3</span>
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-muted">Required capacity (<span id="stab-load-step3">—</span> kW × 1.3)</p>
                <p class="font-mono font-semibold text-text-primary">= <span id="stab-req">—</span> kVA</p>
              </div>
            </div>
            <div class="flex items-center gap-3 p-3 rounded-lg border bg-rose-500/5" style="border-color:color-mix(in srgb, #F43F5E, transparent 55%);">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-rose-500 text-white text-xs font-mono font-bold flex-shrink-0">4</span>
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-muted">Nearest standard market rating above <span id="stab-req2">—</span> kVA</p>
                <p class="font-mono font-bold text-text-primary" id="stab-rating">—</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ③ Sizing & Engineering Principles -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-6">
        <div>
          <h2 class="font-display font-bold text-lg text-text-primary mb-2">Why install a Mainline Stabilizer?</h2>
          <p class="text-sm text-text-muted leading-relaxed">
            Mainline voltage stabilizers regulate the incoming power supply for your entire home. In areas with voltage swings (extremely low or high grid voltage), stabilizers protect expensive motors (ACs, pumps, refrigerators) and electronics (TVs, computers) from burning out.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="font-display font-semibold text-text-primary text-sm uppercase tracking-wider">Key Selection Factors</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-4 rounded-xl border border-border bg-base space-y-1">
              <p class="font-semibold text-text-primary text-sm">Working Voltage Range</p>
              <p class="text-xs text-text-muted leading-relaxed">
                Choose a stabilizer that matches your local fluctuations (e.g., 90V–300V range for severe drops, or 130V–280V for moderate issues).
              </p>
            </div>
            <div class="p-4 rounded-xl border border-border bg-base space-y-1">
              <p class="font-semibold text-text-primary text-sm">Coil Material</p>
              <p class="text-xs text-text-muted leading-relaxed">
                Opt for <strong>100% Copper winding</strong> stabilizers. They exhibit higher conductivity, run cooler, and last longer than aluminium alternatives.
              </p>
            </div>
            <div class="p-4 rounded-xl border border-border bg-base space-y-1">
              <p class="font-semibold text-text-primary text-sm">Under/Over Voltage Cut-off</p>
              <p class="text-xs text-text-muted leading-relaxed">
                Ensures the stabilizer trips/disconnects power completely if the voltage spikes beyond safe operational ranges.
              </p>
            </div>
            <div class="p-4 rounded-xl border border-border bg-base space-y-1">
              <p class="font-semibold text-text-primary text-sm">IT/Sensitive Load Delay</p>
              <p class="text-xs text-text-muted leading-relaxed">
                A built-in Smart Time Delay System (ITDS) prevents sudden compressor restart surges right after power cuts, preserving mechanical life.
              </p>
            </div>
          </div>
        </div>

        <div class="border-t border-border pt-4">
          <h3 class="font-semibold text-text-primary text-sm mb-2">When do you need a stabilizer?</h3>
          <ul class="text-xs text-text-muted list-disc list-inside space-y-1.5 leading-relaxed">
            <li><strong>Severe Fluctuations:</strong> If light bulbs flicker frequently or dim/brighten abnormally.</li>
            <li><strong>Low Voltage Trips:</strong> If air conditioners shut down or struggle to compress because voltage drops below 190V.</li>
            <li><strong>Sensitive Electronic Loads:</strong> Smart home devices, gaming systems, and high-end IT systems are highly susceptible to voltage spikes.</li>
          </ul>
        </div>
      </div>

      <!-- ⑤ Related Recommendations -->
      <div class="rounded-xl border border-border bg-card p-6 sm:p-8 space-y-3">
        <h2 class="font-display font-semibold text-text-primary text-lg">Related Recommendations</h2>
        <p class="text-sm text-text-muted">Your load calculation also informs these selections.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <a href="/recommendations/mcb" class="flex items-center gap-3 p-3.5 rounded-lg border border-border bg-base hover:border-accent/50 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-accent flex-shrink-0" aria-hidden="true">
              <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs font-mono uppercase tracking-widest text-text-muted">MCB</p>
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">Breaker Size →</p>
            </div>
          </a>
          <a href="/recommendations/cable" class="flex items-center gap-3 p-3.5 rounded-lg border border-border bg-base hover:border-accent/50 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5 text-accent flex-shrink-0" aria-hidden="true">
              <path d="M4 12h16M7 5v14M17 5v14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs font-mono uppercase tracking-widest text-text-muted">Cable</p>
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">Wire Size →</p>
            </div>
          </a>
          <a href="/recommendations/inverter" class="flex items-center gap-3 p-3.5 rounded-lg border border-border bg-base hover:border-accent/50 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-accent flex-shrink-0" aria-hidden="true">
              <path d="M4 7h16a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Zm14 2H6v6h12V9Zm2-3h1v2h-1V6Zm-17 0H2v2h1V6Z"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs font-mono uppercase tracking-widest text-text-muted">Inverter</p>
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">UPS Size →</p>
            </div>
          </a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
import type { Appliance } from '@/types';
import { calculateTotals } from '@/utils/calculations';
import { calculateInsights } from '@/utils/insights';

const STORAGE_KEY = 'electricity_load_calculator_state';

function setText(id: string, val: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

function initPage() {
  const emptyEl  = document.getElementById('rec-empty');
  const resultEl = document.getElementById('rec-result');

  const saved = localStorage.getItem(STORAGE_KEY);
  if (!saved) {
    if (emptyEl)  emptyEl.style.display  = '';
    if (resultEl) resultEl.style.display = 'none';
    return;
  }

  let state: { appliances: Appliance[]; tariff?: number; maxCapacityKW?: number } | null = null;
  try { state = JSON.parse(saved); } catch { return; }

  const appliances: Appliance[] = state?.appliances ?? [];
  if (!Array.isArray(appliances) || !appliances.some(a => a.qty > 0)) {
    if (emptyEl)  emptyEl.style.display  = '';
    if (resultEl) resultEl.style.display = 'none';
    return;
  }

  const tariff      = typeof state?.tariff      === 'number' ? state.tariff      : 0;
  const maxCapacity = typeof state?.maxCapacityKW === 'number' ? state.maxCapacityKW : 5;
  const result   = calculateTotals(appliances, tariff, maxCapacity);
  const insights = calculateInsights(result.totalKW, result.monthlyKWh);

  if (emptyEl)  emptyEl.style.display  = 'none';
  if (resultEl) resultEl.style.display = '';

  // Compute steps
  const loadKW  = result.totalKW;
  const reqKVA  = loadKW * 1.3;

  setText('rec-value',          insights.recommendedStabilizer);
  setText('rec-context',        `For ${loadKW.toFixed(2)} kW connected load with a 30% surge overhead`);
  setText('stab-load',          loadKW.toFixed(2));
  setText('stab-load-step3',    loadKW.toFixed(2));
  setText('stab-req',           reqKVA.toFixed(2));
  setText('stab-req2',          reqKVA.toFixed(2));
  setText('stab-rating',        insights.recommendedStabilizer);
}

document.addEventListener('astro:page-load', initPage);
</script>
