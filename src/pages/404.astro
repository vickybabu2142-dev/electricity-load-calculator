---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page Not Found | Electricity Load Calculator"
  description="The page you're looking for doesn't exist. Head back to the Electricity Load Calculator home page."
>
  <div class="min-h-[70vh] flex flex-col items-center justify-center px-4 text-center animate-slide-up">

    <!-- Glowing bolt icon -->
    <div class="relative mb-8">
      <div class="absolute inset-0 rounded-full blur-2xl opacity-20" style="background: var(--accent); transform: scale(1.4);"></div>
      <div class="relative w-20 h-20 rounded-full flex items-center justify-center border border-border bg-card">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10" style="color: var(--accent)">
          <path d="m13 2-2 2.5h3L11 22l2-2.5h-3L13 2z"/>
        </svg>
      </div>
    </div>

    <!-- Error code -->
    <p class="font-mono text-xs tracking-[0.3em] uppercase text-text-muted mb-3">Error 404</p>

    <h1 class="font-display font-bold text-5xl sm:text-7xl text-text-primary mb-4 leading-none tracking-tight">
      Circuit <span style="color: var(--accent);">Broken</span>
    </h1>

    <p class="text-text-muted text-sm sm:text-base max-w-sm leading-relaxed mb-10">
      Looks like this page lost power. The URL you followed doesn't exist or may have been moved.
    </p>

    <!-- Actions -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm transition-opacity hover:opacity-90"
        style="background: var(--accent); color: var(--accent-text);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Back to Calculator
      </a>
      <a
        href="/contact-us"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm border border-border text-text-primary hover:border-accent hover:text-accent transition-colors"
      >
        Report an Issue
      </a>
    </div>

    <!-- Decorative divider -->
    <div class="mt-16 flex items-center gap-4 text-border">
      <div class="h-px w-16 bg-border"></div>
      <span class="font-mono text-[10px] tracking-widest uppercase text-text-muted">Quick Links</span>
      <div class="h-px w-16 bg-border"></div>
    </div>

    <!-- Quick nav links -->
    <nav class="mt-6 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-text-muted">
      <a href="/" class="hover:text-accent transition-colors">Home</a>
      <a href="/about-us" class="hover:text-accent transition-colors">About</a>
      <a href="/contact-us" class="hover:text-accent transition-colors">Contact</a>
      <a href="/privacy-policy" class="hover:text-accent transition-colors">Privacy Policy</a>
    </nav>

  </div>
</BaseLayout>
