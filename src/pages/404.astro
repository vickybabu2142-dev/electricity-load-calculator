---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page Not Found | Electricity Load Calculator"
  description="The page you're looking for doesn't exist. Head back to the Electricity Load Calculator home page."
>
  <main class="min-h-[70vh] flex flex-col items-center justify-center px-4 text-center animate-slide-up">

    <!-- Glowing bolt icon -->
    <div class="relative mb-8">
      <div class="absolute inset-0 rounded-full blur-2xl opacity-20" style="background: var(--accent); transform: scale(1.4);"></div>
      <div class="relative w-20 h-20 rounded-full flex items-center justify-center bg-base">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 text-accent">
          <path d="M13 2 L4.5 13 H10 L8.5 22 L19.5 11 H14 Z"/>
        </svg>
      </div>
    </div>

    <!-- Error code -->
    <p class="font-mono text-xs tracking-[0.3em] uppercase text-text-muted mb-3">Error 404</p>

    <h1 class="font-display font-bold text-5xl sm:text-7xl text-text-primary mb-4 leading-none tracking-tight">
      Circuit <span class="text-accent">Broken</span>
    </h1>

    <p class="text-text-muted text-sm sm:text-base max-w-sm leading-relaxed mb-10">
      Looks like this page lost power. The URL you followed doesn't exist or may have been moved.
    </p>

    <!-- Actions -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="btn-primary inline-flex items-center gap-2 px-6 py-3"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Back to Calculator
      </a>
      <a
        href="/contact-us"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm border border-border text-text-primary hover:border-accent hover:text-accent transition-colors"
      >
        Report an Issue
      </a>
    </div>

  </main>
</BaseLayout>
