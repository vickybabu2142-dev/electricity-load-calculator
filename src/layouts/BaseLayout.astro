---
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

// Self-host fonts for performance
import '@fontsource/khand/400.css';
import '@fontsource/khand/500.css';
import '@fontsource/khand/600.css';
import '@fontsource/khand/700.css';
import '@fontsource/hind/400.css';
import '@fontsource/hind/500.css';
import '@fontsource/hind/600.css';
import '@fontsource/geist-mono/400.css';
import '@fontsource/geist-mono/600.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  breadcrumbSchema?: any;
  schemaGraph?: any[];
}

const {
  title = 'Electricity Load Calculator | Electrical Load Assessment Tool',
  description = "Free electrical load calculator for home. Calculate connected load, energy consumption in kW and kWh, get MCB, cable, inverter & solar recommendations, and assess your electrical health score.",
  keywords = "electricity load calculator, electrical load calculator, home load calculator, connected load calculator, power consumption calculator, electrical load assessment, house wiring load calculation, load calculation for AC, load calculation for home in India, appliance power calculator, electricity load calculator in kw for home, electricity load calculator in kva, electricity load calculator for home, electricity load calculator in kw, bijli load calculator, house electricity load calculator, energy cost estimator",
  breadcrumbSchema,
  schemaGraph = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname.replace(/\/$/, '') || '/', Astro.site ?? Astro.url);
const ogImage = new URL('/web-app-manifest-512x512.png', Astro.site ?? Astro.url).href;

// Default software application schema (primarily for the home page)
const defaultSoftwareSchema = {
  "@type": "SoftwareApplication",
  "name": "Electricity Load Calculator",
  "url": canonicalURL.origin,
  "operatingSystem": "Web",
  "applicationCategory": "UtilitiesApplication",
  "applicationSubCategory": "Engineering/Utility",
  "description": "Free electrical load calculator for home. Calculate connected load, energy consumption in kW and kWh, get MCB, cable, inverter & solar recommendations, and assess your electrical health score.",
  "screenshot": ogImage,
  "softwareVersion": "1.0.0",
  "author": {
    "@type": "Organization",
    "name": "Electricity Load Calculator",
    "url": canonicalURL.origin,
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
  },
  "featureList": [
    "Real-time load calculation in Watts and kW",
    "Daily and monthly energy consumption analysis (kWh)",
    "MCB, cable, inverter, and solar recommendations",
    "Electrical health score assessment",
    "Optional Energy Cost Estimator (user-provided rate)",
    "Professional PDF report generation",
    "Custom appliance support"
  ]
};

const finalSchema = {
  "@context": "https://schema.org",
  "@graph": [
    ...(schemaGraph.length > 0 ? schemaGraph : [defaultSoftwareSchema]),
    {
      "@type": "WebSite",
      "name": "Electricity Load Calculator",
      "url": canonicalURL.origin,
      "description": "Free online electrical load assessment tool — calculate connected load, energy consumption, get MCB/cable/inverter/solar recommendations, and assess your electrical health score.",
    },
    ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <title>{title}</title>

    <!-- Performance: Preconnect to key origins -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />

    <!-- Inline script to apply theme immediately -->
    <script is:inline>
      const applyTheme = () => {
        if (localStorage.getItem('color-theme') === 'light') {
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.remove('light');
        }
      };

      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <!-- Favicon -->
   <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
   <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
   <link rel="shortcut icon" href="/favicon.ico" />
   <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
   <meta name="apple-mobile-web-app-title" content="ElectricLoad" />
   <link rel="manifest" href="/site.webmanifest" />
    <ClientRouter />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-N75LMQQ1LE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-N75LMQQ1LE');
    </script>
  </head>
  <body>
    <SiteHeader />
    <slot />
    <SiteFooter />
  </body>
</html>
